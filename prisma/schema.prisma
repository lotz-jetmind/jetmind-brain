model TechnicalQuery {
  id          String   @id @default(cuid())

  // ── References (all optional \u2014 TQ can come from any context) ──
  defectId      String?  @unique // Legacy: from a single defect
  workOrderId   String?          // From a WO task
  workPackId    String?          // From a work pack

  // ── Content ──────────────────────────────────────────────────
  tqRef       String   @default("")  // e.g. "TQ-2026-0042"
  title       String   @default("") // Short title / subject
  category    String   @default("AMM")   // AMM | SRM | IPC | SB | EO | OTHER
  addressee   String   @default("")  // MRO / Manufacturer / DOA
  priority    String   @default("ROUTINE") // AOG | URGENT | ROUTINE
  docRef      String?  // Document reference
  pageSection String?  // Page / Section / Rev
  description String?  // Problem description (long)
  question    String   @default("") // The actual question
  response    String?  // Filled in when answered
  part21DOA   String?

  // ── People ──────────────────────────────────────────────────
  raiserName  String?
  raiserAuth  String?  // Licence / position

  // ── Status & Tracking ────────────────────────────────────────
  status      String   @default("OPEN") // OPEN | SENT | ANSWERED | CLOSED
  generatedPdfAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Relations ────────────────────────────────────────────────
  defect      Defect?  @relation(fields: [defectId], references: [id])
  taskRefs    TQTaskRef[]

  @@index([status])
  @@index([workOrderId])
  @@index([createdAt])
}

model TQTaskRef {
  id               String         @id @default(cuid())
  tqId             String
  taskId           String?        // WorkOrderTask id
  taskTitle        String
  taskReference    String?
  source           String         // WORK_ORDER | MEL | DEFERRED | AMP
  contextRef       String?        // WO number, MEL ref, etc.
  tq               TechnicalQuery @relation(fields: [tqId], references: [id], onDelete: Cascade)

  @@index([tqId])
}

