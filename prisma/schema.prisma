// ─── Pricing Profile System ───────────────────────────────────────────────────
// FeeScheduleProfile: named fee setup (block hour, crew, pax, fuel stop, etc.)
// type=STANDARD → default for aircraft  |  type=SPECIAL → selectable per quote
// AirportCostProfile: collection of airport mask rules (like cj2.csv)
// AircraftPricingAssignment: aircraft → defaultFeeProfile + airportProfile
// AircraftSpecialProfile: which SPECIAL profiles are available for an aircraft

/// Named fee schedule (e.g. "CJ2 Standard", "Jetcard Rates", "VIP Wet Lease")
model FeeScheduleProfile {
  id          String  @id @default(cuid())
  name        String // "CJ2 Standard"
  type        String  @default("STANDARD") // STANDARD | SPECIAL
  description String? @db.Text // "Jetcard flat rates"
  currency    String  @default("EUR")

  // ── Block time ──────────────────────────────────────
  blockHourFee     Float? // EUR per block hour
  fuelBlockHourFee Float? // additional fuel cost per BH

  // ── Crew ────────────────────────────────────────────
  crewChargePerDay Float? // EUR per calendar day
  crewLayoverFee   Float? // EUR per night outside home base
  secondPilotFee   Float?

  // ── Per-flight fees ─────────────────────────────────
  overnightFee Float? // EUR per overnight stop
  fuelStopFee  Float? // EUR per fuel stop
  paxFee       Float? // EUR per departure PAX

  // ── Minimums ────────────────────────────────────────
  minimumTripFee  Float?
  minimumDailyFee Float?

  // ── Block-hour discount ─────────────────────────────
  discountAfterHours Float? @default(0) // after N BH in one trip
  discountPct        Float? @default(0) // discount %

  // ── Fixed routes (JSON array) ────────────────────────
  // [{route:"EDDM-EGLL", price:8500, currency:"EUR", validFrom:..., validTo:...}]
  fixedRoutesJson String @default("[]")

  // ── Audit ────────────────────────────────────────────
  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultAssignments AircraftPricingAssignment[] @relation("DefaultFeeProfile")
  specialProfiles    AircraftSpecialProfile[]
  quoteOverrides     Quote[]                     @relation("QuoteFeeProfile")

  @@index([type])
  @@index([isActive])
}

/// Named collection of airport fee rules — importable via CSV or OCR
model AirportCostProfile {
  id          String  @id @default(cuid())
  name        String // "CJ2 Airport Costs"
  description String? @db.Text
  currency    String  @default("EUR")

  // Cached median landing fee (recalculated after CSV/OCR import)
  medianLandingFee Float?

  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules       AirportFeeRule[]
  assignments AircraftPricingAssignment[]

  @@index([isActive])
}

/// Single row of airport fee rule — ICAO mask + fee columns
/// Exact match (EDDM) beats wildcard (EG*) beats (E*) beats median fallback
model AirportFeeRule {
  id        String  @id @default(cuid())
  profileId String
  mask      String // e.g. "EDDM", "EG*", "LE*", "LT*"
  note      String?
  currency  String  @default("EUR")

  landingsFee         Float?
  arrivalPaxFee       Float?
  departurePaxFee     Float?
  sundayLanding       Float?
  sundayDeparture     Float?
  saturdayLanding     Float?
  saturdayDeparture   Float?
  parkingHourly       Float?
  parkingPer24h       Float?
  airportOvernightFee Float?
  extraHighFuelCost   Float?
  petFee              Float?
  nightLanding        Float?
  airportExtensionFee Float?
  hangarFee           Float?
  additionalFee       Float?
  fireRescueCat3      Float?

  // Source tracking for OCR imports
  source      String  @default("MANUAL") // MANUAL | CSV | OCR
  importBatch String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile AirportCostProfile @relation(fields: [profileId], references: [id])

  @@unique([profileId, mask])
  @@index([profileId])
  @@index([mask])
}

/// Links an aircraft to its default fee profile + airport cost profile.
/// One active assignment per aircraft.
model AircraftPricingAssignment {
  id         String @id @default(cuid())
  aircraftId String @unique // one assignment per aircraft

  defaultFeeProfileId String
  airportProfileId    String

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aircraft          Aircraft                 @relation(fields: [aircraftId], references: [id])
  defaultFeeProfile FeeScheduleProfile       @relation("DefaultFeeProfile", fields: [defaultFeeProfileId], references: [id])
  airportProfile    AirportCostProfile       @relation(fields: [airportProfileId], references: [id])
  specialProfiles   AircraftSpecialProfile[]

  @@index([aircraftId])
  @@index([defaultFeeProfileId])
  @@index([airportProfileId])
}

/// Junction: which SPECIAL FeeScheduleProfiles are available for a given aircraft
model AircraftSpecialProfile {
  id           String @id @default(cuid())
  assignmentId String
  feeProfileId String

  assignment AircraftPricingAssignment @relation(fields: [assignmentId], references: [id])
  feeProfile FeeScheduleProfile        @relation(fields: [feeProfileId], references: [id])

  @@unique([assignmentId, feeProfileId])
  @@index([assignmentId])
}

model FuelPrice {
  id           String    @id @default(cuid())
  icao         String // ICAO code for quick lookup (denormalized for CSV imports)
  airportId    String? // optional FK – populated when Airport record exists
  supplier     String?
  pricePerUnit Float
  currency     String    @default("EUR")
  unit         String    @default("KG")
  validFrom    DateTime
  validTo      DateTime?
  isCurrent    Boolean   @default(true)
  source       String    @default("MANUAL") // MANUAL | CSV_IMPORT
