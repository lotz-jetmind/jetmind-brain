// ──────────────────────────────────────────────────────────────────────────────
// SUPPLIER / APPROVED ORGANISATION REGISTRY
// Part-M Subpart G / Part-145 / Part-147 — approved contractors, MROs, fuel
// suppliers, ground handlers, and other safety-relevant service providers.
// ──────────────────────────────────────────────────────────────────────────────

model camo_Supplier {
  id            String   @id @default(cuid())
  orgId         String   @default("default")

  // ── Identity ───────────────────────────────────────────────────────────────
  name          String
  code          String?  // Internal reference code, e.g. "SUP-2026-003"
  category      String   // APPROVED_MRO | PART145 | PART147 | FUEL | GROUND_HANDLING | CATERING | OTHER
  approvalType  String   // EASA_PART145 | EASA_PART147 | EASA_PART_M | NATIONAL | NONE
  approvalNumber String? // e.g. "D.145.0001"
  country       String?  // ISO-3166 country code

  // ── Contact ────────────────────────────────────────────────────────────────
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  address       String?  @db.Text
  website       String?

  // ── Approval / Certification ───────────────────────────────────────────────
  approvalScope String?  @db.Text // e.g. "B1, B2, C — A320 family"
  isActive      Boolean  @default(true)
  approvalExpiry DateTime? // When their Part-145/Part-147 approval expires
  lastAuditDate  DateTime?
  nextAuditDue   DateTime?
  auditResult    String?  // SATISFACTORY | UNSATISFACTORY | CONDITIONAL | NOT_AUDITED

  // ── Risk & Performance ─────────────────────────────────────────────────────
  riskRating    String   @default("UNRATED") // LOW | MEDIUM | HIGH | UNRATED
  performanceScore Int?  // 0–100 composite score
  openFindings  Int      @default(0)
  notes         String?  @db.Text

  // ── Contracts ──────────────────────────────────────────────────────────────
  contracts     camo_SupplierContract[]

  // ── Lifecycle ──────────────────────────────────────────────────────────────
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?

  @@index([orgId])
  @@index([category])
  @@index([approvalExpiry])
  @@index([isActive])
}

model camo_SupplierContract {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      camo_Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  contractRef   String   // e.g. "CNT-2026-043"
  description   String?  @db.Text
  services      String?  // JSON array of service types
  startDate     DateTime
  endDate       DateTime?
  value         Decimal? // Contract value (EUR)
  currency      String   @default("EUR")
  status        String   @default("ACTIVE") // ACTIVE | EXPIRED | TERMINATED | SUSPENDED
  documentUrl   String?  // Link to signed contract

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([supplierId])
  @@index([status])
  @@index([endDate])
}

// ──────────────────────────────────────────────────────────────────────────────
// LESSONS LEARNED REGISTER
// IS-BAO §8.6 · ICAO Doc 9859 §7.4 — Formal capture and dissemination of
// safety lessons derived from investigations, occurrences, and audits.
// ──────────────────────────────────────────────────────────────────────────────

model sms_lessons_learned {
  id              String   @id @default(cuid())
  orgId           String   @default("default")

  // ── Reference ─────────────────────────────────────────────────────────────
  lesson_number   String   @unique // e.g. "LL-2026-001"
  title           String
  description     String   @db.Text
  lesson_text     String   @db.Text // The actual lesson to be learned

  // ── Categorisation ────────────────────────────────────────────────────────
  category        String   // HUMAN_FACTORS | TECHNICAL | OPERATIONAL | PROCEDURAL | ORGANISATIONAL
  risk_area       String?  // e.g. "Ground Operations", "Fuel Management"
  easa_category   String?  // ADREP category code

  // ── Source ────────────────────────────────────────────────────────────────
  source_type     String   // OCCURRENCE | INVESTIGATION | AUDIT | EXTERNAL | TREND
  source_ref      String?  // Occurrence number, audit number, ECCAIRS ref, etc.
  occurrence_id   String?

  // ── Dissemination ─────────────────────────────────────────────────────────
  target_audiences String  @default("[]") // JSON array: ["CREW", "CAMO", "OPS", "ALL"]
  bulletin_sent   Boolean  @default(false)
  bulletin_id     String?  // mod7_safety_bulletins.id if bulletin was created

  // ── Status ────────────────────────────────────────────────────────────────
  status          String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  effectiveness   String?  // EFFECTIVE | PARTIALLY_EFFECTIVE | NOT_EFFECTIVE | NOT_ASSESSED

  // ── Lifecycle ─────────────────────────────────────────────────────────────
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  published_at    DateTime?
  created_by      String?

  @@index([orgId])
  @@index([status])
  @@index([category])
  @@index([source_type])
}

// ── CAMO: Competency Assessment (CA010) ──────────────────────────────────────

model CompetencyAssessment {
