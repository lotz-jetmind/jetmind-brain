// ─── HITL: AI Human-in-the-Loop Approval Queue ─────────────────────────────
// Every AI-generated action that is regulatorily relevant or irreversible
// must pass through this queue before it is executed.

model sys_ai_hitl_item {
  id           String  @id @default(uuid())
  domain       String // SAFETY | CAPA | AUDIT | MEL | QUOTE | ROSTER | MAINTENANCE
  action_type  String // TRIAGE | RCA | AUDIT_QUESTIONS | MEL_MAP | OCCURRENCE_SUMMARY | REGULATION_SCAN
  entity_id    String? // FK to the entity this item relates to (occurrenceId, capaId, etc.)
  entity_label String? // Human-readable label e.g. "Occurrence OCC-2026-042"

  ai_payload String // JSON: the full AI suggestion
  confidence Float   @default(0.0) // 0.0 – 1.0
  rationale  String? // AI explanation for its suggestion

  status String @default("PENDING") // PENDING | APPROVED | MODIFIED | REJECTED | EXPIRED

  assigned_to   String? // userId of who should review this
  reviewed_by   String? // userId who reviewed
  reviewed_at   DateTime?
  review_notes  String?   @db.Text // Human comment on decision
  final_payload String? // JSON: the modified/approved output (may differ from ai_payload)

  created_at DateTime  @default(now())
  expires_at DateTime? // Optional hard deadline for time-sensitive items

  assignee User? @relation("HITLAssignee", fields: [assigned_to], references: [id])
  reviewer User? @relation("HITLReviewer", fields: [reviewed_by], references: [id])

  @@index([status, domain])
  @@index([assigned_to, status])
  @@index([status])
}

model sys_ai_daily_brief {
  id               String   @id @default(uuid())
  brief_date       DateTime @unique // Day this brief covers (midnight UTC)
  content          String // Markdown content of the brief
  context_snapshot String // JSON snapshot of KPIs used to generate the brief
  generated_at     DateTime // When Gemini generated this brief

  @@index([brief_date])
}

model sys_data_dictionaries {
  id           String  @id @default(uuid())
  category     String
  value        String
  display_name String? // Human-readable label (defaults to value)
  sort_order   Int? // For ordered lists
  is_active    Boolean @default(true)

