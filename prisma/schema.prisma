  updatedAt   DateTime @updatedAt

  entries     WorkloadEntry[]

  @@index([orgId])
  @@index([status])
  @@index([periodStart])
}

model WorkloadEntry {
  id         String @id @default(cuid())
  wlaId      String

  staffName  String
  staffRole  String
  fte        Float  @default(1.0)

  plannedHours   Float @default(0)
  actualHours    Float @default(0)
  overtimeHours  Float @default(0)
  trainingHours  Float @default(0)
  absenceHours   Float @default(0)

  workOrderCount Int   @default(0)
  arcCount       Int   @default(0)
  auditCount     Int   @default(0)

  workloadRating String @default("NORMAL")
  remarks        String?

  wla            WorkloadAnalysis @relation(fields: [wlaId], references: [id], onDelete: Cascade)

  @@index([wlaId])
}

// ─── Email Verification Token ─────────────────────────────────────────────────
// Used by the email-verification flow. identifier = user email address.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
