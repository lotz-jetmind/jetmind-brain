// ============================================================
// SQMS AUDITEE RESPONSE — Formal finding responses from auditees
// ============================================================

model sqms_AuditeeResponse {
  id               String    @id @default(cuid())
  auditId          String
  findingId        String?
  responseType     String    // ACCEPTED | DISPUTED | ACCEPTED_WITH_COMMENTS
  justification    String    @db.Text
  proposedCapaDate DateTime?
  reviewStatus     String    @default("PENDING")  // PENDING | ACCEPTED_BY_AUDITOR | ESCALATED
  reviewNote       String?   @db.Text
  submittedById    String
  reviewedById     String?
  reviewedAt       DateTime?
  submittedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  audit       sqms_Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  finding     sqms_Finding? @relation("FindingAuditeeResponse", fields: [findingId], references: [id])
  submittedBy User          @relation("AuditeeResponseSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User?         @relation("AuditeeResponseReviewer", fields: [reviewedById], references: [id])

  @@index([auditId])
  @@index([findingId])
}

// ============================================================
// SQMS REQUIREMENT EVIDENCE — Evidence linked to requirements
// ============================================================

model sqms_RequirementEvidence {
  id            String           @id @default(cuid())
  requirementId String
  requirement   sqms_Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  title         String
  description   String?          @db.Text
  evidenceType  String           @default("DOCUMENT")  // DOCUMENT | RECORD | OBSERVATION | TESTIMONY
  fileUrl       String?
  s3Key         String?   // S3/storage key for direct access
  mimeType      String?   // MIME type
  fileSizeBytes  Int?      // File size in bytes for display
  sha256         String?   // SHA-256 hash for evidence integrity
  uploadedByName  String?  // Denormalized uploader name for display for display (e.g. application/pdf)
  filename      String?   // Original file name for display
  uploadedAt    DateTime  @default(now())
  uploadedById  String
  uploadedBy    User             @relation("RequirementEvidenceUploader", fields: [uploadedById], references: [id])
  validFrom     DateTime         @default(now())
  validUntil    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([requirementId])
}


// ── PDF Archive — every generated PDF saved to Hetzner Object Storage ─────────
model sys_pdf_archive {
  id            String   @id @default(cuid())
  department    String                          // e.g. SAFETY, COMPLIANCE, CAMO
  docType       String                          // e.g. ERP_PLAN, ERP_EXERCISE_LOG, COMPLIANCE_REPORT
  fileName      String                          // e.g. ERP-Plan-2026-05-11.pdf
  s3Key         String                          // full key in Hetzner bucket
  s3Url         String                          // public URL
  fileSizeBytes Int?
  sha256        String?                         // SHA-256 of the PDF buffer
  generatedById String?                         // userId who triggered the download
  generatedBy   User?    @relation("PdfArchiveUser", fields: [generatedById], references: [id])
  generatedAt   DateTime @default(now())
  metadata      Json?                           // arbitrary extra context (revision, appendixId, etc.)

  @@index([department, docType])
  @@index([generatedAt])
}

// ─── Amendment Tracking ────────────────────────────────────────────────────────

