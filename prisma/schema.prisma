model sys_easa_certificates {
  id                   String    @id @default(uuid())
  title                String // e.g., "Medical Class 1" or "AOC"
  reference            String // e.g., "DE.CAMO.254 AOC"
  regulations          String? // JSON Array of regulations tied to this certificate
  validity_months      Int? // Default fallback validity in months (e.g., Medical = 12)
  is_infinite          Boolean   @default(false) // Certificate never expires (e.g., permanent approval)
  operator_expiry_date DateTime? // For operator-level certificates: when the operator's approval expires (optional)
  file_url             String?
  created_at           DateTime  @default(now())
}

// =========================================================================
// EASA COMPLIANCE MODULE
// =========================================================================

model AuditManual {
  id              String    @id @default(uuid())
  title           String
  department      String
  content         String
  findings        Finding[]
  scope_of_audits Audit[]   @relation("AuditManualScope")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// @deprecated Use sqms_Audit instead. This is the legacy pre-SQMS audit model.
/// Data migration required before deletion. Tracking: Audit item — old audit stack.
model Audit {
  id            String        @id @default(uuid())
  title         String
  auditor_name  String
  date          DateTime      @default(now())
  status        String        @default("OPEN")
  department    String
  target_vendor String?
  questions     Question[]
  scope_manuals AuditManual[] @relation("AuditManualScope")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model Question {
  id              String    @id @default(uuid())
  audit_id        String
  audit           Audit     @relation(fields: [audit_id], references: [id], onDelete: Cascade)
  text            String
  is_ai_generated Boolean   @default(false)
  findings        Finding[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// @deprecated Use sqms_Finding instead. Legacy pre-SQMS finding model.
/// Tracking: Audit item — old audit stack migration.
model Finding {
  id                     String       @id @default(uuid())
  question_id            String
  question               Question     @relation(fields: [question_id], references: [id], onDelete: Cascade)
  grading                String // Enforced at application level: 'LEVEL_1', 'LEVEL_2', 'OBSERVATION', 'COMPLIANT', 'N_A'
  justification          String?
  linked_manual_id       String?
  manual                 AuditManual? @relation(fields: [linked_manual_id], references: [id])
  dueDate                DateTime? // CAPA tracking: deadline for fix
  status                 String       @default("OPEN") // CAPA tracking: 'OPEN', 'CAPA_SUBMITTED', 'CLOSED'
  root_cause_analysis    String?
  corrective_action_plan String?
  evidences              Evidence[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([status])
}

/// @deprecated Use sqms_Evidence instead. Legacy pre-SQMS evidence model.
model Evidence {
  id         String   @id @default(uuid())
  finding_id String
  finding    Finding  @relation(fields: [finding_id], references: [id], onDelete: Cascade)
  file_url   String
  file_name  String
  createdAt  DateTime @default(now())
}

// ════════════════════════════════════════════════════════════════════════════
// AVIATION SQMS — Compliance & Audit Module (Phase 1)
// ════════════════════════════════════════════════════════════════════════════
// Integration note: References existing User model (id: String / cuid())
// All new models use sqms_ prefix to avoid collision with legacy audit models.
// Design Rule 1: sqms_ChecklistItem.requirementId is NEVER NULL (DB enforced)
// Design Rule 2: sqms_Verification role-check enforced in Server Action
// Design Rule 3: sqms_Evidence.fileHash (SHA-256) enforced before INSERT
// ════════════════════════════════════════════════════════════════════════════

// ─── MODULE 1: REGULATORY REQUIREMENTS ENGINE ────────────────────────────────
// NEW: sqms_ComplianceArticle — single source of truth for all regulation articles.
// Replaces sqms_RegulatoryFramework + sqms_Requirement (legacy kept for migration).
// Articles are seeded from built-in TypeScript data files (src/data/regulations/).

model sqms_ComplianceArticle {
  id           String  @id @default(cuid())
  orgId        String  // tenant isolation

  // ── Origin (from approval-framework-map.ts) ────────────────────────────────
  approvalCode  String  // "AOC", "CAMO", "IS-BAO-S2", "CARC-AOC" etc.
  authority     String  // "EASA", "IS-BAO", "CARC", "FAA" etc.
  part          String  // "ORO.GEN", "CAMO.A", "IS-BAO", "JOR-OPS" etc.
  articleRef    String  // "ORO.GEN.110", "ORO.GEN.110(a)" etc.
  title         String
  text          String  @db.Text
  sortOrder     Int     @default(0)

  // ── Hierarchy ──────────────────────────────────────────────────────────────
  parentId     String?
  parent       sqms_ComplianceArticle?  @relation("ArticleHierarchy", fields: [parentId], references: [id])
  children     sqms_ComplianceArticle[] @relation("ArticleHierarchy")

  // ── Operator configuration (per article) ──────────────────────────────────
  isApplicable   Boolean  @default(true)   // YES / NO
  isConditional  Boolean  @default(false)  // CONDITIONAL
  level          String   @default("SHALL") // SHALL / SHOULD / MAY
  auditFrequency String   @default("ANNUAL") // ANNUAL / BIANNUAL / AS_NEEDED / CONTINUOUS
  evidenceType   String   @default("DOCUMENT") // DOCUMENT / RECORD / CERTIFICATE / PROCEDURE / TRAINING
  exemptionNote  String?  // required when isApplicable = false

  // ── Audit linkage ─────────────────────────────────────────────────────────
  lastAuditedAt DateTime?
  nextAuditDue  DateTime?
  findings      sqms_Finding[]

  // ── AI ────────────────────────────────────────────────────────────────────
  aiQuestions   String?   // JSON array of generated audit questions
  aiGeneratedAt DateTime?

  // ── Compliance Status (written back after audit execution) ────────────────
  // NOT_ASSESSED (default) → COMPLIANT | PARTIAL | NON_COMPLIANT
  complianceStatus  String    @default("NOT_ASSESSED")
  lastReviewedAt    DateTime?
  lastReviewedBy    String?   // Auditor name (denormalized)

  auditSessions sqms_ArticleAuditSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, articleRef])
  @@index([orgId, approvalCode])
  @@index([orgId, part])
  @@index([orgId, isApplicable])
  @@index([orgId, complianceStatus])
}

// ─── COMPLIANCE AUDIT SESSION ─────────────────────────────────────────────────
// One session per article per audit.
// Stores the AI questions + auditor answers + computed outcome.
// On session close, complianceStatus is written back to sqms_ComplianceArticle.

model sqms_ArticleAuditSession {
  id          String   @id @default(cuid())
  auditId     String
  audit       sqms_Audit               @relation(fields: [auditId], references: [id], onDelete: Cascade)
  articleId   String
  article     sqms_ComplianceArticle   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // Questions from aiQuestions at the time the audit was created (snapshot)
  questionsJson String  @db.Text  // [{q, evidence, reference}]

  // Auditor answers: JSON map { "0": {response, note, findingRef}, ... }
  answersJson   String  @default("{}") @db.Text

  // Computed outcome once all questions answered
  // NOT_ASSESSED | COMPLIANT | PARTIAL | NON_COMPLIANT
  outcome       String  @default("NOT_ASSESSED")

  // Audit trail
  completedAt   DateTime?
  reviewedById  String?
  reviewedBy    User?    @relation("ArticleAuditSessionReviewer", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([auditId, articleId])
  @@index([auditId])
  @@index([articleId])
  @@index([outcome])
}

model sqms_RegulatoryFramework {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String
  authority      String
  version        String             @default("1.0")
  effectiveDate  DateTime?
  isActive       Boolean            @default(true)
  // Activation mode: how this framework is enabled
  activationMode String             @default("MANUAL") // APPROVAL | MANUAL | ALWAYS_ON
  linkedApproval String?            // e.g. "AOC", "CAMO", "IS-BAO-S1" — which approval activates this
  // Regulatory oversight
  reviewDueDate  DateTime?          // next scheduled review of applicability
  lastReviewedAt DateTime?
  lastReviewedBy String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  requirements   sqms_Requirement[]
}

model sqms_Requirement {
  id          String                   @id @default(cuid())
  frameworkId String
  framework   sqms_RegulatoryFramework @relation(fields: [frameworkId], references: [id])
  articleRef  String
  title       String
  text        String
  level       String                   @default("SHALL")
  parentId    String?
  parent      sqms_Requirement?        @relation("RequirementHierarchy", fields: [parentId], references: [id])
  children    sqms_Requirement[]       @relation("RequirementHierarchy")
  tags        String?
  isActive    Boolean                  @default(true)

  // ── Applicability & Compliance Matrix ─────────────────────────────────────
  isApplicable   Boolean   @default(false) // marked applicable by operator
  applicableNote String? // justification / scope note
  applicableAt   DateTime? // when marked applicable
  exemptionNote  String? // if not applicable: reason
  auditFrequency String? // ANNUAL | BIANNUAL | AS_NEEDED
  lastAuditedAt  DateTime? // populated from audit records
  nextAuditDue   DateTime? // computed or manually set

  // ── AI-generated fields ───────────────────────────────────────────────────
  aiQuestions   String? // JSON array of generated questions
  aiGeneratedAt DateTime? // when questions were generated

  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt
  checklistItems sqms_ChecklistItem[]
  findings       sqms_Finding[]
  auditRecords   sqms_RequirementAuditRecord[]

  @@index([frameworkId])
  evidence        sqms_RequirementEvidence[]
  @@index([articleRef])
  @@index([isApplicable])
}

// Tracks every time a requirement was covered in an audit
model sqms_RequirementAuditRecord {
  id            String           @id @default(cuid())
  requirementId String
  requirement   sqms_Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  auditId       String?
  audit         sqms_Audit?      @relation(fields: [auditId], references: [id], onDelete: Cascade)
  // For non-audit compliance activities (ARC, FTL review etc.)
  activityId    String? // FK to sqms_ComplianceActivity
  outcome       String           @default("COMPLIANT") // COMPLIANT | NON_COMPLIANT | OBSERVATION | NOT_ASSESSED
  notes         String?          @db.Text
  auditedAt     DateTime         @default(now())
  validUntil    DateTime? // Rolling expiry: auditedAt + 12 months
  auditorId     String?   // Who performed this audit record
  auditor       User?     @relation("RequirementAuditRecordAuditor", fields: [auditorId], references: [id])

  @@index([requirementId])
  @@index([auditId])
  @@index([activityId])
}

model sqms_ChecklistModule {
  id         String               @id @default(cuid())
  code       String               @unique
  title      String
  auditType  String
  department String?
  revision   String               @default("1.0")
  isActive   Boolean              @default(true)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  items      sqms_ChecklistItem[]
  audits     sqms_Audit[]
}

// DESIGN RULE 1: requirementId is NOT NULL — every question must have a
// regulatory basis. Enforced at DB level by the non-nullable FK.
model sqms_ChecklistItem {
  id            String               @id @default(cuid())
  moduleId      String
  module        sqms_ChecklistModule @relation(fields: [moduleId], references: [id])
  requirementId String
  requirement   sqms_Requirement     @relation(fields: [requirementId], references: [id])
  sequence      Int                  @default(0)
  questionText  String
  guidanceText  String?
  responseType  String               @default("OK_FINDING_NA")
  isCritical    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  responses     sqms_AuditResponse[]
  findings      sqms_Finding[]
  evidence      sqms_Evidence[]      @relation("ItemEvidence")

  @@index([moduleId])
  @@index([requirementId])
}

// =============================================================================
// SIGNAL HUB — Department-native collaboration & intelligence threads
// =============================================================================

// Each thread = one discussion + action space for a safety/compliance topic
model signal_thread {
  id           String   @id @default(uuid())

  title        String
  summary      String?  @db.Text   // Optional AI-generated or manual summary

  // Which department owns this thread (primary)
  department   String               // SAFETY | COMPLIANCE | CAMO | OPS | MANAGEMENT

  // Optional cross-department tags — appears in those feeds too
  // Stored as JSON array: ["COMPLIANCE", "MANAGEMENT"]
  cross_tags   String   @default("[]")

  priority     String   @default("MEDIUM")  // CRITICAL | HIGH | MEDIUM | LOW
  status       String   @default("OPEN")    // OPEN | IN_PROGRESS | PENDING_ACTION | RESOLVED

  // Source link — what triggered this thread
  source_type  String?  // OCCURRENCE | AUDIT_FINDING | SPI | REGULATION | NPA | ERP | RISK | MANUAL | OTHER
  source_id    String?  // ID of the linked record
  source_label String?  // Human-readable label for the source

  messages     signal_message[]
  actions      signal_action[]

  created_by_id String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  resolved_at   DateTime?

  created_by User? @relation("SignalThreadCreator", fields: [created_by_id], references: [id])

  @@index([department])
  @@index([status])
  @@index([priority])
  @@index([created_at])
}

// Chat messages inside a thread (human or AI)
model signal_message {
  id         String   @id @default(uuid())
  thread_id  String
  content    String   @db.Text
  is_ai      Boolean  @default(false)  // true = Brain/AI message
  author_id  String?
  author_name String?                  // Denormalized for AI messages
  created_at DateTime @default(now())

  thread    signal_thread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  author    User?         @relation("SignalMessageAuthor", fields: [author_id], references: [id])

  @@index([thread_id])
  @@index([created_at])
}

// Actions spawned from a thread (MOC, CAPA, Manual Update, SRB Agenda, etc.)
model signal_action {
  id          String   @id @default(uuid())
  thread_id   String
  action_type String   // MOC | MANUAL_UPDATE | CAPA | SRB_AGENDA | RISK_ASSESSMENT | AUTHORITY_RESPONSE | TASK
  title       String
  description String?  @db.Text
  assigned_to String?  // Free-text name or user ID
  due_date    DateTime?
  status      String   @default("OPEN")  // OPEN | IN_PROGRESS | DONE
  linked_id   String?  // ID of the created MOC/CAPA/etc. once executed
  created_at  DateTime @default(now())
  created_by_id String?

  thread     signal_thread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  created_by User?         @relation("SignalActionCreator", fields: [created_by_id], references: [id])

  @@index([thread_id])
  @@index([status])
}
// ─── MODULE 2: RBI SCHEDULER & AUDIT PLANNING ────────────────────────────────

model sqms_AuditableArea {
  id               String          @id @default(cuid())
  orgId            String          @default("") // tenant isolation
  name             String
  department       String
  regulatoryScope  String?
  rbiScore         Float           @default(0)
  areaType         String          @default("INTERNAL")  // INTERNAL | EXTERNAL | VENDOR
  vendorName       String?                              // Name of external vendor (when areaType=VENDOR)
  contractRef      String?                              // Contract/agreement reference                              // Name of external vendor (when areaType=VENDOR)
  rbiScoreDate     DateTime?
  lastAuditDate    DateTime?
  nextAuditDueDate DateTime?
  frequencyMonths  Int             @default(12)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  audits           sqms_Audit[]
  rbiFactors       sqms_RbiFactor?

  @@index([orgId])
}

model sqms_RbiFactor {
  id                    String             @id @default(cuid())
  areaId                String             @unique
  area                  sqms_AuditableArea @relation(fields: [areaId], references: [id])
  findingsLast24m       Int                @default(0)
  criticalFindingsCount Int                @default(0)
  overdueCapaCount      Int                @default(0)
  daysSinceLastAudit    Int                @default(0)
  calculatedScore       Float              @default(0)
  calculatedAt          DateTime           @default(now())

  @@index([areaId])
}

model sqms_Audit {
  id                  String                        @id @default(cuid())
  orgId               String                        @default("") // tenant isolation
  code                String                        @unique
  title               String
  areaId              String
  area                sqms_AuditableArea            @relation(fields: [areaId], references: [id])
  moduleId            String?
  module              sqms_ChecklistModule?         @relation(fields: [moduleId], references: [id])
  auditorId           String
  auditor             User                          @relation("sqms_AuditLead", fields: [auditorId], references: [id])
  auditeeId           String?
  auditee             User?                         @relation("sqms_AuditeeOf", fields: [auditeeId], references: [id])
  auditeeDepartmentId String?
  auditeeDepartment   Department?                   @relation(fields: [auditeeDepartmentId], references: [id])
  auditeeVendorId     String?
  auditeeVendor       Vendor?                       @relation(fields: [auditeeVendorId], references: [id])
  status              String                        @default("PLANNED")
  auditType           String                        @default("INTERNAL")
  plannedDate         DateTime?
  actualDate          DateTime?
  closureDate         DateTime?
  openingMeetingAt    DateTime?   // Phase 2: Opening meeting timestamp
  closingMeetingAt    DateTime?   // Phase 4: Closing meeting timestamp
  auditeeAcknowledgedAt DateTime? // Phase 5: Auditee acknowledgement
  objective           String?     @db.Text  // Audit scope and objectives
  previousAuditId     String?     // Link to previous audit for trend tracking
  frameworkIds        String?               // JSON array of framework IDs
  scopeNote           String?     @db.Text  // Free-text scope description
  openingMeetingNotes String?     @db.Text
  closingMeetingNotes String?     @db.Text
  auditeeAcknowledgedById String?           // Who acknowledged the audit
  auditeeAcknowledgedBy   User?   @relation("sqms_AuditeeAcknowledger", fields: [auditeeAcknowledgedById], references: [id])
  auditeeConfirmedAt  DateTime?
  findingCounter      Int       @default(0)
  findingCountObs     Int       @default(0)
  findingCountL1      Int       @default(0)
  findingCountL2      Int       @default(0)
  findingCountL3      Int       @default(0)
  notificationNote    String?   @db.Text
  isAdHoc             Boolean   @default(false) // Ad-hoc audit (not in programme)
  adHocReason         String?                   // Required when isAdHoc=true
  notifiedAt          DateTime?
  notificationSentAt  DateTime?                 // When the notification letter was sent
  startDate           DateTime?                 // Exact audit start date
  endDate             DateTime?                 // Exact audit end date
  coAuditorIds        String?                   // JSON array of co-auditor User IDs
  allQuestionsAnswered Boolean  @default(false) // Gate for Phase 4 closing

  rbiScore            Float?
  offlineSyncVersion  Int                           @default(0)
  cryptoHash          String?
  notes               String?                       @db.Text
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  responses           sqms_AuditResponse[]
  findings            sqms_Finding[]
  signatures          sqms_DigitalSignature[]
  requirementRecords  sqms_RequirementAuditRecord[]
  messages            sqms_AuditMessage[]
  previousAudit       sqms_Audit?          @relation("AuditFollowUp", fields: [previousAuditId], references: [id])
  followUpAudits      sqms_Audit[]         @relation("AuditFollowUp")
  auditeeResponses    sqms_AuditeeResponse[]
  articleAuditSessions sqms_ArticleAuditSession[]
  docRequests          sqms_AuditDocRequest[]      // Desktop Audit Datenraum

  @@index([auditorId])
  @@index([areaId])
  @@index([status])
  @@index([orgId])
}

// ─── Audit Communication Thread ──────────────────────────────────────────────
// Persistent message thread between auditor and auditee for a given audit.
// Supports finding references, file attachments, and read-receipts.
model sqms_AuditMessage {
  id          String     @id @default(cuid())
  auditId     String
  audit       sqms_Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User       @relation("sqms_AuditMessageSender", fields: [senderId], references: [id])
  // AUDITOR | AUDITEE | SYSTEM
  senderRole  String     @default("AUDITOR")
  body        String
  // Optional context — links message to a specific finding or checklist item
  findingId   String?
  itemId      String?
  // JSON array of { evidenceId, fileUrl, fileName } for inline attachments
  attachments String?    @default("[]")
  // ISO string when the other party read this message
  readAt      DateTime?
  createdAt   DateTime   @default(now())

  @@index([auditId, createdAt])
  @@index([senderId])
}

// ─── Desktop Audit — Datenraum (Document Request List) ───────────────────────
// Auditor creates document requests → Auditee uploads → Auditor reviews.
// Forms the evidence base for a remote / desktop audit.
model sqms_AuditDocRequest {
  id            String     @id @default(cuid())
  auditId       String
  audit         sqms_Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  // What is being requested
  title         String
  description   String?    @db.Text
  referenceCode String?    // e.g. "EASA Part-M M.A.302" or "CAME A.1"
  required      Boolean    @default(true)

  // Workflow status: PENDING → UPLOADED → REVIEWED | REJECTED
  status        String     @default("PENDING")

  // Who requested it
  requestedById String
  requestedBy   User       @relation("sqms_DocRequestedBy", fields: [requestedById], references: [id])
  createdAt     DateTime   @default(now())

  // Upload (auditee)
  fileUrl       String?    // Hetzner / Blob URL
  fileName      String?
  fileHash      String?    // SHA-256 — tamper detection
  uploadedById  String?
  uploadedBy    User?      @relation("sqms_DocUploadedBy", fields: [uploadedById], references: [id])
  uploadedAt    DateTime?

  // Review (auditor)
  reviewedById  String?
  reviewedBy    User?      @relation("sqms_DocReviewedBy", fields: [reviewedById], references: [id])
  reviewNote    String?    @db.Text
  reviewedAt    DateTime?

  updatedAt     DateTime   @updatedAt

  @@index([auditId])
  @@index([status])
}


model sqms_AuditResponse {
  id                String             @id @default(cuid())
  auditId           String
  audit             sqms_Audit         @relation(fields: [auditId], references: [id])
  itemId            String
  item              sqms_ChecklistItem @relation(fields: [itemId], references: [id])
  response          String?
  notes             String?            @db.Text
  manualReference   String?
  // Regulatory & Manual references
  regulatoryRef     String? // Free-text EASA/regulatory article (e.g. "CAMO.A.315")
  linkedManualId    String? // FK to legacy Manual model (kept for backward compat)
  linkedManual      Manual?            @relation("AuditResponseManual", fields: [linkedManualId], references: [id])
  // New: links to doc_manuals system (actual manual management)
  linkedDocManualId String? // FK to doc_manuals
  linkedDocManual   doc_manuals?       @relation("AuditResponseDocManual", fields: [linkedDocManualId], references: [id])
  linkedChapterId   String? // FK to doc_chapters
  linkedChapter     doc_chapters?      @relation("AuditResponseChapter", fields: [linkedChapterId], references: [id])
  gpsLat            Float?
  gpsLng            Float?
  offlineCreatedAt  DateTime?
  syncedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  evidence          sqms_Evidence[]    @relation("ResponseEvidence")

  @@unique([auditId, itemId])
  @@index([auditId])
  @@index([linkedManualId])
  @@index([linkedDocManualId])
}

// ─── MODULE 4: EVIDENCE — TAMPER-PROOF STORAGE ───────────────────────────────

// DESIGN RULE 3: fileHash (SHA-256) is always required.
// Binding: at least one of (findingId, itemId, responseId, capaId) must be non-null.
// Enforced in Server Action (SQLite has no partial CHECK constraints).
model sqms_Evidence {
  id             String              @id @default(cuid())
  findingId      String?
  finding        sqms_Finding?       @relation("FindingEvidence", fields: [findingId], references: [id])
  itemId         String?
  checklistItem  sqms_ChecklistItem? @relation("ItemEvidence", fields: [itemId], references: [id])
  responseId     String?
  response       sqms_AuditResponse? @relation("ResponseEvidence", fields: [responseId], references: [id])
  capaId         String?
  capa           sqms_Capa?          @relation("CapaEvidence", fields: [capaId], references: [id])
  occurrenceId   String? // Links to mod1_occurrences (SRA/Hazard evidence)
  occurrence     mod1_occurrences?   @relation("OccurrenceEvidence", fields: [occurrenceId], references: [id])
  fileUrl        String
  fileName       String
  mimeType       String              @default("application/octet-stream")
  fileSizeBytes  Int?
  fileHash       String // SHA-256 hex — validated server-side
  isTampered     Boolean             @default(false)
  gpsLat         Float?
  gpsLng         Float?
  deviceId       String?
  uploadedById   String
  uploadedBy     User                @relation("sqms_EvidenceUploader", fields: [uploadedById], references: [id])
  uploadedAt     DateTime            @default(now())
  deletedAt      DateTime?
  deletedById    String?
  deletionReason String?

  @@index([findingId])
  @@index([capaId])
  @@index([occurrenceId])
}

// ─── MODULE 5: CAPA LIFECYCLE — STATE MACHINE ────────────────────────────────

// DESIGN RULE 1 (for Findings): requirementId is NEVER NULL.
model sqms_Finding {
  id             String              @id @default(cuid())
  orgId          String              @default("") // tenant isolation
  auditId        String
  audit          sqms_Audit          @relation(fields: [auditId], references: [id])
  itemId         String?
  checklistItem  sqms_ChecklistItem? @relation(fields: [itemId], references: [id])
  requirementId  String? // nullable — legacy; new findings use complianceArticleId
  requirement    sqms_Requirement?   @relation(fields: [requirementId], references: [id])
  complianceArticleId String?        // new: links to sqms_ComplianceArticle
  complianceArticle   sqms_ComplianceArticle? @relation(fields: [complianceArticleId], references: [id])
  assignedToId   String?
  assignedTo     User?               @relation("sqms_FindingAssignee", fields: [assignedToId], references: [id])
  state          String              @default("OPEN")
  severity       String              @default("LEVEL2")
  description    String
  dueContainment DateTime?
  dueCap         DateTime?
  dueClosure     DateTime?
  containmentAt  DateTime?
  rcaAt          DateTime?
  capAt          DateTime?
  implementedAt  DateTime?
  verifiedAt     DateTime?
  closedAt       DateTime?
  reopenedAt     DateTime?
  // Phase 4 — Closing Meeting acknowledgement
  statementOfFact     String?   @db.Text // Exact "what is wrong" — mandatory for NC
  findingTitle        String?            // Short display title (auto from checklist item)
  acknowledgedAt      DateTime?          // Auditee clicked [Acknowledge] in closing meeting
  findingAcknowledgedById String?        // Which user acknowledged
  evidence       sqms_Evidence[]     @relation("FindingEvidence")
  containment    sqms_Containment?
  rcaSession     sqms_RcaSession?
  capa           sqms_Capa?
  verification   sqms_Verification?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  mergedIntoId        String?
  mergedJustification String?
  mergedInto          sqms_Finding?  @relation("MergedFindings", fields: [mergedIntoId], references: [id])
  mergedFindings      sqms_Finding[] @relation("MergedFindings")

  externalFindings    sqms_ExternalFinding[]
  auditeeResponses    sqms_AuditeeResponse[] @relation("FindingAuditeeResponse")

  // ── Cross-module: Safety ↔ Compliance bridge ────────────────────────
  // Set when a Safety SRA is linked to this finding
  linkedSraId          String?   // mod2_risk_assessments.id
  // Set when Compliance flags that a safety review is needed
  safetyReviewRequired Boolean   @default(false)
  // PENDING | IN_PROGRESS | CLEARED | NOT_REQUIRED
  safetyReviewStatus   String    @default("NOT_REQUIRED")
  // Set when Safety creates an occurrence from this finding
  linkedOccurrenceId   String?   // mod1_occurrences.id
  // Set when Safety raised a compliance finding from their side
  raisedBySafety       Boolean   @default(false)
  raisedBySafetyNote   String?   @db.Text

  @@index([auditId])
  @@index([state])
  @@index([requirementId])
  @@index([orgId])
  @@index([safetyReviewStatus])
}

model sqms_Containment {
  id              String       @id @default(cuid())
  findingId       String       @unique
  finding         sqms_Finding @relation(fields: [findingId], references: [id])
  description     String
  actionTakenById String
  actionTakenBy   User         @relation("sqms_ContainmentActor", fields: [actionTakenById], references: [id])
  completedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([findingId])
}

// CRITICAL: rootCauseCategoryId is NEVER NULL — no free-text bypass.
model sqms_RcaSession {
  id                  String                 @id @default(cuid())
  findingId           String                 @unique
  finding             sqms_Finding           @relation(fields: [findingId], references: [id])
  method              String                 @default("FIVE_WHYS")
  rootCauseCategoryId String
  rootCauseCategory   sqms_RootCauseCategory @relation(fields: [rootCauseCategoryId], references: [id])
  whyEntries          String?
  fishboneData        String?
  summary             String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  capa                sqms_Capa?

  @@index([findingId])
}

model sqms_RootCauseCategory {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  category    String
  description String?           @db.Text
  isActive    Boolean           @default(true)
  rcaSessions sqms_RcaSession[]
}

// CRITICAL: rcaSessionId is NEVER NULL — a CAP must map to a root cause.
model sqms_Capa {
  id               String            @id @default(cuid())
  findingId        String            @unique
  finding          sqms_Finding      @relation(fields: [findingId], references: [id])
  rcaSessionId     String            @unique
  rcaSession       sqms_RcaSession   @relation(fields: [rcaSessionId], references: [id])
  correctiveAction String?
  preventiveAction String?
  actions          sqms_CapaAction[]
  evidence         sqms_Evidence[]   @relation("CapaEvidence")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([findingId])
}

model sqms_CapaAction {
  id              String    @id @default(cuid())
  capaId          String
  capa            sqms_Capa @relation(fields: [capaId], references: [id])
  taskType        String    @default("GENERAL") // GENERAL, SAFETY_RISK_ASSESSMENT, HAZARD_LOG, SPI, MANUAL_REVISION
  description     String
  manualReference String?
  responsibleId   String
  responsible     User      @relation("sqms_CapaResponsible", fields: [responsibleId], references: [id])
  dueDate         DateTime
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([capaId])
}

// DESIGN RULE 2: Only AUDITOR or CMM may INSERT here.
// Enforced in Server Action BEFORE the Prisma call.
// roleAtVerification stored for non-repudiation.
model sqms_Verification {
  id                 String       @id @default(cuid())
  findingId          String       @unique
  finding            sqms_Finding @relation(fields: [findingId], references: [id])
  verifiedById       String
  verifiedBy         User         @relation("sqms_VerificationActor", fields: [verifiedById], references: [id])
  roleAtVerification String
  outcome            String
  notes              String
  rejectionReason    String?
  verifiedAt         DateTime     @default(now())

  @@index([findingId])
}

// ─── MODULE 6: DIGITAL SIGNATURES ────────────────────────────────────────────

model sqms_DigitalSignature {
  id                 String     @id @default(cuid())
  auditId            String
  audit              sqms_Audit @relation(fields: [auditId], references: [id])
  signedById         String
  signedBy           User       @relation("sqms_AuditSigner", fields: [signedById], references: [id])
  roleAtSigning      String
  dataHash           String // SHA-256 of canonical audit payload
  payloadJson        String? // Full signed payload JSON for crypto re-verification
  signatureData      String
  signerPublicKeyJwk String?
  signedAt           DateTime   @default(now())

  @@unique([auditId, signedById])
  @@index([auditId])
}

// ─── MODULE 7: WEB PUSH SUBSCRIPTIONS ───────────────────────────────────────
// Stores per-user Web Push API subscriptions for CAPA deadline reminders.

model sqms_PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("sqms_PushSubscriber", fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique // Web Push endpoint URL (browser-generated)
  p256dh    String // Public key for payload encryption
  auth      String // Authentication secret
  userAgent String? // For debugging / browser identification
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── MODULE 8: SAFETY REVIEW BOARD (SRB) ────────────────────────────────────
// EASA requires periodic Safety Review Board meetings to evaluate SPIs/SPTs.
// These records document meeting configuration, agenda, attendees and decisions.

model sqms_SRBMeeting {
  id              String                   @id @default(cuid())
  title           String // e.g. "Q1 2026 Safety Review Board"
  scheduledDate   DateTime
  status          String                   @default("PLANNED") // PLANNED | HELD | CANCELLED | POSTPONED
  location        String? // Physical or video platform
  minutesUrl      String? // Link to signed minutes document
  chairId         String?
  chair           User?                    @relation("sqms_SRBChair", fields: [chairId], references: [id])
  attendees       sqms_SRBAttendee[]
  agendaItems     sqms_SRBAgendaItem[]
  minutesSections sqms_SRBMinutesSection[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([scheduledDate])
  @@index([status])
}

model sqms_SRBAttendee {
  id        String          @id @default(cuid())
  meetingId String
  meeting   sqms_SRBMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation("sqms_SRBAttendee", fields: [userId], references: [id])
  role      String // e.g. "Chair", "Safety Manager", "Accountable Manager"
  attended  Boolean         @default(false)

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

model sqms_SRBAgendaItem {
  id            String          @id @default(cuid())
  meetingId     String
  meeting       sqms_SRBMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sortOrder     Int             @default(0)
  itemType      String // SPI_REVIEW | SPT_REVIEW | CAPA_STATUS | FINDING_TREND | AOB | ACTION_ITEM | OCCURRENCE_TREND | HAZARD_REVIEW | MOC_REVIEW | FINDING_TREND
  spiId         String? // Link to a specific SPI being reviewed
  title         String
  description   String?         @db.Text
  decision      String? // Outcome / decision text
  actionOwner   String? // Free-text name or userId
  actionDueDate DateTime?
  closedAt      DateTime?
  notes         String?         @db.Text

  // ── Linked references (stored as JSON arrays of IDs) ──────────────────────
  linkedHazardIds String @default("[]") // JSON: mod1_occurrences ids
  linkedSraIds    String @default("[]") // JSON: sqms_SafetyRiskAssessment ids
  linkedAuditIds  String @default("[]") // JSON: sqms_Audit ids
  linkedSpiIds    String @default("[]") // JSON: sys_spi_spt_definitions ids
  linkedManualIds String @default("[]") // JSON: doc_manuals ids

  createdAt DateTime @default(now())

  tasks sqms_SRBTask[]

  @@index([meetingId])
}

// ─── SRB Tasks (action items created during the meeting) ──────────────────────

model sqms_SRBTask {
  id           String             @id @default(cuid())
  agendaItemId String
  agendaItem   sqms_SRBAgendaItem @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)
  title        String
  description  String?            @db.Text
  ownerId      String? // User assigned
  owner        User?              @relation("sqms_SRBTaskOwner", fields: [ownerId], references: [id])
  dueDate      DateTime?
  status       String             @default("OPEN") // OPEN | IN_PROGRESS | COMPLETED | CANCELLED
  completedAt  DateTime?
  priority     String             @default("NORMAL") // LOW | NORMAL | HIGH | CRITICAL
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([agendaItemId])
  @@index([status])
}

// ─── SRB Topic Templates (admin-configurable standard agenda topics) ──────────

model sqms_SRBTopicTemplate {
  id          String   @id @default(cuid())
  sortOrder   Int      @default(0)
  itemType    String // SPI_REVIEW | SPT_REVIEW | CAPA_STATUS | FINDING_TREND | ACTION_ITEM | HAZARD_REVIEW | OCCURRENCE_TREND | AOB
  title       String // Default title shown in agenda
  description String?  @db.Text // Guidance text for the reviewer
  isActive    Boolean  @default(true)
  isMandatory Boolean  @default(false) // Cannot be removed from agenda
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}

// ─── SRB Generated Minutes Sections (for PDF output) ─────────────────────────

model sqms_SRBMinutesSection {
  id          String          @id @default(cuid())
  meetingId   String
  meeting     sqms_SRBMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  sectionType String // COVER | ATTENDEES | AGENDA_ITEM | SIGNATURE | APPENDIX
  sortOrder   Int             @default(0)
  title       String
  content     String // Markdown / structured text
  createdAt   DateTime        @default(now())

  @@index([meetingId])
}

// ─── Flight Operations Messages (FOM) & Instructions (FOI) ───────────────────
// Used by Flight Operations to communicate with pilots.
// FOM = operational messages (weather, airspace, NOTAMs)
// FOI = standing instructions / procedural changes

model sqms_FlightOpsMessage {
  id       String @id @default(cuid())
  // Document Key — auto-assigned: FOM-YYYY-NNN or FOI-YYYY-NNN
  docKey   String @unique // e.g. "FOM-2024-001"
  type     String // "FOM" | "FOI"
  subject  String
  body     String // Long text — SQLite stores as TEXT natively
  category String @default("GENERAL") // GENERAL | WEATHER | AIRSPACE | PROCEDURES | FUEL | MEL | SECURITY
  priority String @default("NORMAL") // NORMAL | URGENT | CRITICAL
  status   String @default("DRAFT") // DRAFT | ISSUED | CANCELLED | SUPERSEDED | EXPIRED

  effectiveDate DateTime?
  expiryDate    DateTime?

  // Authoring
  issuedById String?
  issuedBy   User?     @relation(fields: [issuedById], references: [id])
  issuedAt   DateTime?

  // Versioning
  supersededById String?
  supersededBy   sqms_FlightOpsMessage?  @relation("Supersession", fields: [supersededById], references: [id])
  supersedes     sqms_FlightOpsMessage[] @relation("Supersession")

  // Acknowledgements from pilots
  acknowledgements sqms_FomAcknowledgement[]

  // Mitigation links to other safety entities
  fomLinks sqms_FomLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([issuedById])
  @@index([effectiveDate])
  @@index([status])
}

model sqms_FomAcknowledgement {
  id             String                @id @default(cuid())
  messageId      String
  message        sqms_FlightOpsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId         String
  user           User                  @relation("FomAcknowledgements", fields: [userId], references: [id])
  acknowledgedAt DateTime              @default(now())
  comment        String?

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

// ─── FOM/FOI Links — Polymorphic Mitigation Evidence ─────────────────────────
// Links any FOM or FOI to other safety entities as mitigation proof.
// "The risk is under control because pilots were briefed via FOI-2024-001."

model sqms_FomLink {
  id        String                @id @default(cuid())
  messageId String
  message   sqms_FlightOpsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Link targets — exactly one should be set
  findingId    String? // sqms_Finding (audit finding)
  capaActionId String? // sqms_CapaAction
  occurrenceId String? // mod1_occurrences (hazard/SRA)
  capTaskId    String? // mod2_cap_tasks (SRA CAP task)

  linkType String  @default("MITIGATION") // MITIGATION | BRIEF | PROCEDURE | EVIDENCE
  note     String?

  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([findingId])
  @@index([occurrenceId])
  @@index([capTaskId])
}

// ─── SAFETY SIGNAL BUS ────────────────────────────────────────────────────────
// Cross-module intelligence layer. Any module can emit a Signal that references
// another module. Signals are soft links — they suggest, flag, and connect,
// but never automatically delete or modify data in other modules.
//
// Signal Flow Example:
//   SRB Meeting observation → Signal(SPI_REVIEW_NEEDED) → SPI Dashboard
//   Audit Finding L1        → Signal(SRA_REQUIRED)      → SRA Module
//   CAMO Defect Pattern     → Signal(AUDIT_FOCUS_FLAG)  → Next Audit Area
//   SRA Residual Risk HIGH  → Signal(SRB_AGENDA_ITEM)   → SRB Meeting

model sqms_Signal {
  id String @id @default(cuid())

  // ── Source (what triggered this signal) ──────────────────────────────────
  sourceType  String // AUDIT | FINDING | SRA | SRB_MEETING | SPI | FOM | CAMO | MOC | OCCURRENCE | MANUAL
  sourceId    String // ID of the source record
  sourceLabel String? // Human-readable label, e.g. "AUD-2026-003 Finding L1"

  // ── Target (what this signal points to) ──────────────────────────────────
  targetType  String? // Same enum as sourceType — null = broadcast/unlinked
  targetId    String? // ID of the target record (null = suggestion only)
  targetLabel String? // Human-readable label of the target

  // ── Signal metadata ───────────────────────────────────────────────────────
  signalType String // See SignalType enum below
  title      String // Short headline, e.g. "SRA required after Level 1 Finding"
  body       String? @db.Text // Optional longer description / observation text
  priority   String  @default("NORMAL") // LOW | NORMAL | HIGH | CRITICAL

  // ── Status lifecycle ──────────────────────────────────────────────────────
  status String @default("OPEN") // OPEN | ACKNOWLEDGED | ACTIONED | DISMISSED

  // ── Action taken (when status = ACTIONED) ────────────────────────────────
  actionType String? // SRA_CREATED | AUDIT_FLAGGED | SPI_ADJUSTED | FOM_ISSUED | DISMISSED_JUSTIFIED | CREW_REPLACED | AOG_RESOLVED | CAPA_CREATED
  actionId   String? // ID of the created record (e.g. new SRA id)
  actionNote String? // Free text describing what was done

  // ── Event Bus / Chain tracking ────────────────────────────────────────────
  chainId      String? // Groups all signals belonging to one operational chain
  chainStep    Int       @default(0) // Position in the chain (0 = trigger, 1+ = reactions)
  chainContext String?   @db.Text // JSON payload: { legId, crewId, aircraftId, ... }
  orgId        String? // Tenant isolation for multi-tenant
  resolvedById String?
  resolvedBy   User?     @relation("sqms_SignalResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?

  // ── Audit trail ──────────────────────────────────────────────────────────
  createdById      String?
  createdBy        User?     @relation("sqms_SignalCreator", fields: [createdById], references: [id])
  acknowledgedById String?
  acknowledgedBy   User?     @relation("sqms_SignalAcknowledger", fields: [acknowledgedById], references: [id])
  acknowledgedAt   DateTime?
  actionedById     String?
  actionedBy       User?     @relation("sqms_SignalActioner", fields: [actionedById], references: [id])
  actionedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([signalType])
  @@index([createdById])
  @@index([chainId])
  @@index([orgId, status])
  @@index([status, priority])
}

// SignalType reference (enforced in app layer, not DB enum for flexibility):
// SPI_REVIEW_NEEDED    — SPI metric may need threshold adjustment
// SRA_TRIGGER_SUGGESTED — Situation warrants a new Safety Risk Assessment
// SRA_REQUIRED         — Level 1 finding: SRA is mandatory
// AUDIT_FOCUS_FLAG     — Flag an area/topic for heightened audit scrutiny
// SRB_AGENDA_ITEM      — Item should appear on next SRB meeting agenda
// MITIGATION_EVIDENCE  — FOM/FOI/document serves as mitigation proof
// AUDIT_CHECKPOINT     — MoC or change should be verified in next audit
// GENERAL_OBSERVATION  — Freeform cross-module observation
// RECURRENCE_DETECTED  — Same finding/hazard appearing in multiple modules
// THRESHOLD_BREACH     — KPI/SPI has crossed an alert threshold

// ─── CAMO Compliance Activity System ─────────────────────────────────────────
// Tracks compliance-generating activities (ARC extensions, FTL reviews, etc.)
// that satisfy EASA regulatory requirements on a rolling 12-month basis.

model sqms_ChecklistTemplate {
  id                    String   @id @default(cuid())
  code                  String   @unique // e.g. "APP-CAME-007", "QM103" — official document key
  title                 String // e.g. "Product Audit Checklist"
  description           String?  @db.Text
  domain                String   @default("CAMO") // CAMO | AOC | PART_IS — which department owns this template
  type                  String // ARC_EXTENSION | CAME_AUDIT | PRODUCT_AUDIT | SUPPLIER_AUDIT | MANPOWER_REVIEW | CAMO_TRAINING | FTL_REVIEW | OPS_AUDIT | IS_AUDIT
  applicableTo          String   @default("AIRCRAFT") // AIRCRAFT | ORGANISATION | BOTH
  defaultValidityMonths Int      @default(12)
  regulatoryBasis       String? // e.g. "M.A.901(m), M.A.710(c)"
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  items      sqms_ChecklistTemplateItem[]
  activities sqms_ComplianceActivity[]

  @@index([type])
  @@index([domain])
  @@index([isActive])
}

model sqms_ChecklistTemplateItem {
  id             String                 @id @default(cuid())
  templateId     String
  template       sqms_ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  ref            String // e.g. "1.1", "2.3", "4.2.3"
  title          String // e.g. "Nationality & Registration Marks"
  description    String?                @db.Text // Full check description
  regulationRefs String? // JSON: ["M.A.901(m)1","M.A.901(m)2"]
  isCritical     Boolean                @default(false)
  sortOrder      Int                    @default(0)
  createdAt      DateTime               @default(now())

  @@unique([templateId, ref])
  @@index([templateId])
}

model sqms_ComplianceActivity {
  id         String                  @id @default(cuid())
  domain     String                  @default("CAMO") // CAMO | AOC | PART_IS — determines which compliance module owns this
  type       String // ARC_EXTENSION | CAME_AUDIT | PRODUCT_AUDIT | SUPPLIER_AUDIT | MANPOWER_REVIEW | CAMO_TRAINING | FTL_REVIEW | OPS_AUDIT | IS_AUDIT
  title      String // Human-readable, e.g. "ARC Extension OE-XYZ Apr 2025"
  templateId String?
  template   sqms_ChecklistTemplate? @relation(fields: [templateId], references: [id])

  // Aircraft (for per-aircraft activities like ARC)
  aircraftReg String? // e.g. "OE-XYZ"
  aircraftId  String? // FK to Aircraft model

  // Dates & validity
  performedAt DateTime
  validUntil  DateTime // performedAt + defaultValidityMonths (default 12)
  completedAt DateTime?

  // Execution
  status        String  @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | CANCELLED
  performedById String?
  performedBy   User?   @relation("sqms_ActivityPerformer", fields: [performedById], references: [id])

  // Documentation
  reportRef String? // e.g. "ARC-2025-OE-XYZ-001"
  notes     String? @db.Text

  // Linked to existing systems (no duplicate CAPA/NCCA built)
  linkedAuditId      String? // FK to sqms_Audit if overlapping
  checklistResponses String? // JSON: {itemRef: "1.1", outcome: "OK", notes: "...", requirementIds: [...]}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
  @@index([type])
  @@index([status])
  @@index([aircraftReg])
  @@index([performedById])
  @@index([performedAt])
}

// ─── Tenant / Operator Configuration ─────────────────────────────────────────
// Set during onboarding by the AI Setup Assistant.

/// Which modules are enabled for this operator.
model TenantModule {
  id         String   @id @default(cuid())
  moduleCode String   @unique
  isEnabled  Boolean  @default(true)
  configJson String?
  enabledAt  DateTime @default(now())
  enabledBy  String?
  updatedAt  DateTime @updatedAt

  @@index([moduleCode])
  @@index([isEnabled])
}

/// Custom tracking items per module (OPC/LPC intervals, AD tracking, medical expiry etc.)
model TrackingCategoryConfig {
  id              String   @id @default(cuid())
  moduleCode      String
  categoryKey     String
  label           String
  isEnabled       Boolean  @default(true)
  type            String
  periodDays      Int?
  unit            String?
  warnDaysBefore  Int      @default(30)
  affectsCurrency Boolean  @default(false)
  appliesToTypes  String?
  notesTemplate   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([moduleCode, categoryKey])
  @@index([moduleCode])
  @@index([isEnabled])
}

/// General key-value settings for the tenant (company name, framework, authority, etc.)
model TenantSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── AI Configuration ──────────────────────────────────────────────────────────
/// Stores per-provider AI configuration. One row per provider, one marked active.
model sys_ai_config {
  id           String   @id @default(cuid())
  /// Provider identifier: "gemini" | "openai" | "anthropic"
  provider     String   @unique
  /// API key — stored obfuscated (base64). NOT production-grade encryption.
  /// Migrate to KMS or environment secrets before going to production.
  apiKeyEnc    String?
  /// Model name as returned by the provider API, e.g. "gemini-2.0-flash"
  modelName    String   @default("gemini-1.5-flash")
  /// Whether this provider is the currently active one for all AI actions
  isActive     Boolean  @default(false)
  /// Optional: custom system prompt prefix appended to all requests
  systemPrompt String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Semantic Search Embedding Store ──────────────────────────────────────────
/// One row per indexed text item. Embedding stored as JSON float array.
/// Suitable for SQLite. For PostgreSQL production, use pgvector instead.
model sys_search_embedding {
  id          String   @id @default(cuid())
  /// Which data table this came from: "sqms_Finding" | "mod1_occurrences" | "sqms_SRA" etc.
  sourceTable String
  /// PK of the source record
  sourceId    String
  /// The human-readable text that was embedded (trimmed to 2000 chars)
  content     String
  /// JSON-serialised float[] — the embedding vector (typically 768 dims for Gemini)
  embedding   String
  /// When this embedding was created / last refreshed
  createdAt   DateTime @default(now())

  @@unique([sourceTable, sourceId])
  @@index([sourceTable])
}

// ─── Third-Party Integrations ──────────────────────────────────────────────────
/// Stores configuration for external system API integrations (Leon, Avinode, etc.)
model sys_integration {
  id             String    @id @default(cuid())
  /// Unique slug: "leon" | "avinode" | "schedaero" | "jetmanager"
  provider       String    @unique
  /// Display name shown in UI
  displayName    String
  /// Whether integration is currently active/enabled
  isEnabled      Boolean   @default(false)
  /// Operator/tenant ID for the external system (e.g. "hyp" for hyp.leon.aero)
  operatorId     String?
  /// API refresh token / API key — stored base64 encoded (use KMS in production)
  apiKeyEnc      String?
  /// Base URL override (optional, auto-constructed from operatorId if not set)
  baseUrl        String?
  /// JSON config blob for any provider-specific settings
  config         String?
  /// Sync scope: JSON array of enabled sync modules e.g. ["flights","crew","aircraft"]
  syncScope      String    @default("[\"flights\"]")
  /// UTC timestamp of last successful sync
  lastSyncAt     DateTime?
  /// Status of last sync: "ok" | "error" | "pending"
  lastSyncStatus String?
  /// Error message from last sync attempt (if any)
  lastSyncError  String?
  /// Number of records synced in last run
  lastSyncCount  Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── AD/SB/SI AI Assessment (legacy — kept for migration) ────────────────────

model sys_adsb_assessment {
  id                   String    @id @default(cuid())
  documentType         String
  referenceNumber      String
  title                String
  issuer               String
  effectiveDate        DateTime?
  complianceDate       DateTime?
  summary              String
  impact               String    @default("PENDING")
  affectedAircraftIds  String    @default("[]")
  affectedAircraftJson String    @default("[]")
  correctiveAction     String
  estimatedManHours    Float?
  estimatedCost        String?
  linkedActionsJson    String    @default("[]")
  rawText              String
  confidence           Float     @default(0.5)
  reviewStatus         String    @default("AI_DRAFT")
  reviewedBy           String?
  reviewNote           String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// ─── AIRWORTHINESS DOCUMENTS HUB ──────────────────────────────────────────────
// Unified registry for all CAMO technical documents:
// AD | SB | STC | LTA | SIB | SIL | SI
// Replaces: camo_ad_status_list + sys_adsb_assessment

/// Master document record – one row per AD/SB/STC/LTA/SIB/SIL/SI
model AirworthinessDoc {
  id String @id @default(cuid())

  // ── Identity ─────────────────────────────────────────────────────────────
  type            String // AD | SB | STC | LTA | SIB | SIL | SI
  referenceNumber String
  title           String  @default("")
  issuer          String  @default("") // EASA | FAA | LBA | Manufacturer
  revision        String?

  // ── Dates & Compliance ───────────────────────────────────────────────────
  effectiveDate       DateTime?
  complianceDate      DateTime? // First compliance deadline
  isRecurring         Boolean   @default(false)
  intervalDays        Int? // e.g. 365 for annual
  intervalFlightHours Float? // e.g. 300 FH

  // ── Classification ───────────────────────────────────────────────────────
  isMandatory Boolean @default(false)
  impactLevel String  @default("PENDING") // MANDATORY | OPTIONAL | INFO | PENDING
  docStatus   String  @default("ACTIVE") // ACTIVE | SUPERSEDED | CANCELLED

  // ── Content ──────────────────────────────────────────────────────────────
  summary           String  @default("")
  correctiveAction  String?
  estimatedManhours Float?
  estimatedCostEur  Float?
  affectedTypesJson String  @default("[]") // JSON: ["C525","C525A"]

  // ── Source ───────────────────────────────────────────────────────────────
  // How the document entered the system
  sourceType String  @default("UPLOAD") // EASA_PULL | FAA_PULL | LBA_PULL | UPLOAD | MANUAL
  sourceUrl  String? // URL if pulled from authority
  rawText    String? // Stored for AI re-analysis

  // ── AI / HITL ────────────────────────────────────────────────────────────
  aiConfidence Float     @default(0)
  reviewStatus String    @default("AI_DRAFT") // AI_DRAFT | REVIEWED | APPROVED
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  compliance AircraftDocCompliance[]

  @@index([type])
  @@index([docStatus])
  @@index([reviewStatus])
  @@index([complianceDate])
}

/// Per-aircraft compliance record — one row per (document × aircraft)
model AircraftDocCompliance {
  id         String           @id @default(cuid())
  docId      String
  doc        AirworthinessDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  aircraftId String
  aircraft   Aircraft         @relation(fields: [aircraftId], references: [id], onDelete: Cascade)

  // ── Status ───────────────────────────────────────────────────────────────
  // COMPLIANT | PENDING | OVERDUE | NOT_APPLICABLE | IN_WORK
  status            String  @default("PENDING")
  applicabilityNote String? // Why applicable / not applicable

  // ── Compliance Evidence ──────────────────────────────────────────────────
  dueDate       DateTime?
  completedDate DateTime?
  completedBy   String?
  workOrderRef  String?
  evidence      String? // Free-text notes / document refs

  // ── HITL Override ────────────────────────────────────────────────────────
  overriddenBy String?
  overrideNote String?
  overriddenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([docId, aircraftId])
  @@index([aircraftId])
  @@index([docId])
  @@index([status])
  @@index([dueDate])
}

// ─── Sales Global Settings ───────────────────────────────────────────────────
// Single row per organization – upserted via Admin Settings
model SalesSetting {
  id                       String @id @default(cuid())
  // Fuel
  defaultFuelPriceEurKg    Float  @default(1.85)
  // Operator
  homeBaseIcao             String @default("EDDF")
  // Crew
  crewDailyRateEur         Float  @default(550)
  crewHotelRateEur         Float  @default(200)
  crewPerDiemEur           Float  @default(60)
  // Margin
  defaultMarginPct         Float  @default(25)
  minMarginPct             Float  @default(10)
  // Quote
  defaultOptionExpiryH     Int    @default(48)
  quoteValidityDays        Int    @default(7)
  // Costs
  atcRatePerNm             Float  @default(0.32)
  defaultParkingRateEurH   Float  @default(80)
  // Quote PDF
  companyName              String @default("Charter Aviation GmbH")
  paymentTerms             String @default("50% deposit upon booking, balance 7 days before departure.")
  vatNote                  String @default("All prices exclude VAT unless otherwise stated.")
  // Aircraft profile overrides (JSON: { [profileKey]: { docPerHourEur?, fuelBurnKgPerHour?, crewDailyRateEur? } })
  aircraftProfileOverrides String @default("{}")
  // Hotspot airports — major private jet hubs (no positioning if trip ends here)
  // JSON string array e.g. ["EDDF","EDDM","LSZH","EGLL","LFPB","LEBL","LIML","LOWW"]
  hotspotAirports          String @default("[\"EDDF\",\"EDDM\",\"LSZH\",\"EGLL\",\"LFPB\",\"LEBL\",\"LIML\",\"LOWW\"]")
  // Hotspot positioning surcharge % (applied when a trip ends at a hotspot instead of home base)
  hotspotSurchargePct      Float  @default(5)
  // Per-airport overrides (JSON: { [ICAO]: { overnightAllowed?, parkingRatePerHour?, handlingFeeBase?, landingFeeTonMTOW?, nearestHotelIcao? } })
  airportOverrides         String @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// SUPERADMIN — Platform Operator Layer
// Neo-Flight operator can manage the platform, but CANNOT access tenant data
// unless the tenant explicitly grants a time-limited support session.
// ═══════════════════════════════════════════════════════════════════════════════

/// Platform superadmin accounts (Neo-Flight operators only — separate from tenant users)
model SuperAdmin {
  id             String    @id @default(cuid())
  email          String    @unique
  hashedPassword String?
  name           String?
  mfaSecret      String?
  mfaEnabled     Boolean   @default(false)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  auditLogs     SuperAdminAuditLog[]
  supportGrants TenantSupportAccess[] @relation("GrantedToSuperAdmin")
}

/// Tenant (customer) grants time-limited support access to a SuperAdmin.
/// Without a valid grant, SuperAdmin CANNOT read or write any tenant data.
/// EASA principle: data access requires documented, revocable consent.
model TenantSupportAccess {
  id              String    @id @default(cuid())
  orgId           String // Which tenant granted access
  superAdminId    String // Which Neo-Flight operator received access
  grantedByUserId String // Tenant admin who granted (must be ADMIN role)
  reason          String // Customer-entered reason for the support request
  expiresAt       DateTime // Auto-expires (max 48h enforced in application)
  revokedAt       DateTime? // Tenant can revoke early
  revokedByUserId String? // Who revoked
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  superAdmin SuperAdmin @relation("GrantedToSuperAdmin", fields: [superAdminId], references: [id])

  @@index([orgId, isActive])
  @@index([superAdminId, isActive])
  @@index([expiresAt])
}

/// Immutable audit log for every SuperAdmin action.
/// Written before AND after any data mutation in a tenant scope.
/// Tenants can view their own row, SuperAdmin cannot delete rows.
model SuperAdminAuditLog {
  id            String   @id @default(cuid())
  superAdminId  String
  orgId         String? // NULL = platform-level action (e.g. create tenant)
  accessGrantId String? // FK to TenantSupportAccess that authorized this action
  action        String // CREATE_TENANT | SUSPEND_TENANT | ENTER_TENANT | EXIT_TENANT
  // VIEW_USER_LIST | RESET_USER_PASSWORD | UPDATE_SETTING | etc.
  targetType    String? // e.g. "User", "Organization", "Flight"
  targetId      String?
  ipAddress     String?
  userAgent     String?
  payloadBefore String? // JSON snapshot BEFORE mutation (never stored for sensitive fields)
  payloadAfter  String? // JSON snapshot AFTER mutation
  createdAt     DateTime @default(now())

  superAdmin SuperAdmin @relation(fields: [superAdminId], references: [id])

  @@index([superAdminId, createdAt])
  @@index([orgId, createdAt])
  @@index([action])
}

// ═══════════════════════════════════════════════════════════════════════════════
// STAGED DEPLOYMENT SYSTEM
// New code is tested on staging.neo-flight.aero first.
// SuperAdmin then activates the new version per tenant (all / one / selected).
// Features are gated per tenant via featureFlags JSON.
// Schema migrations are always backward-compatible (safe-migrate.mjs).
// ═══════════════════════════════════════════════════════════════════════════════

/// Platform release registry — each release SuperAdmin uploads to the system.
model AppRelease {
  id                String    @id @default(cuid())
  version           String    @unique // semver: "2.1.0"
  channel           String    @default("stable") // stable | beta | hotfix
  title             String // "February 2026 Feature Release"
  changelog         String // Markdown release notes
  breakingChanges   Boolean   @default(false)
  requiresMigration Boolean   @default(false) // Has pending schema migration
  migrationNotes    String? // What the migration does (for admin review)
  releasedAt        DateTime?
  createdAt         DateTime  @default(now())
  createdBy         String // SuperAdmin ID

  deployments    TenantDeployment[]
  deploymentLogs TenantDeploymentLog[]

  @@index([channel, releasedAt])
}

/// Per-tenant deployment state — which version is active + feature flags.
/// SuperAdmin controls this. Tenants cannot modify their own version.
model TenantDeployment {
  id             String  @id @default(cuid())
  orgId          String  @unique // One record per org
  currentVersion String  @default("1.0.0") // Currently running version
  targetVersion  String? // Scheduled upgrade target (null if up to date)
  releaseId      String? // FK to AppRelease

  // Feature flags — JSON object: { "flagKey": true/false }
  // New features ship as disabled. SuperAdmin enables per tenant.
  // Example: { "ai_hitl_v2": true, "bulk_export": false, "new_scheduler": true }
  featureFlags String @default("{}")

  // Deployment status
  status         String    @default("UP_TO_DATE") // UP_TO_DATE | PENDING_UPDATE | UPDATING | ERROR | ROLLBACK
  lastDeployedAt DateTime?
  lastDeployedBy String? // SuperAdmin ID
  errorMessage   String?

  // Tenant opted-in to automatic updates (SuperAdmin can toggle)
  autoUpdate Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  release AppRelease? @relation(fields: [releaseId], references: [id])

  @@index([status])
  @@index([currentVersion])
  @@index([autoUpdate])
}

/// Immutable deployment history per tenant — never deleted.
/// EASA ORO.GEN.220: change records must be retained.
model TenantDeploymentLog {
  id           String   @id @default(cuid())
  orgId        String
  releaseId    String
  fromVersion  String
  toVersion    String
  deployedBy   String // SuperAdmin ID
  deployedAt   DateTime @default(now())
  durationMs   Int? // How long the activation took
  status       String // SUCCESS | FAILED | ROLLED_BACK
  notes        String?  @db.Text
  flagsApplied String? // JSON snapshot of feature flags at deploy time

  release AppRelease @relation(fields: [releaseId], references: [id])

  @@index([orgId, deployedAt])
  @@index([releaseId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// EMAIL SYSTEM
// Outbound: via Resend (already installed)
// Inbound:  via Resend Inbound Webhooks → parsed into InboundEmail + auto-linked
//           e.g. reports@lufthansa.jetmind.aero → Safety Report draft
// ═══════════════════════════════════════════════════════════════════════════════

/// Outbound email log — every sent email is recorded for audit.
model EmailLog {
  id          String   @id @default(cuid())
  orgId       String
  to          String // Recipient address(es), comma-joined
  from        String // Sender address used
  subject     String
  template    String // Template key: e.g. "CAPA_DEADLINE", "SAFETY_REPORT_ACK"
  status      String   @default("SENT") // SENT | FAILED | BOUNCED | OPENED
  resendId    String? // Resend message ID for tracking
  relatedType String? // "SafetyReport" | "CapaAction" | "User" etc.
  relatedId   String? // FK-equivalent for the linked entity
  sentAt      DateTime @default(now())
  failReason  String?

  @@index([orgId, sentAt])
  @@index([template])
  @@index([status])
  @@index([resendId])
}

/// Inbound email — received via Resend Inbound Webhook.
/// Can be auto-converted to Safety Reports, Hazard Logs, or stored as raw.
model InboundEmail {
  id              String  @id @default(cuid())
  orgId           String? // Resolved from recipient address (tenant routing)
  messageId       String  @unique // Email Message-ID header
  fromAddress     String
  fromName        String?
  toAddress       String // Which jetmind inbox received it
  subject         String
  bodyText        String // Plain-text body
  bodyHtml        String? // HTML body (stripped for safety before display)
  attachmentCount Int     @default(0)
  attachments     String? // JSON array: [{ filename, contentType, size, url }]

  // Processing status
  status          String  @default("PENDING") // PENDING | PROCESSED | IGNORED | ERROR
  processingNotes String?

  // Auto-linkage — if the email was converted to a record
  linkedType String? // "SafetyReport" | "HazardLog" | "CapaAction" | null
  linkedId   String?

  receivedAt  DateTime  @default(now())
  processedAt DateTime?

  @@index([orgId, receivedAt])
  @@index([status])
  @@index([fromAddress])
  @@index([toAddress])
}

/// Inbound email routing rules — which inbox maps to which action.
/// SuperAdmin configures these per tenant.
model EmailRoute {
  id          String   @id @default(cuid())
  orgId       String
  address     String // e.g. "reports@lufthansa.jetmind.aero"
  action      String // CREATE_SAFETY_REPORT | CREATE_HAZARD_LOG | NOTIFY_ADMIN | ARCHIVE
  label       String // Human readable: "Safety Reporting Inbox"
  isActive    Boolean  @default(true)
  autoProcess Boolean  @default(false) // Auto-create record without human review
  notifyUsers String? // JSON: [userId, ...] who gets notified on inbound
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, address])
  @@index([orgId, isActive])
  @@index([address])
}

// ═══════════════════════════════════════════════════════════════════════════════
// READ TRACKING ("Read & Sign")
// ─────────────────────────────────────────────────────────────────────────────
// Applies to: Manuals, Flight Operations Messages, Safety Bulletins,
//             ADs/SBs, Training documents, Circulars — any ReadableDocument.
//
// EASA compliance:
//   ORO.GEN.200 — Management system documentation must be distributed,
//   acknowledged and version-controlled.
//   ORO.GEN.220 — Records must be kept for the period specified.
//
// Rules:
//   - DocReadRecord is immutable (never deleted, audit only)
//   - Each new version requires a fresh read acknowledgement
//   - DocReadRequirement defines who MUST read (by role or individual user)
//   - Compliance export (PDF) shows read vs. outstanding per document version
// ═══════════════════════════════════════════════════════════════════════════════

/// Represents any document that requires read acknowledgement.
/// Works as a thin adapter — links to the actual document (manual, bulletin, etc.)
/// via docType + docId, so it doesn't replace existing models.
model ReadableDocument {
  id    String @id @default(cuid())
  orgId String

  /// Discriminator for the source model
  /// Values: MANUAL | BULLETIN | FLIGHT_OPS_MESSAGE | SB | AD | TRAINING | CIRCULAR | CUSTOM
  docType String

  /// ID in the source model (e.g. Manual.id, Bulletin.id)
  docId String

  /// Human-readable title (denormalised for performance)
  title String

  /// Document version string (e.g. "Rev 3", "2026-01-15", "v2.1")
  version String @default("1")

  /// Whether read tracking is ACTIVE for this version.
  /// Can be toggled off per revision (e.g. draft/internal version).
  trackingEnabled Boolean @default(true)

  /// Whether reading this version is mandatory for the configured roles/users/groups
  mandatory Boolean @default(false)

  /// Deadline by which mandatory reads must be completed (optional)
  deadline DateTime?

  /// JSON array of opsRoles required to read: ["PILOT","CABIN_CREW","DISPATCHER"]
  requiredRoles String?

  /// JSON array of specific userIds required (overrides or extends roles)
  requiredUsers String?

  /// JSON array of ReadGroup.id values required to read
  requiredGroups String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reads        DocReadRecord[]
  requirements DocReadRequirement[]

  @@unique([orgId, docType, docId, version])
  @@index([orgId, docType])
  @@index([orgId, mandatory])
  @@index([orgId, trackingEnabled])
  @@index([deadline])
}

/// Immutable record: one row per user per document version read.
/// Never deleted — append-only audit table.
model DocReadRecord {
  id    String @id @default(cuid())
  orgId String

  docId String // ReadableDocument.id
  doc   ReadableDocument @relation(fields: [docId], references: [id])

  userId String
  user   User   @relation("UserReadRecords", fields: [userId], references: [id])

  /// Full name at time of reading (denormalised — user could be deleted later)
  userName  String
  userEmail String
  userRole  String

  /// Electronic acknowledgement checkbox — user clicked "I confirm I have read..."
  acknowledged   Boolean  @default(false)
  acknowledgedAt DateTime @default(now())

  /// Optional: digital signature (base64 or hash of name+timestamp+userId)
  signature String?

  /// IP address at time of read (for high-security environments)
  ipAddress String?
  userAgent String?

  /// Extra context: device, browser, location if available
  metadata String? // JSON

  createdAt DateTime @default(now())

  @@unique([docId, userId]) // One record per user per doc-version
  @@index([orgId, acknowledgedAt])
  @@index([docId])
  @@index([userId])
  @@index([userRole])
}

/// Who is required to read a specific document version (compliance tracking).
/// Created by admins when publishing a new document version.
model DocReadRequirement {
  id    String @id @default(cuid())
  orgId String

  docId String // ReadableDocument.id
  doc   ReadableDocument @relation(fields: [docId], references: [id])

  /// "ROLE" = all users with this opsRole, "USER" = specific user, "GROUP" = ReadGroup.id
  targetType String // ROLE | USER | GROUP

  /// For ROLE: e.g. "PILOT", "CABIN_CREW". For USER: the userId.
  targetValue String

  createdAt DateTime @default(now())
  createdBy String // userId of admin who set this

  @@unique([docId, targetType, targetValue])
  @@index([orgId])
  @@index([docId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// READ TRACKING GROUPS
// ─────────────────────────────────────────────────────────────────────────────
// Admins define named groups (e.g. "Wien Pilots", "All CAMO Engineers").
// Groups can be assigned as required readers on any ReadableDocument version.
// Members can be individuals or entire opsRoles (resolved at query time).
// ═══════════════════════════════════════════════════════════════════════════════

/// A named, reusable reader group (e.g. "All Pilots AMS", "CAMO Team").
model ReadGroup {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?  @db.Text
  color       String   @default("#6366f1") // UI color for identification
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String // userId of admin who created the group

  members ReadGroupMember[]

  @@unique([orgId, name])
  @@index([orgId, isActive])
}

/// Many-to-many: User ↔ ReadGroup membership.
model ReadGroupMember {
  id      String    @id @default(cuid())
  groupId String
  group   ReadGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User      @relation("UserReadGroups", fields: [userId], references: [id], onDelete: Cascade)
  addedAt DateTime  @default(now())
  addedBy String // userId of admin who added them

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODULE ACCESS CONTROL
// ─────────────────────────────────────────────────────────────────────────────
// Two-layer system:
//
//  Layer 1 — Plan (SuperAdmin): which MODULES a tenant's subscription includes.
//   Organization.plan (FREE|STARTER|PRO|ENTERPRISE) determines the base set.
//   OrgModuleOverride allows SuperAdmin to grant/revoke individual modules.
//
//  Layer 2 — Role (Org Admin): which modules each opsRole can ACCESS within
//   the tenant's enabled modules. OrgRolePermission stores these per-org grants.
//
// At runtime: canAccess(user, module) = planAllows(module) && roleAllows(module)
// ═══════════════════════════════════════════════════════════════════════════════

/// Per-tenant SuperAdmin module override.
/// Allows granting modules above the plan, or revoking ones included in it.
model OrgModuleOverride {
  id        String   @id @default(cuid())
  orgId     String
  module    String // MODULE key (e.g. "CAMO", "AI", "CHARTER")
  enabled   Boolean // true = force-enable (even if plan doesn't include)
  // false = force-disable (even if plan includes)
  reason    String? // Admin note
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  setBy     String // SuperAdmin userId

  @@unique([orgId, module])
  @@index([orgId])
}

/// Per-tenant role permission: which opsRoles can access which modules.
/// Company admins configure this. Defaults are seeded from ROLE_MODULE_DEFAULTS.
model OrgRolePermission {
  id      String  @id @default(cuid())
  orgId   String
  opsRole String // e.g. "PILOT", "CAMO", "SAFETY", "ADMIN"
  module  String // MODULE key
  allowed Boolean @default(true)

  updatedAt DateTime @updatedAt
  updatedBy String // userId who changed it

  @@unique([orgId, opsRole, module])
  @@index([orgId, opsRole])
  @@index([orgId, module])
}

// ─── Routing Cache ────────────────────────────────────────────────────────────
// Persists AutoRouter / FPDB results across serverless cold starts.
// Key: "{fromIcao}:{toIcao}:{depDate|generic}" — depDate is YYYY-MM-DD or "generic"
// TTL: 24h for autorouter (wind-corrected), 7d for fpdb, 30d for gcd_corrected
// Cron can clean expired entries: DELETE WHERE expiresAt < NOW()

model sys_routing_cache {
  id           String   @id @default(cuid())
  routeKey     String   @unique // "{from}:{to}:{depDate}"
  fromIcao     String
  toIcao       String
  source       String // "autorouter" | "fpdb" | "gcd_corrected"
  distanceNm   Float
  blockTimeMin Int?
  fuelKg       Float?
  optimalFL    Int?
  route        String? // ICAO airway route string
  resultJson   String // full AirwayRouteResult as JSON (for forward-compat)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([fromIcao, toIcao])
  @@index([expiresAt])
}

// ─── FTL Configuration Templates ─────────────────────────────────────────────
// Operator-configurable FTL rule sets. Only one template is active at a time.
// Built-in templates (isBuiltIn=true) cannot be deleted.
// Reference: EASA Part-ORO ORO.FTL, German 2. DVO LuftBO §42, custom OMs.
//
// All *H fields are in decimal hours (e.g. 10.5 = 10h 30min).
// All *DH fields are in decimal hours of DUTY (not just flight time).

model sys_ftl_config {
  id String @id @default(cuid())

  // Identity
  name          String // "EASA ORO.FTL", "LuftDVO §42", "OM-A Custom"
  description   String? @db.Text
  regulationRef String? // "EU 965/2012 ORO.FTL.235"
  omRef         String? // "OM-A Chapter 7.3 Rev 05"
  country       String? // ISO 3166-1 alpha-2

  // Status
  isActive  Boolean @default(false)
  isBuiltIn Boolean @default(false)

  // ── Reporting / Check-in times ───────────────────────────────────────────
  // Added to FDP at the start (report to departure).
  reportTimeDomesticMin      Int @default(30) // domestic: 30 min
  reportTimeInternationalMin Int @default(45) // international: 45 min
  debriefTimeMin             Int @default(30) // post-FDP debrief to add

  // ── Night / Early Start definition ──────────────────────────────────────
  // "Night" period for reduced FDP limits (local time, hour 0-23)
  nightPeriodStartHour Int @default(23) // 23:00 local
  nightPeriodEndHour   Int @default(6) // 06:00 local
  // Report time before this hour counts as "early start" (reduced FDP)
  earlyStartBeforeHour Int @default(6) // report before 06:00 = early

  // ── Minimum Rest ─────────────────────────────────────────────────────────
  minRestH               Float  @default(10.0) // standard minimum rest
  minRestNightH          Float? // night-ops minimum (if different)
  minRestAfterExtensionH Float? // required rest after extended FDP (ORO.FTL.235)

  // ── FDP Limits ────────────────────────────────────────────────────────────
  maxFdpBaseH     Float  @default(13.0) // standard daytime, single sector
  maxFdpNightH    Float? // night/early-start FDP limit
  maxFdpExtendedH Float? // augmented / in-flight rest limit

  // ── Commander's Discretion Extension (ORO.FTL.205(f)) ───────────────────
  // Allows the PIC to extend FDP in unforeseen operational circumstances.
  extEnabled                Boolean @default(true) // may extensions be used?
  extDiscretionMaxH         Float   @default(2.0) // max extension per FDP (EASA: 2h)
  extMaxPerRollingWeekCount Int     @default(3) // max extensions in 7-day window
  extMaxConsecutiveCount    Int     @default(2) // max consecutive extended FDPs
  extMinRestAfterH          Float? // required rest after extension (if different)
  extRequiresReport         Boolean @default(true) // must the PIC file an ASR/NCR?

  // ── Split Duty (ORO.FTL.205(g)) ──────────────────────────────────────────
  // Crew is given a break in a suitable resting facility; break reduces effective FDP.
  splitEnabled        Boolean @default(false) // split duties allowed?
  splitMinBreakH      Float?  @default(3.0) // min break to qualify as split (EASA: 3h)
  // How much of the break can be credited to extend the FDP:
  // EASA: credit = half the break, capped at splitMaxCreditH
  splitCreditFraction Float?  @default(0.5) // fraction of break credited (0.0–1.0)
  splitMaxCreditH     Float?  @default(3.0) // absolute cap on FDP extension via split
  splitMaxTotalFdpH   Float? // hard ceiling for split FDP

  // ── Cumulative Duty Limits ────────────────────────────────────────────────
  maxCumulative7dH   Float  @default(60.0)
  maxCumulative28dH  Float? // 190h / 28 days (ORO.FTL.210)
  maxCumulative365dH Float? // 1000h / 365 days

  // ── Warning Margins ───────────────────────────────────────────────────────
  warnRestMarginH   Float @default(2.0)
  warnFdpMarginH    Float @default(1.0)
  warnCumulative7dH Float @default(5.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([country])
}

// ─── CAMO: Parts Inventory ────────────────────────────────────────────────────

model camo_inventory_part {
  id          String   @id @default(uuid())
  partNumber  String   @unique
  description String
  category    String   @default("AIRFRAME") // AIRFRAME | ENGINE | AVIONICS | CONSUMABLE
  supplier    String   @default("")
  price       Float    @default(0.0)
  minLevel    Int      @default(1) // minimum stock level before alert
  stock       String   @default("[]") // JSON: StockEntry[]
  notes       String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, isActive])
  @@index([partNumber])
}

// ─── Briefing OCR + ReFuelEU ──────────────────────────────────────────────────

/// Uploaded dispatch briefing document (OFP, NOTAM set, weather, fuel slip)
model FlightBriefing {
  id              String    @id @default(cuid())
  flightLegId     String
  documentType    String // OFP | NOTAM_SET | WEATHER | FUEL_SLIP | MIXED
  rawDocumentUrl  String // Original PDF URL (retain 4 years per EASA)
  uploadedById    String?
  status          String    @default("PENDING_OCR")
  ocrConfidence   Float?
  ocrReviewedById String?
  ocrReviewedAt   DateTime?
  reviewNotes     String?

  // ── Fuel Plan (from OFP) ──────────────────────────────────────────────────
  taxiFuelKg      Float?
  tripFuelKg      Float?
  contingencyKg   Float?
  alternateKg     Float?
  finalReserveKg  Float?
  additionalKg    Float?
  extraFuelKg     Float? // Extra fuel filed by captain (tankering, alternate reason, etc.)
  extraFuelReason String? // Captain's stated reason for extra fuel
  totalFuelReqKg  Float?

  // ── Fuel Uplift (from Fuel Slip) ──────────────────────────────────────────
  fuelOnBoardKg    Float? // FROB at departure (from ramp sheet / OFP)
  requiredUpliftKg Float? // Calculated: max(0, totalFuelReqKg - fuelOnBoardKg)
  actualUpliftKg   Float?
  fuelSlipRef      String?
  upliftDensity    Float?
  upliftTempC      Float?

  // ── Handwriting / Annotations ─────────────────────────────────────────────
  hasHandwriting   Boolean @default(false)
  handwritingNotes String?

  // ── Operational Risks (extracted by OCR) ─────────────────────────────────
  weatherRisks      Json? // [{type: "CB"|"LOW_VIS"|"CROSSWIND"|"ICE"|"TS", severity: "LOW"|"MED"|"HIGH", raw: String}]
  notamRisks        Json? // [{type: "SINGLE_RWY"|"RWY_CLOSED"|"ILS_NOTAM"|"SLOT"|"TAXIWAY", station: String, raw: String}]
  militaryZones     String[] // Active TSA/TRA/CTA zone codes
  delayRisks        Json? // [{type: "ATC"|"DE_ICING"|"SLOT"|"GROUND", estimatedMin: Int}]
  performanceLimits Json? // [{type: "MTOW"|"FLAP"|"TERRAIN"|"NOISE", value: String}]
  alternateQuality  String? // GOOD | SINGLE_RWY | RESTRICTED | NIGHT_ONLY | CLOSED

  // ── ReFuelEU Exemption Documentation ─────────────────────────────────────
  refueleuExempt         Boolean @default(false)
  exemptionReason        String? // FROB_SUFFICIENT | SAFETY_ALTERNATE | WEIGHT | TECHNICAL | GROUND_TIME
  exemptionJustification String? // Free-text narrative for EASA audit
  linkedPrevBriefingId   String? // Reference to prior leg briefing explaining FROB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flightLeg      FlightLeg         @relation(fields: [flightLegId], references: [id])
  weatherRecords BriefingWeather[]

  @@index([flightLegId])
  @@index([status])
  @@index([documentType])
  @@index([refueleuExempt])
}

/// Extracted weather observation from briefing (METAR, TAF, SIGMET, PIREP)
model BriefingWeather {
  id           String    @id @default(cuid())
  briefingId   String
  stationIcao  String
  type         String // METAR | TAF | SIGMET | PIREP | ATIS
  validFrom    DateTime
  validTo      DateTime?
  rawText      String
  windDirDeg   Int?
  windKts      Int?
  gustKts      Int?
  visibilityM  Int?
  cloudBase1Ft Int?
  cloudBase2Ft Int?
  tempC        Float?
  dewpointC    Float?
  qnhHpa       Int?
  flightCat    String?
  createdAt    DateTime  @default(now())

  briefing FlightBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  @@index([briefingId])
  @@index([stationIcao, validFrom])
}

/// ReFuelEU Aviation (EU 2023/2405) — per airport per year compliance record
model ReFuelEuRecord {
  id            String  @id @default(cuid())
  year          Int
  departureIcao String
  registration  String?

  fuelUpliftedT     Float @default(0)
  tripFuelT         Float @default(0)
  taxiFuelT         Float @default(0)
  fuelRequiredT     Float @default(0)
  fuelNonTankedT    Float @default(0)
  fuelSafetyExemptT Float @default(0)

  safPurchasedT    Float   @default(0)
  safSupplier      String?
  safFeedstockType String?
  safLifecycleGCO2 Float?

  totalFlights     Int   @default(0)
  flightHoursBlock Float @default(0)

  tankeringRatio  Float   @default(0)
  isCompliant     Boolean @default(false)
  exemptionReason String?

  reportStatus String    @default("DRAFT")
  submittedAt  DateTime?
  verifiedAt   DateTime?
  verifierName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, departureIcao, registration])
  @@index([year, isCompliant])
  @@index([departureIcao])
}

/// EASA Union Airport List (annual) — only these airports count for ReFuelEU
model ReFuelEuUnionAirport {
  id          String   @id @default(cuid())
  year        Int
  icao        String
  airportName String?
  country     String?
  source      String   @default("EASA")
  createdAt   DateTime @default(now())

  @@unique([year, icao])
  @@index([year])
}

// ─── Compliance Program Manager ──────────────────────────────────────────────
// Annual regulatory audit: Documents HOW each applicable regulation is
// implemented, links live evidence from the operational system, and records
// the annual verification sign-off (ORO.GEN.220 / Part-CAMO AMC).

/// One statement per applicable regulation — persistent across audit cycles
model compliance_statement {
  id                 String    @id @default(cuid())
  requirementId      String    @unique // → sqms_Requirement
  implementationText String    @default("") @db.Text // HOW we implement this
  processOwner       String? // userId of responsible person
  processOwnerName   String? // display name
  linkedModules      String    @default("[]") // JSON: ["WorkOrder","Training",...]
  status             String    @default("PENDING") // COMPLIANT|FINDING|PENDING|NOT_APPLICABLE
  lastVerifiedAt     DateTime?
  lastVerifiedBy     String? // userId
  lastVerifiedByName String?
  nextDueDate        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  verifications compliance_verification[]

  @@index([status])
  @@index([nextDueDate])
}

/// One record per annual verification event
model compliance_verification {
  id             String               @id @default(cuid())
  statementId    String
  statement      compliance_statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  status         String // COMPLIANT | FINDING | NOT_APPLICABLE
  findings       String?              @db.Text
  notes          String?              @db.Text
  evidenceUrl    String? // uploaded file
  evidenceName   String?
  verifiedAt     DateTime             @default(now())
  verifiedBy     String // userId
  verifiedByName String
  nextDue        DateTime?

  @@index([statementId])
  @@index([verifiedAt])
  @@index([status])
}

// ─── Aircraft Owner & Rebilling ───────────────────────────────────────────────
// An AircraftOwner represents a legal entity (person or company) that owns
// one or more aircraft managed under CAMO. They have their own portal login
// and receive rebilling invoices for maintenance, handling, and operational costs.

model AircraftOwner {
  id                String    @id @default(cuid())
  name              String // Display name (company or person)
  email             String    @unique // Login email for owner portal
  phone             String?
  address           String?
  vatNumber         String? // For invoice compliance
  preferredCurrency String    @default("EUR")
  language          String    @default("de") // Portal language
  notes             String?   @db.Text
  isActive          Boolean   @default(true)
  portalPassword    String? // Hashed — separate from crew/staff auth
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  aircraft          AircraftOwnership[]
  rebillingInvoices OwnerRebillingInvoice[]

  @@index([email])
}

// Many aircraft can have one owner; one owner can own many aircraft
model AircraftOwnership {
  id           String        @id @default(cuid())
  ownerId      String
  aircraftId   String
  sharePercent Float         @default(100) // For fractional ownership
  startDate    DateTime      @default(now())
  endDate      DateTime? // null = currently active
  owner        AircraftOwner @relation(fields: [ownerId], references: [id])
  aircraft     Aircraft      @relation(fields: [aircraftId], references: [id])

  @@unique([ownerId, aircraftId])
  @@index([aircraftId])
}

// An OwnerRebillingInvoice is generated by the operator and sent to the owner.
// It can be triggered from a WorkOrder (CAMO maintenance) or a FlightLeg (ops costs).
// Status flow: DRAFT → PENDING_OWNER → ACKNOWLEDGED → PAID | DISPUTED
model OwnerRebillingInvoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique
  ownerId       String
  aircraftId    String
  status        String @default("DRAFT")
  // DRAFT | PENDING_OWNER | ACKNOWLEDGED | PAID | DISPUTED | CANCELLED

  invoiceType String @default("MAINTENANCE")
  // MAINTENANCE | HANDLING | FUEL | PARTIAL_ADVANCE | FINAL | OPERATIONAL

  title       String // e.g. "Q1 2025 Maintenance — D-HABC"
  notes       String? @db.Text
  currency    String  @default("EUR")
  subtotal    Float   @default(0)
  vatRate     Float   @default(0.19)
  vatAmount   Float   @default(0)
  totalAmount Float   @default(0)

  // AI-generated plain-language explanation for the owner portal
  aiExplanation   String?   @db.Text
  aiExplanationAt DateTime?
  // HITL: approved by an operator staff member before visible to owner
  hitlApprovedBy  String? // userId
  hitlApprovedAt  DateTime?

  // Source references
  workOrderId String? // if triggered from CAMO WO
  flightLegId String? // if triggered from flight ops

  // Owner interaction
  ownerViewedAt       DateTime?
  ownerAcknowledgedAt DateTime?
  ownerNotes          String?

  dueDate DateTime?
  paidAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     AircraftOwner            @relation(fields: [ownerId], references: [id])
  aircraft  Aircraft                 @relation(fields: [aircraftId], references: [id])
  lineItems OwnerRebillingLineItem[]
  workOrder WorkOrder?               @relation(fields: [workOrderId], references: [id])

  @@index([ownerId])
  @@index([aircraftId])
  @@index([status])
  @@index([flightLegId])
}

model OwnerRebillingLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float
  category    String? // LABOUR | PARTS | HANDLING | FUEL | OTHER
  vendorRef   String? // Original Vendor Invoice reference

  invoice OwnerRebillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─── CAMO FORMS & DOCUMENTS SYSTEM ───────────────────────────────────────────
// Wave 165: Universal Form Builder for CAMO/EASA compliance documents
// Part-M.A.704 (ARC), Part-M.A.710 (Review), Part-145 (Form 1), etc.

model FormTemplate {
  id                String           @id @default(cuid())
  orgId             String? // null = global EASA standard (available to all orgs)
  name              String
  description       String?          @db.Text
  category          String // ARC_ISSUE | ARC_EXTEND | ARC_CHECKLIST | ARC_EXTEND_CHECKLIST | FORM1 | WORK_ORDER | JOB_CARD | DEFECT | MEL_DEFERRAL | AUTHORITY_REPORT | MOC | CUSTOM
  fields            Json // FormFieldDef[] — see form-types.ts
  printLayout       String           @default("A4_PORTRAIT") // A4_PORTRAIT | A4_LANDSCAPE | EASA_STANDARD
  version           String           @default("1.0")
  isEASAStandard    Boolean          @default(false)
  isActive          Boolean          @default(true)
  requiredPrivilege String? // Role required to STAMP/ISSUE (e.g. "ARC_REVIEWER")
  sortOrder         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  submissions       FormSubmission[]

  @@index([orgId, category])
  @@index([isActive])
}

model FormSubmission {
  id            String    @id @default(cuid())
  formNumber    String    @unique // Auto-generated e.g. "ARC-2025-001"
  templateId    String
  orgId         String
  contextType   String // AIRCRAFT | AUDIT | WORK_ORDER | OCCURRENCE | STANDALONE
  contextId     String? // ID of linked entity (aircraftId, auditId, etc.)
  data          Json // {fieldId: value, ...} — all filled values
  status        String    @default("DRAFT") // DRAFT | COMPLETED | SIGNED | STAMPED | ARCHIVED
  signatures    Json      @default("{}") // {fieldId: {base64, signedBy, signedAt}}
  stamps        Json      @default("[]") // [{stampedBy, approvalRef, authorizationRef, role, signedAt, base64}]
  linkedFormIds Json      @default("[]") // IDs of related submissions (checklist → ARC)
  dataHash      String? // SHA-256 of data+signatures (set on STAMP)
  pdfUrl        String? // Hetzner Object Storage URL of archived PDF
  submittedById String
  submittedAt   DateTime?
  completedAt   DateTime?
  signedAt      DateTime?
  stampedAt     DateTime?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  template    FormTemplate @relation(fields: [templateId], references: [id])
  submittedBy User         @relation("FormSubmitter", fields: [submittedById], references: [id])

  @@index([orgId, contextId])
  @@index([contextType, contextId])
  @@index([status])
  @@index([templateId])
}

// ─── CAMO AUTHORISED PERSONNEL REGISTER ──────────────────────────────────────
// Part-CAMO.A.305 — CAMO must maintain a register of personnel authorised to
// conduct airworthiness reviews and issue/extend ARCs.
// This register is an mandatory Appendix to the CAME.
//
// Authorisation types:
//   ARC_REVIEW    → Conduct the physical airworthiness review (Part-CAMO.A.305(a))
//   ARC_ISSUE     → Issue the ARC on behalf of the CAMO (Part-M.A.710(a))
//   ARC_EXTEND    → Extend validity of ARC (Part-M.A.709)
//   CAMO_MANAGER  → Accountable / Post-holder
//   CERTIFYING_STAFF → Part-66 / Part-145 Certifying Staff sign-off
//   QUALITY_AUDIT → Quality audit / compliance monitoring (Part-CAMO.A.270)
//   SAFETY_MANAGER → Safety management responsibilities

/// Personnel authorised to perform CAMO functions per Part-CAMO.A.305
model CamoAuthorisedPersonnel {
  id    String @id @default(cuid())
  orgId String

  // Personal details
  fullName   String
  email      String?
  phone      String?
  employeeId String? // Internal staff number

  // Role / function
  role     String // CAMO_MANAGER | ARC_REVIEWER | CERTIFYING_STAFF | SAFETY_MANAGER | QUALITY_AUDITOR
  jobTitle String? // Free text: e.g. "Deputy CAMO Manager"

  // Authorisations — JSON array of authorisation objects
  // [{ type: ARC_ISSUE|ARC_EXTEND|ARC_REVIEW|..., ref: string, validFrom, validTo, aircraftTypes: string[] }]
  authorisations Json @default("[]")

  // Qualifications
  licenceNumber   String? // EASA Part-66 licence number (if Certifying Staff)
  licenceRatings  String? // JSON: string[] — rated aircraft types/categories
  trainingRecords String? // JSON: [{type, date, ref}]

  // CAME Appendix reference
  cameRef        String? // e.g. "CAME App. 1, Rev. 3"
  authorisedBy   String? // Name of the Accountable Manager who authorised
  authorisedById String? // userId (optional link)

  // Status
  isActive         Boolean   @default(true)
  validFrom        DateTime  @default(now())
  validTo          DateTime? // null = indefinite (renewed annually)
  suspendedAt      DateTime?
  suspensionReason String?

  // Notes
  notes String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@index([orgId, role])
  @@index([orgId, isActive])
  @@index([validTo])
}

// ─── AUTHORITY PORTAL ─────────────────────────────────────────────────────────
// External access for LBA / EASA inspectors — isolated from main user table.

model AuthorityPortalUser {
  id              String    @id @default(cuid())
  orgId           String
  email           String
  name            String
  organization    String // e.g. "Luftfahrt-Bundesamt", "EASA"
  role            String    @default("VIEWER") // VIEWER | APPROVER
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdByUserId String?

  tokens      AuthorityPortalToken[]
  sharedItems AuthoritySharedItem[]
  comments    AuthorityPortalComment[]

  @@unique([orgId, email])
  @@index([orgId])
}

model AuthorityPortalToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user AuthorityPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model AuthoritySharedItem {
  id           String @id @default(cuid())
  orgId        String
  portalUserId String

  itemType    String
  itemId      String
  itemCode    String?
  title       String
  description String?
  fileUrl     String?

  actionType String // APPROVAL | ACCEPTANCE | READ_RECEIPT | SIGNATURE | DOWNLOAD | INFO
  shareNote  String?
  deadline   DateTime?

  status String @default("PENDING")

  fulfilledAt   DateTime?
  fulfilledBy   String?
  fulfilledNote String?
  signature     String?

  sharedAt       DateTime @default(now())
  sharedByUserId String?

  portalUser AuthorityPortalUser      @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  comments   AuthorityPortalComment[]

  @@index([orgId])
  @@index([orgId, portalUserId])
  @@index([orgId, itemId])
  @@index([orgId, status])
}

model AuthorityPortalComment {
  id           String @id @default(cuid())
  orgId        String
  itemId       String
  portalUserId String

  authorType String // AUTHORITY | OPERATOR
  authorName String
  content    String @db.Text

  requiresFollowUp Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedBy       String?

  createdAt DateTime @default(now())

  item       AuthoritySharedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  portalUser AuthorityPortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)

  @@index([orgId, itemId])
  @@index([portalUserId])
}

model AuthorityApprovalRequest {
  id              String    @id @default(cuid())
  orgId           String
  ref             String    @unique
  itemType        String
  itemId          String
  itemTitle       String
  itemCode        String?
  actionType      String
  message         String?   @db.Text
  authorityEmail  String
  authorityName   String?
  authorityOrg    String    @default("Luftfahrt-Bundesamt")
  pinHash         String
  pinExpiresAt    DateTime
  pinAttempts     Int       @default(0)
  status          String    @default("PENDING")
  fulfilledAt     DateTime?
  fulfilledBy     String?
  fulfilledNote   String?
  fulfilledIp     String?
  signature       String?
  createdAt       DateTime  @default(now())
  createdByUserId String?

  @@index([orgId])
  @@index([ref])
  @@index([orgId, itemId])
  @@index([orgId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// JetmindDocument — Universal document archive with OCR metadata
// Bridges Paperless-ngx DMS (external) with all Jetmind modules.
// ─────────────────────────────────────────────────────────────────────────────
model JetmindDocument {
  id    String @id @default(cuid())
  orgId String @default("") // tenant isolation

  // ── Storage ────────────────────────────────────────────────────────────
  filename      String // original upload filename
  mimeType      String // application/pdf, image/jpeg, etc.
  fileUrl       String // Hetzner Object Storage URL (primary storage)
  fileSizeBytes Int?

  // ── Paperless-ngx ──────────────────────────────────────────────────────
  paperlessId  Int?      @unique // Paperless document ID (null until archived)
  paperlessUrl String? // direct link to Paperless web UI
  archivedAt   DateTime?

  // ── Gemini OCR ─────────────────────────────────────────────────────────
  ocrStatus      String    @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  ocrProcessedAt DateTime?
  ocrDurationMs  Int?
  documentType   String    @default("GENERAL") // AviationDocumentType enum
  confidence     Float? // 0.0 – 1.0
  rawOcrText     String?   @db.Text // full OCR text for search
  extractedJson  String?   @db.Text // full OcrExtractedData as JSON

  // ── Structured extracted fields (indexed for fast queries) ─────────────
  suggestedTitle String?
  issuedTo       String?
  issuedBy       String?
  documentNumber String?
  issueDate      DateTime?
  expiryDate     DateTime?
  aircraftType   String?
  trainingType   String?
  grade          String?
  regulationRef  String?

  // ── Status flags ───────────────────────────────────────────────────────
  isExpired      Boolean @default(false)
  isExpiringSoon Boolean @default(false)
  warningFlags   String  @default("[]") // JSON array of string flags
  needsReview    Boolean @default(false) // HITL flag: low confidence or warnings

  // ── Links to Jetmind records (all optional — link to relevant module) ──
  crewMemberId   String?
  crewDocId      String?
  trainingId     String?
  certificateId  String?
  camoAircraftId String?
  workPackId     String?
  auditId        String?
  findingId      String?
  mocId          String?
  manualId       String?

  // ── Upload provenance ──────────────────────────────────────────────────
  uploadedByUserId String?
  uploadedAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, documentType])
  @@index([orgId, ocrStatus])
  @@index([orgId, expiryDate])
  @@index([orgId, isExpired])
  @@index([orgId, needsReview])
  @@index([crewMemberId])
  @@index([camoAircraftId])
}

// ─── NOTIFICATION PREFERENCES ─────────────────────────────────────────────────
// Configures who receives which email notifications and when.

/// Global notification rule: which roles/emails get notified for which event type.
model sys_notification_rule {
  id    String @id @default(cuid())
  orgId String @default("")

  // Event type — what triggers this notification
  eventType String // e.g. CREW_CERT_EXPIRY | ARC_EXPIRY | WORK_ORDER_DISPATCH | CAPA_OVERDUE | READ_SIGN | AUDIT_FINDING | SRB_MINUTES

  // Who receives it
  recipientType  String // ROLE | EMAIL | CREW_SELF
  recipientValue String // e.g. "CAMO_MANAGER" | "ops@airline.com" | "CREW_SELF"

  // When to trigger (days before expiry, 0 = on event)
  daysBeforeExpiry Int @default(0) // 0 = immediate, 30 = 30 days before, etc.

  // Fine-tuning
  isEnabled Boolean @default(true)
  label     String? // Human-readable label e.g. "30-day ARC warning"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, eventType])
  @@index([orgId, isEnabled])
}

/// Log of sent notifications (for deduplication + audit trail)
model sys_notification_log {
  id             String   @id @default(cuid())
  orgId          String   @default("")
  eventType      String
  subjectId      String // ID of the entity that triggered this (e.g. crewQualId, aircraftId)
  recipientEmail String
  subject        String
  sentAt         DateTime @default(now())
  success        Boolean  @default(true)
  error          String?

  @@index([orgId, eventType])
  @@index([subjectId])
  @@index([sentAt])
}

// ─── AMP (AIRCRAFT MAINTENANCE PROGRAMME) ────────────────────────────────────
// M.A.302 — EASA Part-M / Part-CAMO
// The AMP is managed within a Manual (doc_manuals) and links to Aircraft.
// Source documents (AMM revisions, STCs, SBs, MPDs) drive task proposals.
// All AI-extracted tasks go through HITL review before becoming active.

/// A source document linked to an AMP — AMM, STC, MPD, SB, Minor Change
model AmpSourceDoc {
  id        String @id @default(cuid())
  orgId     String @default("")

  // Which manual (AMP) this document belongs to
  manualId  String
  manual    doc_manuals @relation(fields: [manualId], references: [id], onDelete: Cascade)

  // Which aircraft this affects (optional — some docs are type-wide)
  aircraftId String?
  aircraft   Aircraft? @relation(fields: [aircraftId], references: [id])

  // Document identity
  docType     String // AMM | MPD | STC | SB | AD | MINOR_CHANGE | OTHER
  reference   String // e.g. "AMM Rev 47" | "STC EASA.A.S.02376" | "SB 27-001"
  title       String @default("")
  issuer      String @default("") // Manufacturer | EASA | FAA | STC-Holder
  docRevision String @default("") // "Rev 47" | "Issue 3"
  effectiveDate DateTime?

  // Storage
  fileUrl   String? // Hetzner Object Storage URL
  fileHash  String? // SHA-256 for tamper detection
  fileSizeBytes Int @default(0)

  // AI Analysis
  analysisStatus  String @default("PENDING") // PENDING | ANALYSING | DONE | FAILED
  analysisJson    String? // Full Gemini response (JSON)
  tasksProposed   Int    @default(0) // How many tasks were extracted
  tasksAccepted   Int    @default(0)
  tasksRejected   Int    @default(0)

  // Audit trail
  uploadedByUserId String?
  uploadedAt       DateTime @default(now())
  analysedAt       DateTime?

  tasks AmpTask[]

  @@index([orgId])
  @@index([orgId, manualId])
  @@index([orgId, aircraftId])
  @@index([docType])
  @@index([analysisStatus])
}

/// A single maintenance task extracted from a source document and proposed for the AMP
/// Follows M.A.302 structure: ATA chapter, task ID, intervals (FH/FC/Calendar), mandatory/optional
model AmpTask {
  id        String @id @default(cuid())
  orgId     String @default("")

  // Which AMP (manual) this task belongs to
  manualId  String
  manual    doc_manuals @relation(fields: [manualId], references: [id], onDelete: Cascade)

  // Which source document proposed this task
  sourceDocId String?
  sourceDoc   AmpSourceDoc? @relation(fields: [sourceDocId], references: [id])

  // ATA Classification (e.g. "05-10" = Scheduled Maintenance Checks)
  ataChapter  String @default("") // ATA 100 / JASC chapter (e.g. "21", "32-10")
  taskNumber  String @default("") // MPD/AMM task number (e.g. "05-10-01")
  taskTitle   String @default("")
  description String @default("") // What the task involves

  // Task type (from AMM/MPD nomenclature)
  taskType    String @default("INSPECTION") // INSPECTION | FUNCTIONAL_CHECK | LUBRICATION | REPLACEMENT | OVERHAUL | STRUCTURAL | OTHER

  // Intervals — at least one must be set for scheduled tasks
  intervalFH       Float?   // Flight Hours interval (e.g. 500.0)
  intervalFC       Int?     // Flight Cycles interval (e.g. 1000)
  intervalDays     Int?     // Calendar days (e.g. 365)
  intervalMonths   Int?     // Calendar months (e.g. 12)

  // First due thresholds (from MPD "First Compliance")
  firstDueFH       Float?
  firstDueFC       Int?
  firstDueDays     Int?

  // Tolerances (% or absolute)
  tolerancePct     Float?   // e.g. 25.0 for ±25%
  toleranceFH      Float?   // absolute FH tolerance (e.g. ±50 FH)

  // Mandatory / Airworthiness Limitations
  isMandatory      Boolean @default(false) // ALS/CMR — cannot be escalated
  isAlsTask        Boolean @default(false) // Airworthiness Limitation Section
  isCmr            Boolean @default(false) // Certification Maintenance Requirement
  isAdRelated      Boolean @default(false) // Driven by an Airworthiness Directive

  // Reference to source data for traceability (M.A.302 compliance)
  mpdTaskRef       String? // MPD task number cross-reference
  ammRef           String? // AMM section reference (e.g. "32-10-01")
  adReference      String? // AD number if task is AD-driven
  stcReference     String? // STC reference if task comes from STC ICA

  // Access level (who can perform)
  certificationReq String @default("") // e.g. "Part-66 Cat B1" | "Part-145"

  // HITL Status — M.A.302 requires human review/approval of AMP tasks
  hitlStatus    String @default("PROPOSED") // PROPOSED | ACCEPTED | REJECTED | MODIFIED
  hitlNote      String? // Why accepted/rejected/modified
  reviewedBy    String? // User ID who reviewed
  reviewedAt    DateTime?

  // AI extraction confidence
  aiConfidence  Float @default(0) // 0.0 – 1.0

  // Activation
  isActive      Boolean @default(false) // Only active after ACCEPTED + AMP revision
  activatedAt   DateTime?
  activatedBy   String?

  // AMP revision when this task was introduced
  ampRevisionAdded String? // e.g. "Rev 14"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, manualId])
  @@index([orgId, hitlStatus])
  @@index([orgId, isActive])
  @@index([ataChapter])
  @@index([isMandatory])
  @@index([sourceDocId])
}

// ─── CAMO Part Replacement Ledger ─────────────────────────────────────────────
// EASA Part-CAMO.A.315 — component traceability & warranty management
model PartReplacement {
  id                       String              @id @default(cuid())
  aircraftId               String
  workPackId               String?

  // Part identification (EASA Form 1 / FAA 8130-3 traceable)
  partNumber               String
  altPartNumber            String?
  serialNumber             String?
  batchLot                 String?
  description              String
  ataChapter               String?

  // Replacement event
  replacedAt               DateTime
  replacedPartSerialNumber String?
  replacedDueTo            String              // fault description
  faultCode                String?
  techLogRef               String?

  // Supplier & traceability
  supplier                 String?
  traceRef                 String?
  approvedDesign           Boolean             @default(true)

  // Hours/Cycles at install
  tsnAtInstall             Float?
  csnAtInstall             Float?

  // Warranty
  warrantyStatus           String              @default("UNKNOWN")
  // UNKNOWN | UNDER_WARRANTY | OUT_OF_WARRANTY | EXPIRED | CLAIMED
  warrantyExpiry           DateTime?
  warrantyRef              String?
  warrantyClaimSent        Boolean             @default(false)
  warrantyAmount           Float?              // recovered amount if claimed

  // Cost
  partCost                 Float?
  laborCost                Float?
  currency                 String              @default("EUR")

  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  aircraft  Aircraft            @relation(fields: [aircraftId], references: [id])
  workPack  MaintenanceWorkPack? @relation(fields: [workPackId], references: [id])

  @@index([aircraftId])
  @@index([workPackId])
  @@index([partNumber])
  @@index([warrantyStatus])
  @@index([ataChapter])
  @@index([replacedAt])
}

// ─── Work Order Quote Revision (cost escalation log) ──────────────────────────
// EASA Part-CAMO — audit trail for maintenance cost changes
model WorkOrderQuoteRevision {
  id          String   @id @default(cuid())
  quoteItemId String
  revisionNum Int
  previousPrice Float
  newPrice    Float
  delta       Float
  deltaPercent Float
  reason      String
  reasonCode  String?
  approvedById String?
  changedAt   DateTime @default(now())

  quoteItem WorkOrderQuoteItem @relation(fields: [quoteItemId], references: [id])

  @@index([quoteItemId])
  @@index([changedAt])
}

// ─── Training Scheduler ───────────────────────────────────────────────────────
// EASA ORO.FC.230 — operator training planning configuration

model TrainingSchedulerConfig {
  id     String  @id @default(cuid())
  orgId  String?

  // Sim capacity
  simCount              Int     @default(1)
  simBlockHoursPerDay   Float   @default(8.0)
  maxTreHoursPerDay     Float   @default(8.0)

  // Daily quotas
  opcPerDay              Int     @default(2)
  lpcPerDay              Int     @default(2)
  combinedOpcLpcPerDay   Int     @default(1)
  lineCheckPerDay        Int     @default(1)
  crmParticipantsPerDay  Int     @default(12)

  // Session durations (hours)
  opcDurationHours       Float   @default(4.0)
  lpcDurationHours       Float   @default(4.0)
  combinedDurationHours  Float   @default(6.0)
  lineCheckDurationHours Float   @default(3.0)
  crmDurationHours       Float   @default(8.0)

  // Pairing options
  pilotsPerSimSession    Int     @default(2)
  allowPairedOpc         Boolean @default(true)
  allowCombinedOpcLpc    Boolean @default(true)
  groupCrmByFleet        Boolean @default(true)
  groupByHomeBase        Boolean @default(false)

  // Planning horizon
  minNoticeDays          Int     @default(14)
  planningHorizonWeeks   Int     @default(26)
  creditWindowMonths     Int     @default(3)

  // Urgency weights
  weightOverdue          Float   @default(100)
  weightCritical         Float   @default(80)
  weightExpiring         Float   @default(60)
  weightDue              Float   @default(40)
  weightEarlyRenewal     Float   @default(10)

  // JSON config fields
  simLocationsJson       String  @default("[{\"icao\":\"BASE\",\"label\":\"Home Base\",\"fleets\":[]}]")
  workingDaysJson        String  @default("[1,2,3,4,5]")
  simUnavailableDatesJson String @default("[]")

  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model TrainingSchedulePlan {
