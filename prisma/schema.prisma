/// Per-country passenger taxes — configurable tiers based on distance
/// Example: Italy (LI**) charges 100 EUR/pax <1500km, 200 EUR/pax >=1500km
model CountryTax {
  id          String  @id @default(cuid())
  countryCode String // ISO 2-letter: IT, DE, FR, ES, CH, AT ...
  countryName String // Display name: "Italy", "Germany"
  taxName     String // e.g. "Italian Air Passenger Duty (APD)"
  taxCode     String? // Internal code e.g. "IT_APD"

  // Who pays?
  appliesTo String @default("PASSENGER") // PASSENGER | AIRCRAFT | BOTH
  // When does it apply?
  direction String @default("BOTH") // DEPARTURE | ARRIVAL | BOTH

  // ── Tier System (JSON array for distance-based rates) ──────────────────
  // JSON: [{minKm:0, maxKm:1499, amountPerPax:100}, {minKm:1500, maxKm:null, amountPerPax:200}]
  tiersJson String // JSON array of TaxTier objects

  currency String @default("EUR")

  // ── Exemptions ─────────────────────────────────────────────────────
  // JSON: ["TRANSIT", "CONNECTING", "CARGO", "CREW", "INFANTS"]
  exemptionsJson String @default("[]")

  // ── Validity ───────────────────────────────────────────────────
  validFrom  DateTime  @default(now())
  validUntil DateTime? // null = indefinite
  isActive   Boolean   @default(true)

  // ── Source / Audit ─────────────────────────────────────────────
  source    String? // "Official gazette", "Government website", etc.
  notes     String?  @db.Text // Additional compliance notes
  updatedBy String? // User ID who last updated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryCode, taxCode])
  @@index([countryCode])
}

