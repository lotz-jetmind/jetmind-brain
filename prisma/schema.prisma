// ─── OMEGA DIRECTIVE: MODULE 3 (MANAGEMENT OF CHANGE) ─────────────────────────

model mod3_moc_projects {
  id                                 String   @id @default(uuid())
  orgId                              String   @default("") // tenant isolation
  moc_number                         String   @unique
  title                              String
  description_raw                    String
  source_cap_id                      String?
  owner_user_id                      String
  target_date                        DateTime
  ai_impact_analysis                 String? // legacy — kept for backward compat
  accountable_manager_signature_hash String?
  status                             String   @default("Draft")
  is_prior_approval_required         Boolean  @default(false)
  lba_approved                       Boolean  @default(false)

  // ── Three-State Analysis (EASA AMC1 ORO.GEN.200) ─────────────────────────
  current_state_desc     String? // How things work TODAY
  transition_period_desc String? // Risks/changes DURING transition
  future_state_desc      String? // Target state AFTER change

  // ── Classification ────────────────────────────────────────────────────────
  change_class             String  @default("Minor") // Minor | Significant | Major
  classification_reasoning String? // Mandatory for Significant + Major
  triggered_by             String? // Regulatory | CAPA | Internal | Safety_Report | External | Other
  affected_manuals_json    String? // JSON string: ["OM-A", "CAME", ...]

  // ── LBA / NAA Communication ───────────────────────────────────────────────
  lba_notification_sent_at DateTime?
  lba_notification_ref     String? // Reference number of notification
  lba_prior_approval_ref   String? // LBA reference on approval letter
  lba_prior_approval_date  DateTime? // Date approval was received

  // ── Implementation ────────────────────────────────────────────────────────
  implementation_date   DateTime?
  change_readiness_json String? // JSON: [{label, checked, checkedAt, checkedBy}]

  // ── Post-Implementation Review ────────────────────────────────────────────
  pir_due_date         DateTime?
  pir_completed_date   DateTime?
  pir_status           String    @default("Not_Required") // Not_Required | Pending | InProgress | Completed
  pir_findings         String?
  pir_sign_off_user_id String?

  sme_signoffs      mod3_sme_signoffs[]
  proactive_hazards mod3_proactive_hazards[]
  moc_hazards       mod3_moc_hazards[]
  moc_documents     mod3_moc_documents[]
  source_cap        mod2_cap_tasks?             @relation(fields: [source_cap_id], references: [id])
  briefings         mod8_compliance_briefings[]
  amendments        mod9_10_amendments[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, change_class])
}

