// ─── OMEGA DIRECTIVE: MODULE 5 (AUTHORITY REPORTING) ──────────────────────────

model mod5_authority_reports {
  id                   String    @id @default(uuid())
  occurrence_id        String    @unique
  deadline_utc         DateTime
  eccairs_payload_json String?
  submission_status    String // Enum: Ticking, Draft_Generated, Submitted_On_Time, Submitted_Late, Missed_Deadline
  submitted_at_utc     DateTime?

  // ── EASA Reporting Basis (EU 376/2014) ───────────────────────────────────────
  // MANDATORY_72H     → Accident / Serious Incident: LBA + EASA within 72h
  // MANDATORY_30DAY   → Incident: LBA within 30 days (Art. 4 EU 376/2014)
  // VOLUNTARY         → Occurrence: Optional internal/external submission
  reporting_basis   String @default("MANDATORY_72H")
  // notification_type: INITIAL (within deadline) | SUPPLEMENTARY (follow-up detail)
  notification_type String @default("INITIAL")

