generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  name                     String?
  hashedPassword           String?
  mfaSecret                String?
  mfaEnabled               Boolean                   @default(false)
  mfaMethod                String                    @default("totp") // totp | email | backup
  mfaBackupCodes           String? // JSON array of hashed backup codes
  passwordResetToken       String?                   @unique
  passwordResetExpiry      DateTime?
  lastLoginAt              DateTime?
  failedLoginAttempts      Int                       @default(0)
  lockedUntil              DateTime?
  opsRole                  String                    @default("VIEWER")
  role                     String                    @default("VIEWER")
  userRoleId               String?
  orgId                    String?
  department               String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  customFields             String?
  homeBase                 String?
  flight_duty_block_active Boolean                   @default(false)
  aiEnabled                Boolean                   @default(true) // Per-user AI feature flag; false = hide all AI UI + block AI actions
  chatMessages             ChatMessage[]
  formSubmissions          FormSubmission[]          @relation("FormSubmitter")
  authorityContacts        compliance_authority_contact[] @relation("AuthorityContactCreatedBy")
  authorityTasksAssigned   compliance_authority_task[]    @relation("AuthorityTaskAssignee")
  complianceDeadlines      compliance_deadline[]           @relation("DeadlineCreatedBy")
  crewMember               CrewMember?
  timeOffRequests          CrewTimeOffRequest[]
  duties                   DutyPeriod[]
  customerTrips            Flight[]                  @relation("CustomerTrips")
  authoredNews             NewsItem[]
  organization             Organization?             @relation(fields: [orgId], references: [id])
  userRole                 Role?                     @relation(fields: [userRoleId], references: [id])
  approvedWorkPackages     WorkPackageReview[]
  flights                  FlightLeg[]               @relation("FlightLegToUser")
  read_and_sign_logs       mod7_read_and_sign_logs[]
  training_records         mod8_training_records[]
  mod6_audits              mod6_audits[]             @relation("AuditLead")
  sys_ai_veto_log          sys_ai_veto_log[]
  sys_techpubs_evaluated   sys_techpubs_evaluated[]  @relation("EvaluatedTechPubs")
  doc_read_receipts        doc_read_receipts[]       @relation("UserReadReceipts")
  assigned_doc_tasks       doc_tasks[]               @relation("AssignedDocTasks")
  created_doc_tasks        doc_tasks[]               @relation("CreatedDocTasks")
  hitl_assigned            sys_ai_hitl_item[]        @relation("HITLAssignee")
  hitl_reviewed            sys_ai_hitl_item[]        @relation("HITLReviewer")
  signaturePin             String?
  emailVerified            DateTime?
  isAuditor                Boolean                   @default(false)
  // ── HR / Personal Details ────────────────────────────────────────────────
  address                  String?
  phone                    String?
  dateOfJoining            DateTime?
  dateOfLeaving            DateTime?
  status                   String                    @default("ACTIVE") // ACTIVE, INACTIVE, DELETED
  aircraftTypes            String? // e.g. "A320, B737"
  passportNumber           String?
  dateOfBirth              DateTime?
  crewRole                 String? // e.g. "CAPTAIN", "FIRST_OFFICER", "CABIN_CREW", "MECHANIC"

  npOfDepartments         Department[]              @relation("DepartmentNP")
  deputyOfDepartments     Department[]              @relation("DepartmentDeputy")
  amendment_signatures    mod9_10_signatures[]
  reported_hazards        mod1_occurrences[]        @relation("ReportedHazards")
  owned_mitigations       mod1_occurrences[]        @relation("MitigationOwner")
  // ── SQMS Audit Module relations ─────────────────────────────────────────
  sqms_audits_led         sqms_Audit[]              @relation("sqms_AuditLead")
  sqms_audits_as_auditee  sqms_Audit[]              @relation("sqms_AuditeeOf")
  sqms_findings_assigned  sqms_Finding[]            @relation("sqms_FindingAssignee")
  sqms_containments       sqms_Containment[]        @relation("sqms_ContainmentActor")
  sqms_capa_actions       sqms_CapaAction[]         @relation("sqms_CapaResponsible")
  sqms_verifications      sqms_Verification[]       @relation("sqms_VerificationActor")
  sqms_signatures         sqms_DigitalSignature[]   @relation("sqms_AuditSigner")
  sqms_evidence_uploaded  sqms_Evidence[]           @relation("sqms_EvidenceUploader")
  sqms_push_subscriptions sqms_PushSubscription[]   @relation("sqms_PushSubscriber")
  sqms_srb_chaired        sqms_SRBMeeting[]         @relation("sqms_SRBChair")
  sqms_srb_attendances    sqms_SRBAttendee[]        @relation("sqms_SRBAttendee")
  sqms_srb_tasks          sqms_SRBTask[]            @relation("sqms_SRBTaskOwner")
  sms_safety_policies     sms_safety_policy[]       @relation("PolicyCreator")
  sms_safety_objectives   sms_safety_objective[]    @relation("ObjectiveCreator")
  sms_just_culture        sms_just_culture_policy[] @relation("JCPolicyCreator")
  sms_bowtie_diagrams     sms_bowtie_diagram[]      @relation("BowtieDiagramCreator")
  sms_erp_exercises         sms_erp_exercise_log[]    @relation("ERPExerciseCreator")
  sms_erp_revisions         sms_erp_revision[]         @relation("ERPRevisionAuthor")
  sms_erp_activations       sms_erp_activation[]       @relation("ERPActivationCreator")
  sms_erp_resolutions       sms_erp_activation[]       @relation("ERPActivationResolver")
  signal_threads            signal_thread[]             @relation("SignalThreadCreator")
  signal_messages           signal_message[]            @relation("SignalMessageAuthor")
  signal_actions            signal_action[]             @relation("SignalActionCreator")
  // ── Flight Ops (FOM/FOI) ─────────────────────────────────────────────────
  fom_issued              sqms_FlightOpsMessage[]
  fom_acknowledgements    sqms_FomAcknowledgement[] @relation("FomAcknowledgements")
  // ── Safety Signal Bus ────────────────────────────────────────────────────
  signals_created         sqms_Signal[]             @relation("sqms_SignalCreator")
  signals_acknowledged    sqms_Signal[]             @relation("sqms_SignalAcknowledger")
  signals_actioned        sqms_Signal[]             @relation("sqms_SignalActioner")
  signals_resolved        sqms_Signal[]             @relation("sqms_SignalResolver")
  sqms_audit_messages     sqms_AuditMessage[]       @relation("sqms_AuditMessageSender")
  sqms_doc_requested      sqms_AuditDocRequest[]    @relation("sqms_DocRequestedBy")
  sqms_doc_uploaded       sqms_AuditDocRequest[]    @relation("sqms_DocUploadedBy")
  sqms_doc_reviewed       sqms_AuditDocRequest[]    @relation("sqms_DocReviewedBy")
  // ── Compliance Activity ───────────────────────────────────────────────────
  compliance_activities   sqms_ComplianceActivity[] @relation("sqms_ActivityPerformer")
  // ── Organisation Management ────────────────────────────────────────────
  orgPosts                OrgPost[]
  orgPostsAsDeputy        OrgPost[]                 @relation("OrgPostDeputy")
  // ── Read Tracking ──────────────────────────────────────────────────────
  docReadRecords          DocReadRecord[]           @relation("UserReadRecords")
  readGroupMemberships    ReadGroupMember[]         @relation("UserReadGroups")

  // ── Performance indexes ───────────────────────────────────────────────────
  @@index([email]) // Login lookup (most frequent query)
  @@index([orgId]) // Tenant isolation filter
  @@index([role]) // Role-based access control queries
  @@index([orgId, role]) // Combined tenant + role filtering
  @@index([orgId, status])
  // ── External Audit & Auditor Qualifications ──────────────────────────────
  sqms_external_audits_created sqms_ExternalAudit[]        @relation("ExternalAuditCreatedBy")
  sqms_auditor_quals           sqms_AuditorQualification[] @relation("AuditorQualifications")
  sqms_auditor_quals_created   sqms_AuditorQualification[] @relation("AuditorQualCreatedBy")
  sqms_audits_acknowledged     sqms_Audit[]                @relation("sqms_AuditeeAcknowledger")
  auditee_responses_submitted  sqms_AuditeeResponse[]      @relation("AuditeeResponseSubmitter")
  auditee_responses_reviewed   sqms_AuditeeResponse[]      @relation("AuditeeResponseReviewer")
  audit_records_audited        sqms_RequirementAuditRecord[] @relation("RequirementAuditRecordAuditor")
  requirement_evidence_uploaded sqms_RequirementEvidence[]   @relation("RequirementEvidenceUploader")
  article_audit_sessions_reviewed sqms_ArticleAuditSession[] @relation("ArticleAuditSessionReviewer")
  brain_briefings              sys_brain_briefing[]
  pdf_archive                  sys_pdf_archive[]             @relation("PdfArchiveUser")
}

// ─── ORGANISATION MANAGEMENT (APP020 / OMM) ────────────────────────────────────────────────
model OrgUnit {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?  @db.Text
  color       String   @default("#6366f1")
  sortOrder   Int      @default(0)
  parentId    String? // Hierarchical parent (org chart position)
  reportsToId String? // Functional reporting line (can differ from hierarchy)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent     OrgUnit?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children   OrgUnit[] @relation("OrgHierarchy")
  reportsTo  OrgUnit?  @relation("OrgReporting", fields: [reportsToId], references: [id])
  reportedBy OrgUnit[] @relation("OrgReporting")
  posts      OrgPost[]
}

model OrgPost {
  id                        String  @id @default(uuid())
  unitId                    String
  title                     String
  abbreviation              String?
  regulationRef             String? // e.g. "CAMO.A.305(a)", "ORO.GEN.210(a)"
  description               String? @db.Text
  isNominatedPerson         Boolean @default(false)
  requiresForm4             Boolean @default(false)
  requiresAuthorityApproval Boolean @default(false)
  sortOrder                 Int     @default(0)
  holderId                  String?
  deputyId                  String?
  reportsToNote             String? // Pipe-separated reporting lines

  // ── Appointment / Tenure ─────────────────────────────────────────────────
  appointmentDate      DateTime? // Official date of appointment of current holder
  appointmentLetterRef String? // Reference to appointment letter (e.g. "APT-2024-001")
  npStatus             String? // "ACTIVE" | "PENDING_APPROVAL" | "EXPIRED" | "VACANT"

  // ── EASA Form 4 / Authority Approval ─────────────────────────────────────
  form4Ref              String? // EASA Form 4 reference number
  form4Date             DateTime? // Date Form 4 was issued / approved
  form4Expiry           DateTime? // Expiry date of Form 4 approval
  form4IssuingAuthority String? // e.g. "LBA", "CAA", "EASA"

  // ── Qualifications / Experience ───────────────────────────────────────────
  qualificationsNote String? // Brief notes on required qualifications / licenses
  licenseNumber      String? // Relevant license/certificate number (if applicable)

  // ── Validity Window ───────────────────────────────────────────────────────
  validFrom DateTime?
  validTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit   OrgUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  holder User?   @relation(fields: [holderId], references: [id])
  deputy User?   @relation("OrgPostDeputy", fields: [deputyId], references: [id])
}

model RCA {
  id        String    @id @default(cuid())
  findingId String    @unique
  rootCause String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  steps     RCAStep[]

  @@index([findingId])
}

model RCAStep {
  id       String @id @default(cuid())
  rcaId    String
  order    Int
  question String
  answer   String
  rca      RCA    @relation(fields: [rcaId], references: [id])
}

model AuditAnswer {
  id         String  @id @default(cuid())
  auditId    String
  questionId String
  status     String
  comment    String?

  @@index([auditId])
  @@index([status])
}

model AuditHeatmap {
  id        String   @id @default(cuid())
  data      String
  createdAt DateTime @default(now())
}

/// @deprecated Use sqms_Capa / sqms_CapaAction instead. Legacy CAPA model.
model CAP {
  id          String   @id @default(cuid())
  findingId   String   @unique
  description String
  dueDate     DateTime
  status      String   @default("OPEN")
  actions     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([findingId])
  @@index([status])
}

model ITAsset {
  id               String          @id @default(cuid())
  name             String
  type             String
  criticalityLevel String
  owner            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  incidents        CyberIncident[]
}

model CyberIncident {
  id                String   @id @default(cuid())
  title             String
  date              DateTime @default(now())
  threatType        String
  operationalImpact String
  assetId           String
  status            String   @default("OPEN")
  mitigation        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  asset             ITAsset  @relation(fields: [assetId], references: [id])

  @@index([status])
}

// ─── Immutable System Audit Log ───────────────────────────────────────────────
// Written on every approval/state-change action. Never deleted. EASA ORO.GEN.200
model sys_audit_log {
  id            String   @id @default(uuid())
  actor_user_id String? // NULL if SYSTEM action
  action        String // e.g. "TRIAGE_VALIDATE", "TRIAGE_REJECT", "ASSESSMENT_AUTHORIZED"
  target_table  String // e.g. "mod1_occurrences"
  target_id     String // ID of the affected record
  payload_json  String? // Serialized diff / decision data (JSON string)
  created_at    DateTime @default(now())

  @@index([target_table, target_id])
}

model Aircraft {
  id                      String                      @id @default(cuid())
  registration            String                      @unique
  type                    String
  typeId                  String?
  serialNumber            String
  msn                     String?
  engineDetails           String?
  apuDetails              String?
  flightHours             Int                         @default(0)
  flightCycles            Int                         @default(0)
  ampReference            String?
  ammReference            String?
  emmReference            String?
  apuMMReference          String?
  lastCheckDate           DateTime?
  nextCheckDate           DateTime?
  fuelMassUnit            String                      @default("KG")
  fuelVolumeUnit          String                      @default("LTR")
  customFields            String?
  customAttributes        String                      @default("{}")
  isCamoActive            Boolean                     @default(true)
  // ── AOG (Aircraft on Ground) tracking ──────────────────────────────────────────
  isAog                   Boolean                     @default(false)
  aogSince                DateTime?
  aogReason               String?
  aogEtr                  DateTime? // Estimated Time of Recovery
  // ── Charter / Positioning ──────────────────────────────────────────────────
  // freeCirculation: aircraft is not based at a fixed airport (always flying)
  // When true, the system will not add a return-to-home-base positioning cost.
  // Instead, a hotspot surcharge is applied when the trip ends at a hotspot airport.
  freeCirculation         Boolean                     @default(false)
  // homeBaseIcao: overrides the operator home base for this specific aircraft
  // Leave blank to inherit the operator home base from SalesSettings
  homeBaseIcao            String?
  // ── ARC (Airworthiness Review Certificate) ── Part-M.A.704
  arcNumber               String?
  arcExpiryDate           DateTime?
  lastArcReviewDate       DateTime?
  aircraftType            AircraftType?               @relation(fields: [typeId], references: [id])
  maintenanceStatus       AircraftMaintenanceStatus[]
  pricing                 AircraftPricing?
  pricingAssignment       AircraftPricingAssignment?
  adStatusList            camo_ad_status_list[]
  defects                 Defect[]
  flights                 FlightLeg[]
  workPacks               MaintenanceWorkPack[]
  pbhCoverage             PBH_WarrantyCoverage[]
  quotes                  Quote[]
  structuralDamage        StructuralDamage[]
  techLogEntries          TechLogEntry[]
  workOrders              WorkOrder[]
  hazards                 mod1_occurrences[]          @relation("AircraftHazards")
  airworthinessCompliance AircraftDocCompliance[]
  ampSourceDocs           AmpSourceDoc[]
  ownerships              AircraftOwnership[]
  ownerRebillingInvoices  OwnerRebillingInvoice[]
  partReplacements        PartReplacement[]
}

model MaintenanceDefinition {
  id String @id @default(cuid())
  // ── Performance indexes ───────────────────────────────────────────────────

  name           String
  description    String?                     @db.Text
  intervalFH     Int?
  intervalFC     Int?
  intervalMonths Int?
  aircraftTypeId String
  statuses       AircraftMaintenanceStatus[]
  aircraftType   AircraftType                @relation(fields: [aircraftTypeId], references: [id])
}

model AircraftMaintenanceStatus {
  id                String                @id @default(cuid())
  aircraftId        String
  definitionId      String
  lastPerformedDate DateTime
  lastPerformedFH   Int
  lastPerformedFC   Int
  nextDueFH         Int?
  nextDueFC         Int?
  nextDueDate       DateTime?
  status            String                @default("OK")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  definition        MaintenanceDefinition @relation(fields: [definitionId], references: [id])
  aircraft          Aircraft              @relation(fields: [aircraftId], references: [id])

  @@unique([aircraftId, definitionId])
  @@index([aircraftId])
  @@index([status])
}

model TechLogEntry {
  id             String                      @id @default(cuid())
  aircraftId     String
  description    String
  date           DateTime                    @default(now())
  status         String                      @default("OPEN")
  workPackId     String?
  findingId      String?                     @unique
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  defect         Defect?
  deferral       Deferral?
  workPack       MaintenanceWorkPack?        @relation(fields: [workPackId], references: [id])
  aircraft       Aircraft                    @relation(fields: [aircraftId], references: [id])
  workOrderTasks WorkOrderTask[]
  aiReviews      camo_ai_compliance_review[]

  @@index([aircraftId])
  @@index([findingId])
  @@index([status])
}

model Deferral {
  id             String       @id @default(cuid())
  techLogEntryId String       @unique
  melEntryId     String
  deadline       DateTime
  status         String       @default("ACTIVE")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  melEntry       MELEntry     @relation(fields: [melEntryId], references: [id])
  techLogEntry   TechLogEntry @relation(fields: [techLogEntryId], references: [id])

  @@index([status])
}

// ─── CAMO AI Compliance Review (HITL) ────────────────────────────────────────
// Each record = one AI-generated compliance finding that requires human review.
// Linked to a source activity (TechLogEntry, MaintenanceWorkPack, etc.)
// Status: PENDING → ACCEPTED | REJECTED | FINDING_CREATED
model camo_ai_compliance_review {
  id String @id @default(cuid())

  // Source context
  sourceType     String // "DEFECT" | "WORKPACK" | "AD_STATUS" | "ARC"
  techLogEntryId String?
  workPackId     String?

  // Regulation reference (Part-CAMO article)
  regulationRef   String // e.g. "CAMO.A.315(c)" or "Part-M/A.304"
  regulationTitle String // Human-readable title

  // AI finding
  severity       String // "CRITICAL" | "WARNING" | "INFO"
  finding        String // What the AI found (could be non-compliant, missing info, etc.)
  recommendation String // What the AI recommends
  aiConfidence   Float  @default(0.8)
  aiModel        String @default("gemini")

  // HITL state
  status        String    @default("PENDING") // PENDING | ACCEPTED | REJECTED | FINDING_CREATED
  reviewedBy    String? // User ID
  reviewedAt    DateTime?
  reviewComment String?

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  techLogEntry TechLogEntry?        @relation(fields: [techLogEntryId], references: [id])
  workPack     MaintenanceWorkPack? @relation(fields: [workPackId], references: [id])

  @@index([status])
}

model MaintenanceWorkPack {
  id                 String                      @id @default(cuid())
  uId                String                      @unique
  aircraftId         String
  status             String                      @default("OPEN")
  revision           Int                         @default(0)
  scheduledDate      DateTime?
  description        String?                     @db.Text
  startDate          DateTime?
  endDate            DateTime?
  tsnAtHandover      Int?
  csnAtHandover      Int?
  engineDetails      String?
  apuDetails         String?
  ampReference       String?
  ammReference       String?
  mro                String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  crsReference       String?
  crsDate            DateTime?
  cameChecklistState String?
  aiAnalysisSummary  String?
  documents          Document[]
  aircraft           Aircraft                    @relation(fields: [aircraftId], references: [id])
  techLogEntries     TechLogEntry[]
  quoteItems         WorkOrderQuoteItem[]
  tasks              WorkOrderTask[]
  aiReviews          camo_ai_compliance_review[]
  partReplacements   PartReplacement[]

  @@index([aircraftId])
  @@index([status])
}

model WorkOrderTask {
  id              String              @id @default(cuid())
  workPackId      String
  title           String
  description     String?             @db.Text
  source          String              @default("MANUAL")
  status          String              @default("PENDING")
  sequenceNumber  Int                 @default(0)
  revisionAdded   Int                 @default(0)
  revisionRemoved Int?
  techLogEntryId  String?
  jobCardContent  String?
  workOrderId     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  workOrder       WorkOrder?          @relation(fields: [workOrderId], references: [id])
  techLogEntry    TechLogEntry?       @relation(fields: [techLogEntryId], references: [id])
  workPack        MaintenanceWorkPack @relation(fields: [workPackId], references: [id])

  @@index([status])
}

model Document {
  id                 String               @id @default(cuid())
  name               String
  type               String
  url                String
  verificationStatus String               @default("PENDING")
  extractedData      String?
  workPackId         String
  createdAt          DateTime             @default(now())
  workPack           MaintenanceWorkPack  @relation(fields: [workPackId], references: [id])
  quoteItems         WorkOrderQuoteItem[]
}

model Flight {
  id               String      @id @default(cuid())
  tripNumber       String      @unique
  bookingId        String?
  customerId       String?
  totalStatus      String      @default("DRAFT")
  customAttributes String      @default("{}")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  customer         User?       @relation("CustomerTrips", fields: [customerId], references: [id])
  booking          Booking?    @relation(fields: [bookingId], references: [id])
  legs             FlightLeg[]
}

model FlightLeg {
  id                     String           @id @default(cuid())
  flightId               String
  legSequence            Int              @default(1)
  flightNumber           String
  date                   DateTime
  aircraftId             String
  origin                 String
  destination            String
  status                 String           @default("SCHEDULED")
  paxCount               Int              @default(0)
  offBlockTime           DateTime?
  onBlockTime            DateTime?
  scheduledOffBlockTime  DateTime?
  scheduledOnBlockTime   DateTime?
  departureSlot          DateTime?
  arrivalSlot            DateTime?
  pprNumber              String?
  handlingStatus         String           @default("REQUESTED")
  offBlockActual         DateTime?
  takeOffActual          DateTime?
  landingActual          DateTime?
  onBlockActual          DateTime?
  fuelUplift             Float?
  fuelUnit               String           @default("LBS")
  fuelDensity            Float?
  delayCode              String?
  delayDuration          Int?
  briefingAcknowledgedAt DateTime?
  tripTypeId             String?
  dutyPeriodId           String?
  ftlExtensionMinutes    Int?
  ftlOverrideReason      String?
  ftlCommanderId         String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  customAttributes       String           @default("{}")
  crewDuties             CrewDuty[]
  costSheet              FlightCostSheet?
  dutyPeriod             DutyPeriod?      @relation(fields: [dutyPeriodId], references: [id])
  tripType               TripType?        @relation(fields: [tripTypeId], references: [id])
  aircraft               Aircraft         @relation(fields: [aircraftId], references: [id])
  flight                 Flight           @relation(fields: [flightId], references: [id])
  services               FlightService[]
  invoices               Invoice[]
  matchedQuotes          Quote[]
  serviceRequests        ServiceRequest[]
  smartNotams            SmartNotam[]
  briefings              FlightBriefing[]
  passengers             Passenger[]      @relation("FlightLegToPassenger")
  crew                   User[]           @relation("FlightLegToUser")

  // ── Performance indexes for compliance & dashboard queries ──────────────
  @@index([date, status]) // ReFuelEU year+status filter
  @@index([origin]) // Union-airport bucketing
  @@index([aircraftId, date]) // Fleet timeline queries
  @@index([flightId]) // Trip-to-leg lookups
  @@index([status])
}

model DutyPeriod {
  id        String      @id @default(cuid())
  userId    String
  startTime DateTime
  endTime   DateTime
  sectors   Int         @default(0)
  maxFDP    Int?
  extension Int?
  status    String      @default("PLANNED")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
  flights   FlightLeg[]

  @@index([userId])
  @@index([status])
}

model FlightService {
  id          String    @id @default(cuid())
  type        String
  vendor      String?
  status      String    @default("REQUESTED")
  details     String?
  flightLegId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  flightLeg   FlightLeg @relation(fields: [flightLegId], references: [id])

  @@index([flightLegId])
  @@index([status])
}

model ServiceRequest {
  id              String    @id @default(cuid())
  flightLegId     String
  type            String
