model CrewTraining {
  id         String    @id @default(cuid())
  crewId     String
  title      String
  type       String
  date       DateTime
  expiryDate DateTime?
  grade      String?
  instructor String?
  reportUrl  String?
  status     String    @default("PLANNED")

  // ── Document Attachments ───────────────────────────────
  fileUrl          String? // Primary document (PDF/image) via Hetzner Object Storage
  originalFileName String? // Original filename for display
  uploadedBy       String? // User ID who uploaded
  uploadedAt       DateTime? // When document was attached

  // ── AI Classification ─────────────────────────────────
  aiClassification String? // e.g. "OPC Training Report"
  aiConfidence     Float? // 0.0–1.0

  // ── Audit Trail ───────────────────────────────────────
  archivedAt     DateTime? // Never delete — soft archive
  archivedReason String? // Reason for archiving

  // ── Regulation Intelligence ────────────────────
  regulationRef  String? // e.g. "ORO.FC.220", "Part-FCL.510"
  reviewRequired Boolean @default(false) // ⚡ set true when linked regulation changes

  crew         CrewMember            @relation(fields: [crewId], references: [id])
  certificates TrainingCertificate[]

  @@index([crewId])
  @@index([status])
}

/// Internal training certificates issued by the organization (CRM, ESE, Line Check, Conversion, etc.)
model TrainingCertificate {
  id           String    @id @default(cuid())
  serialNumber String    @unique
  crewId       String
  trainingId   String?
  // Certificate type: CRM | ESE | CONVERSION | LINE_CHECK | TYPE_RATING | DANGEROUS_GOODS | EMERGENCY | CUSTOM
  certType     String
  title        String
  // Template variant: PORTRAIT_STANDARD | LANDSCAPE_PREMIUM
  template     String    @default("LANDSCAPE_PREMIUM")
  issuedDate   DateTime
  expiryDate   DateTime?
  issuedBy     String // Name of signing authority
  issuedByRole String? // e.g. "TRE · AOC-12345"
  trainerId    String? // Optional link to Trainer registry
  grade        String?
  hours        Float?
  location     String?
  aircraft     String? // e.g. "Airbus A320-200"
  remarks      String?
  signature    String? // SHA-256 hash for document integrity verification
  status       String    @default("VALID") // VALID | REVOKED | EXPIRED | ARCHIVED
  pdfUrl       String?

  // ── Document Upload & AI Classification (immutable audit trail) ──────────
  uploadedFileUrl  String? // Original scanned/uploaded document via Hetzner Object Storage
  originalFileName String? // e.g. "opc-certificate-bergmann-2026.pdf"
  uploadedBy       String? // User ID
  uploadedAt       DateTime? // Timestamp of upload
  aiClassification String? // AI-detected type: "OPC Certificate" | "Type Rating" | ...
  aiConfidence     Float? // Confidence score 0.0–1.0
  aiCrewMatch      String? // AI-matched crew member name (before confirmation)
  aiMatchConfirmed Boolean   @default(false) // User confirmed AI assignment

  // ── Audit Trail ─────────────────────────────────────────────────────────
  // Records are NEVER deleted. Superseded when a newer version is uploaded.
  supersededById String? // FK to newer certificate that replaced this one
  supersededAt   DateTime? // When this was superseded
  archivedAt     DateTime? // Manual archive (≠ delete)
  archivedBy     String? // User ID who archived
  archivedReason String? // Reason

  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  crew         CrewMember              @relation(fields: [crewId], references: [id])
  training     CrewTraining?           @relation(fields: [trainingId], references: [id])
  templateId   String?
  certTemplate CertificateTemplate?    @relation(fields: [templateId], references: [id])
  trainer      Trainer?                @relation(fields: [trainerId], references: [id])
  itemResults  CertificateItemResult[]

  @@index([crewId])
  @@index([status])
}

/// Reusable certificate templates – define once, issue many times
model CertificateTemplate {
  id                  String                    @id @default(cuid())
  name                String // Template name, e.g. "OPC Airbus A320"
  templateKey         String?                   @unique // Short identifier e.g. "CRM-INIT", "OPC-A320"
  certType            String // CRM | OPC | LPC | ESE | CONVERSION | LINE_CHECK | TYPE_RATING | DG | EMERGENCY | CUSTOM
  title               String // Default title printed on the certificate
  description         String?                   @db.Text // Introductory text / preamble on the PDF
  easaRefs            String? // Comma-separated regulation references
  defaultValidity     Int? // Default validity in months
  defaultIssuedBy     String?
  defaultIssuedByRole String?
  defaultLocation     String?
  defaultHours        Float?
  defaultAircraft     String?
  isActive            Boolean                   @default(true)
  // Manual linking — soft references (no CASCADE, manuals may live in different models)
  linkedManualId      String? // ref to Manual.id (OM-A system)
  linkedDocManualId   String? // ref to doc_manuals.id (CAME/OMM system)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  items               CertificateTemplateItem[]
  certificates        TrainingCertificate[]
}

/// Individual task / competency item within a certificate template
/// e.g. "EFATO", "ILS Approach Cat I", "Emergency Descent", "CRM Communication"
model CertificateTemplateItem {
  id          String                  @id @default(cuid())
  templateId  String
  category    String? // Grouping header, e.g. "Normal Procedures" / "Emergency Procedures"
  name        String // Task name shown on the certificate
  description String?                 @db.Text // Optional detail / requirement text
  gradingType String                  @default("PASS_FAIL")
  // PASS_FAIL | NUMERIC_1_4 | SATISFACTORY | YES_NO | TEXT
  required    Boolean                 @default(true)
  order       Int                     @default(0)
  template    CertificateTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results     CertificateItemResult[]
}

/// The actual graded result for one task item on a specific issued certificate
model CertificateItemResult {
  id          String                  @id @default(cuid())
  certId      String
  itemId      String
  grade       String? // "PASS" | "FAIL" | "1" | "2" | "3" | "4" | "S" | "U" | "YES" | "NO" | custom text
  remark      String? // Examiner's note for this item
  certificate TrainingCertificate     @relation(fields: [certId], references: [id], onDelete: Cascade)
  item        CertificateTemplateItem @relation(fields: [itemId], references: [id])
}

/// Registered trainers with their qualifications — used to filter issuer field when issuing certificates
model Trainer {
  id            String                @id @default(cuid())
  name          String
  title         String? // e.g. "TRE", "TRI", "SFI", "CRM Facilitator"
  licenseNumber String? // e.g. "LBA-TRE-12345"
  qualifiedFor  String // Comma-separated cert types: "CRM,OPC,LPC" — used for filtering
  licenseExpiry String? // ISO date string
  organization  String? // External training org or internal
  phone         String?
  email         String?
  notes         String?               @db.Text
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  certificates  TrainingCertificate[]
  assignments   TrainingAssignment[]
}

// ─── Training Program (Programm-Template, konfiguriert vom Admin / NPFO / NPCT / CMM) ──
/// e.g. "Initial Line Training A320", "OPC alle 6 Monate", "LPC jährlich"
model TrainingProgram {
  id             String               @id @default(cuid())
  orgId          String? // Tenant-scoping
  name           String // "Initial Line Training – PC-12"
  type           String // OPC | LPC | LINE_CHECK | LINE_TRAINING | CRM | CUSTOM
  description    String?              @db.Text
  // Regulatory reference e.g. ORO.FC.230
  easaRef        String?
  // How many line legs are required for this program?
  requiredLegs   Int                  @default(0)
  // Minimum flight hours
  requiredHours  Float                @default(0)
  // Validity period after completion (months)
  validityMonths Int                  @default(12)
  // Which forms must be filled per-leg / per-session?
  // Stored as JSON array: ["LINE_CHECK","DEBRIEF"] etc.
  requiredForms  String?
  // Is this program active (visible for assignment)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  assignments    TrainingAssignment[]
}

// ─── Training Assignment (Zuweisung an einen Piloten durch NPFO/NPCT/CMM) ───
/// When a manager says "Pilot ABC needs an LPC" — this record is created.
model TrainingAssignment {
  id                String    @id @default(cuid())
  orgId             String?
  // Which program was assigned
  programId         String
  // Which pilot
  crewId            String
  // Who assigned it (NPFO / NPCT / CMM)
  assignedByUserId  String?
  // Assigned trainer / line checker for the final check
  assignedTrainerId String?
  // Per-day / per-leg notes from line trainer
  trainerNotes      String?   @db.Text
  // Status workflow
  // PENDING → IN_PROGRESS → AWAITING_FINAL_CHECK → COMPLETED | FAILED
  status            String    @default("PENDING")
  // Target completion date
  targetDate        DateTime?
  // Actual completion date
  completedAt       DateTime?
  // Pass/Fail of the overall assignment
  result            String? // PASS | FAIL | INCOMPLETE
  // Overall grade comment
  finalRemarks      String?   @db.Text
  // AI-generated progress summary
  aiSummary         String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  program TrainingProgram         @relation(fields: [programId], references: [id])
  crew    CrewMember              @relation(fields: [crewId], references: [id])
  legs    TrainingAssignmentLeg[]
  trainer Trainer?                @relation(fields: [assignedTrainerId], references: [id])

  @@index([crewId])
  @@index([programId])
  @@index([status])
}

// ─── Training Assignment Leg (einzelne Leg-Einträge pro Zuweisung) ───────────
/// Each line training leg gets its own record (can be linked to Leon FlightLeg later)
model TrainingAssignmentLeg {
  id              String   @id @default(cuid())
  assignmentId    String
  // Sequence number: Leg 1, 2, 3 …
  legNumber       Int
  // Date of the leg
  date            DateTime
  // From / To
  depIcao         String?
  arrIcao         String?
  // Aircraft registration
  aircraft        String?
  // Leon flight leg ID for future sync
  leonFlightLegId String?
  // Duration in minutes
  durationMinutes Int?
  // Type of sortie: LINE_CHECK | OPC_CHECK | DEBRIEF | OBSERVATION | FINAL_CHECK
  legType         String   @default("LINE_CHECK")
  // Structured form data (JSON: Line Check results, OPC grades etc.)
  formData        String?  @db.Text
  // Trainer who flew / checked this leg
  checkerName     String?
  // Overall result for this leg
  result          String? // PASS | FAIL | SATISFACTORY | INCOMPLETE
  remarks         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

