// ---------------------------------------------------------
// MODULES 9 & 10: MANUAL AMENDMENTS & AUTHORITY APPROVALS
// ---------------------------------------------------------

// ─── GOOGLE ANTIGRAVITY DMS (XML-BASED) ──────────────────────────────────────────────────

model doc_manuals {
  id                         String    @id @default(uuid())
  orgId                      String    @default("") // tenant isolation
  manual_code                String // e.g., "OM-A", "CAME" — unique per org (see @@unique below)
  title                      String
  current_revision           String // e.g., "Rev 14.2"
  current_effective_date_utc DateTime?
  regulatory_framework       String?
  status                     String    @default("Active") // Active, Drafting, Pending Approval
  master_template_id         String?
  compliance_status          String    @default("UP_TO_DATE")
  equipment_profile          String? // JSON array

  // Approval Settings
  approval_signatories   String    @default("[\"Accountable Manager\", \"Compliance Manager\"]") // JSON array
  approval_text_template String?
  last_approved_at_utc   DateTime?

  // Revision Workflow Fields
  draft_revision_highlights String? // Mandatory free-text summary of what changed in this revision cycle
  approval_sheet_url        String?
  cover_page_custom_text    String? // URL of the signed authority approval sheet (LBA/EASA)

  // Additional Configuration
  numbering_begins_at   String  @default("0")
  changebar_setting     String  @default("per article")
  read_tracking_enabled Boolean @default(true)
  footer_certificates   String? // JSON array of certificate IDs selected for the footer
  departments_targeted  String  @default("[]") // JSON string[] — which departments must read & sign (e.g. ["flight_ops","maintenance"])

  chapters           doc_chapters[]
  nodes              doc_nodes[]
  amendments         mod9_10_amendments[]
  read_receipts      doc_read_receipts[]      @relation("ManualReadReceipts")
  tasks              doc_tasks[]
  linked_regulations doc_linked_regulations[]

  auditResponses sqms_AuditResponse[] @relation("AuditResponseDocManual")
  ampSourceDocs  AmpSourceDoc[]
  ampTasks       AmpTask[]

  // ── Performance indexes ────────────────────────────────────────────────────
  @@unique([orgId, manual_code]) // One code per tenant (e.g. each airline has its own OMM)
  @@index([manual_code]) // Manual lookup by code
  @@index([orgId])
  @@index([orgId, status])
}

model doc_company_profiles {
  id              String   @id @default(uuid())
  name            String
  flight_ops_type String // e.g. "Part-CAT"
  equipment       String // JSON array e.g. ["A320", "B737"]
  created_at      DateTime @default(now())
}

model doc_global_variables {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  variable_type String   @default("TEXT") // TEXT, LIST, REFERENCE
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model doc_read_receipts {
  id               String    @id @default(uuid())
  manual_id        String
  user_id          String
  revision         String
  read_at_utc      DateTime?
  signature_hash   String?
  // ── Policy / NP enforcement ───────────────────────────────────────────────
  require_signature Boolean  @default(false)  // ACM / SM / NP must sign, not just read
  signed_at         DateTime?                  // Timestamp of formal signature
  source_type       String   @default("MANUAL") // MANUAL | POLICY | ERP
  source_policy_id  String?                   // FK hint — sms_safety_policy.id when source_type=POLICY
  created_at        DateTime @default(now())

  manual doc_manuals @relation("ManualReadReceipts", fields: [manual_id], references: [id], onDelete: Cascade)
  user   User        @relation("UserReadReceipts", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([source_type])
  @@index([require_signature])
}

model doc_chapters {
  id             String  @id @default(uuid())
  manual_id      String
  parent_id      String?
  chapter_number String // Dynamically computed, e.g. "8.1.1"
  title          String
  sort_order     Int     @default(0)
  locked_by      String? // Check-out Prinzip (user_id)

  // Commit workflow
  commit_description String?   @db.Text // Short description of what changed in this chapter this revision
  committed_at       DateTime? // When was it committed/marked ready
  current_revision   String? // The specific revision/version of this chapter

  manual   doc_manuals    @relation(fields: [manual_id], references: [id], onDelete: Cascade)
  parent   doc_chapters?  @relation("ChapterHierarchy", fields: [parent_id], references: [id], onDelete: Restrict)
  children doc_chapters[] @relation("ChapterHierarchy")

  nodes doc_nodes[]

  source_deps doc_dependencies[] @relation("SourceDeps")
  target_deps doc_dependencies[] @relation("TargetDeps")

  tasks              doc_tasks[]
  linked_regulations doc_linked_regulations[]

  auditResponses sqms_AuditResponse[] @relation("AuditResponseChapter")

  // ── Regulation Intelligence ────────────────────
  regulationRef  String? // Primary applicable EASA requirement ref
  reviewRequired Boolean @default(false) // ⚡ set true when linked regulation changes
}

model doc_nodes {
  id               String   @id @default(uuid())
  manual_id        String
  chapter_id       String
  node_type        String // 'HEADING', 'PARAGRAPH', 'TABLE', 'SVG_ASSET', 'CAUTION'
  content          String?  @db.Text // The JSON/HTML block
  order_index      Int      @default(0)
  status           String   @default("ACTIVE") // DRAFT, ACTIVE, ARCHIVED
  archive_revision String? // Stores the version number explicitly when archived (e.g. "V1.0")
  updated_at       DateTime @updatedAt

  manual  doc_manuals  @relation(fields: [manual_id], references: [id], onDelete: Cascade)
  chapter doc_chapters @relation(fields: [chapter_id], references: [id], onDelete: Cascade)

  revisions doc_revision_deltas[]

  tasks              doc_tasks[]
  linked_regulations doc_linked_regulations[]

  @@index([status])
}

model doc_revision_deltas {
  id               String   @id @default(uuid())
  node_id          String
  action           String // 'CREATED', 'UPDATED', 'DELETED'
  previous_content String?  @db.Text
  new_content      String?  @db.Text
  author_name      String?  @default("System")
  created_at       DateTime @default(now())

  node doc_nodes @relation(fields: [node_id], references: [id], onDelete: Cascade)
}

model doc_dependencies {
  id                String  @id @default(uuid())
  source_chapter_id String
  target_chapter_id String
  requires_review   Boolean @default(false)

  source_chapter doc_chapters @relation("SourceDeps", fields: [source_chapter_id], references: [id], onDelete: Cascade)
  target_chapter doc_chapters @relation("TargetDeps", fields: [target_chapter_id], references: [id], onDelete: Cascade)
}

model doc_tasks {
  id          String    @id @default(uuid())
  manual_id   String
  chapter_id  String?
  node_id     String?
  assignee_id String
  assigner_id String
  message     String
  due_date    DateTime? // Fälligkeitsdatum
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  status      String    @default("OPEN") // OPEN | IN_PROGRESS | DONE | CANCELLED
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  manual   doc_manuals   @relation(fields: [manual_id], references: [id], onDelete: Cascade)
  chapter  doc_chapters? @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  node     doc_nodes?    @relation(fields: [node_id], references: [id], onDelete: Cascade)
  assignee User          @relation("AssignedDocTasks", fields: [assignee_id], references: [id])
  assigner User          @relation("CreatedDocTasks", fields: [assigner_id], references: [id])

  @@index([status])
}

model doc_linked_regulations {
  id         String   @id @default(uuid())
  manual_id  String
  chapter_id String?
  node_id    String?
  part       String
  reference  String
  amendment  String?
  status     String   @default("VALID") // VALID, CHANGED_NEEDS_REVIEW
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  manual  doc_manuals   @relation(fields: [manual_id], references: [id], onDelete: Cascade)
  chapter doc_chapters? @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  node    doc_nodes?    @relation(fields: [node_id], references: [id], onDelete: Cascade)

  @@index([status])
}

model sys_ai_veto_log {
  id               String   @id @default(uuid())
  user_id          String
  action_context   String
  original_ai_text String?
  vetoed_at_utc    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

// ─── OMEGA DIRECTIVE: MODULE 1 & ERM ADMIN ────────────────────────────────────

model sys_risk_dimensions {
  id         String             @id @default(uuid())
  name       String
  icon_emoji String
  is_active  Boolean            @default(true)
  scores     mod2_risk_scores[]
}

model mod1_occurrences {
  id                   String    @id @default(uuid())
  orgId                String    @default("") // tenant isolation
  occurrence_number    String
  identification_type  String    @default("Reactive_Occurrence") // Enum: Reactive_Occurrence, Proactive_Identification
  event_datetime_utc   DateTime?
  reporter_user_id     String?
  is_anonymous         Boolean
  location_icao        String
  flight_phase         String
  description_raw      String
  ai_adrep_category    String?
  final_adrep_category String?

  // ── EASA Occurrence Classification (EU 376/2014 + IR 2015/1018) ──────────────
  // Mandatory field set during Triage — drives LBA/ECCAIRS reporting obligation
  // Values: ACCIDENT | SERIOUS_INCIDENT | INCIDENT | OCCURRENCE | PROACTIVE
  easa_occurrence_type String? // Set by Safety Manager during triage

  // ── Triage Review Tracking ───────────────────────────────────────────────────
  reviewed_by_user_id    String? // Who triaged this report
  reviewed_at_utc        DateTime? // When triage was completed
  // rejection_reason: Used when status = Reviewed_No_Action
  // Values: DUPLICATE | OUTSIDE_SMS_SCOPE | INSUFFICIENT_INFO | ALREADY_KNOWN_HAZARD | OTHER
  rejection_reason       String?
  rejection_notes        String?   @db.Text // Free text explanation (Just Culture feedback)
  reporter_feedback_sent Boolean   @default(false) // Track if feedback was sent to reporter

  status String
  // Valid statuses:
  // Pending_Triage         → freshly submitted, in Inbox
  // Active_Hazard          → validated, requires risk assessment (→ Hazard Log)
  // Reviewed_No_Action     → reviewed but no escalation needed (was: "Rejected")
  // IN MITIGATION          → risk assessment done, CAP tasks running
  // Mitigation_Active      → synonym for IN MITIGATION (legacy)
  // NEW                    → proactive hazard, immediately in Hazard Log
  // Closed                 → all CAP tasks closed, risk accepted
  // Rejected               → legacy, replaced by Reviewed_No_Action

  riskScore              Int?
  riskLevel              String?
  // SMS Hazard Log Fields (SM010)
  source_reference       String? // Link to origin report/audit
  potential_consequences String? // What can happen in worst case?
  risk_impact_category   String? // From sys_data_dictionaries
  initial_likelihood     Int? // 1 to 5
  initial_severity       Int? // 1 to 5
  initial_risk_score     Int? // L x S
  mitigation_measures    String? // Action plan to reduce risk
  responsible_person_id  String? // User who owns the mitigation
  residual_likelihood    Int? // 1 to 5
  residual_severity      Int? // 1 to 5
  residual_risk_score    Int? // Computed L x S
  inherent_risk_details  String?
  residual_risk_details  String?
  closure_verification   String? // Proof of effectiveness
  hazard_metadata        String? // JSON for tasks, evidences, etc.
  due_date               DateTime? // Escalation trigger

  department String @default("ALL") // AOC, CAMO, Part-IS, ALL

  responsible_person User? @relation("MitigationOwner", fields: [responsible_person_id], references: [id])

  reporter   User?     @relation("ReportedHazards", fields: [reporter_user_id], references: [id])
  aircraftId String?
  aircraft   Aircraft? @relation("AircraftHazards", fields: [aircraftId], references: [id])

  evidence          mod1_evidence[]
  sqms_evidence     sqms_Evidence[]          @relation("OccurrenceEvidence")
  assessments       mod2_risk_assessments[]
  authority_reports mod5_authority_reports[]
  investigations    mod4_investigations[]

  // ── Regulatory Intelligence ──────────────────────────────────────────────────
  regulationRef  String? // EASA article this report relates to (e.g. ORO.GEN.200, ARO.RAMP)
  reviewRequired Boolean @default(false) // ⚡ set true when linked regulation changes

  bowtie_diagrams sms_bowtie_diagram[]

  @@index([orgId])
  @@index([aircraftId])
  @@index([orgId, status])
}

model mod1_evidence {
  id            String @id @default(uuid())
  occurrence_id String

  file_url   String
  occurrence mod1_occurrences @relation(fields: [occurrence_id], references: [id])

  // ── Performance index ────────────────────────────────────────────────────
  @@index([occurrence_id]) // Evidence lookup by occurrence
}

// ─── OMEGA DIRECTIVE: MODULE 2 & MODULE 4 ──────────────────────────────────────

model mod2_risk_assessments {
  id                  String                   @id @default(uuid())
  occurrence_id       String
  assessed_by_user_id String
  assessed_at_utc     DateTime                 @default(now())
  status              String // Enum: Draft, Mitigation_Active, Closed_Acceptable
