  ai_summary           String?
  ai_impact_detected   Boolean  @default(false)
  is_applicable        Boolean
  engineering_remarks  String
  evaluated_by_user_id String
  evaluated_at_utc     DateTime @default(now())

  evaluator User @relation("EvaluatedTechPubs", fields: [evaluated_by_user_id], references: [id])
}

model camo_ad_status_list {
  id              String    @id @default(uuid())
  aircraftId      String?
  ad_reference    String
  subject         String
  applicability   String
  // Status: COMPLIANT | OVERDUE | PENDING | NOT_APPLICABLE | Draft | Open | Closed | Superseded
  status          String    @default("PENDING")
  due_date        DateTime?
  compliance_date DateTime?
  next_due_date   DateTime?
  recurring       Boolean   @default(false)
  source_eval_id  String?
  aircraft        Aircraft? @relation(fields: [aircraftId], references: [id])

  @@index([aircraftId])
  @@index([status])
}

// ─── ADMIN REGISTERS ──────────────────────────────────────────────

// ─── SMS SAFETY POLICY — IS-BAO 4.1 / EASA ORO.GEN.200 ──────────────────────
// Stores the current (and all historical) versions of the corporate Safety Policy.
// Each revision requires Accountable Manager signature before becoming ACTIVE.
// A company can only have ONE ACTIVE policy at a time.

model sms_safety_policy {
  id                    String    @id @default(uuid())
  revision              String    // e.g. "Rev 3.0"
  effective_date_utc    DateTime
  status                String    @default("Draft")
  // DRAFT → PENDING_SIGNATURE → ACTIVE → SUPERSEDED

  // Policy content — structured fields
  scope_text            String    @db.Text
  commitment_text       String    @db.Text
  objectives_text       String?   @db.Text
  just_culture_text     String?   @db.Text
  reporting_commitment  String?   @db.Text
  resource_commitment   String?   @db.Text

  // Signatories
  accountable_manager_name   String?
  accountable_manager_signed Boolean   @default(false)
  accountable_manager_at     DateTime?
  safety_manager_name        String?
  safety_manager_signed      Boolean   @default(false)
  safety_manager_at          DateTime?

  // Audit trail
  created_by_id         String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt
  superseded_at         DateTime?
  superseded_by_id      String?   // FK to the new policy revision that replaced this

  // Distribution tracking
  distributed_to_all    Boolean   @default(false)
  distributed_at        DateTime?

  created_by User? @relation("PolicyCreator", fields: [created_by_id], references: [id])

  @@index([status])
}

// ─── SMS SAFETY OBJECTIVES — IS-BAO 4.2 / EASA ORO.GEN.200(a)(2) ─────────────
// SMART safety objectives with measurable targets, SPI linkage, AM approval
// and a full review log for audit trail purposes.

model sms_safety_objective {
  id                String   @id @default(uuid())

  title             String
  description       String   @db.Text
  category          String   // OCCURRENCE | REPORTING | TRAINING | AUDIT | CULTURE | OPERATIONAL | REGULATORY

  // SMART target
  target_value      Float
  current_value     Float    @default(0)
  unit              String   // e.g. "per 1000 hrs", "%", "count", "days"
  is_lower_better   Boolean  @default(true)

  // Timeline
  target_date       DateTime
  review_frequency  String   @default("QUARTERLY") // MONTHLY | QUARTERLY | ANNUAL

  // Status lifecycle
  status            String   @default("DRAFT")
  // DRAFT → ACTIVE → ON_TRACK | AT_RISK | BREACHED | ACHIEVED → CLOSED

  // Ownership & approval
  owner_name        String?
  approved_by_name  String?
  approved_at       DateTime?

  // Optional link to an SPI for auto-tracking
  linked_spi_id     String?

  // Review history — JSON array of { date, reviewer, notes, value_at_review, status_at_review }
  review_log        String   @default("[]") @db.Text

  created_by_id     String?
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  created_by User? @relation("ObjectiveCreator", fields: [created_by_id], references: [id])

  @@index([status])
  @@index([category])
}

// ─── JUST CULTURE POLICY — IS-BAO Stage 2 / EASA ORO.GEN.200(a) ─────────────
// Stores the signed Just Culture Policy with behavior classification matrix.
// Staff read-and-sign receipts are tracked for IS-BAO audit evidence.

model sms_just_culture_policy {
  id                    String    @id @default(uuid())
  revision              String    // e.g. "Rev 1.0"
  effective_date_utc    DateTime
  status                String    @default("DRAFT")
  // DRAFT → PENDING_SIGNATURE → ACTIVE → SUPERSEDED

  // Core content sections
  definition_text       String    @db.Text   // What Just Culture means at this org
  behavior_matrix_json  String    @default("{}") @db.Text
  // JSON: { error: {label, desc, consequence}, atRisk: {...}, reckless: {...} }
  non_punitive_text     String    @db.Text   // Non-punitive reporting commitment
  confidentiality_text  String?   @db.Text   // Confidentiality of reports
  investigation_text    String?   @db.Text   // Investigation principles
  accountability_text   String?   @db.Text   // Where accountability still applies

  // Signatory (AM only required for Just Culture per IS-BAO Stage 2)
  accountable_manager_name   String?
  accountable_manager_signed Boolean   @default(false)
  accountable_manager_at     DateTime?

  // Audit trail
  created_by_id    String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
  superseded_at    DateTime?
  superseded_by_id String?

  created_by    User?                            @relation("JCPolicyCreator", fields: [created_by_id], references: [id])
  read_receipts sms_just_culture_read_receipt[]

  @@index([status])
}

// Read-and-sign receipt — one row per user per policy revision
model sms_just_culture_read_receipt {
  id        String   @id @default(uuid())
  policy_id String
  user_id   String
  user_name String?
  signed_at DateTime @default(now())

  policy sms_just_culture_policy @relation(fields: [policy_id], references: [id], onDelete: Cascade)

  @@unique([policy_id, user_id])
  @@index([policy_id])
}

// ─── BOWTIE MODELER — IS-BAO Stage 3 / EASA SMS ──────────────────────────────
// Visual Bowtie Risk Model: Threats → [Controls] → TOP EVENT → [Controls] → Consequences
// threats_json / consequences_json store arrays of {id, description, category, owner, controls:[]}
// Controls have: {id, description, effectiveness, status, owner}
// Enabled by sys_global_settings.enable_bowtie_modeler = true

model sms_bowtie_diagram {
  id                    String    @id @default(uuid())
  title                 String
  hazard_description    String    @db.Text
  top_event             String    // e.g. "Loss of control of aircraft"
  hazard_category       String    @default("OPERATIONAL")
  // OPERATIONAL | HUMAN_FACTORS | ENVIRONMENTAL | TECHNICAL | ORGANISATIONAL

  linked_occurrence_id  String?   // Optional FK to mod1_occurrences

  // Left side: Threats → Preventive Controls
  threats_json          String    @default("[]") @db.Text
  // [{id, description, category, owner, controls: [{id, desc, effectiveness, status, owner}]}]

  // Right side: Recovery Controls → Consequences
  consequences_json     String    @default("[]") @db.Text
  // [{id, description, severity, owner, controls: [{id, desc, effectiveness, status, owner}]}]

  status                String    @default("ACTIVE") // ACTIVE | REVIEW | ARCHIVED

  created_by_id         String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  created_by        User?             @relation("BowtieDiagramCreator", fields: [created_by_id], references: [id])
  linked_occurrence mod1_occurrences? @relation(fields: [linked_occurrence_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([linked_occurrence_id])
}

// ─── ERP EXERCISE LOG — IS-BAO 3.6 ──────────────────────────────────────────
// Tracks annual ERP tests and exercises as required by IS-BAO 3.6.
// The ERP plan itself is stored in sys_global_settings (erp_*_json fields).

model sms_erp_exercise_log {
  id             String   @id @default(uuid())
  exercise_date  DateTime
  exercise_type  String   // TABLETOP | FULL_SCALE | PARTIAL | NOTIFICATION_ONLY
  emergency_type String   // Matches a type from sys_global_settings.erp_emergency_types_json

  scenario       String   @db.Text       // Exercise scenario description
  participants   String   @default("[]") @db.Text // JSON: [{name, role}]

  outcome        String   @default("SATISFACTORY")
  // SATISFACTORY | NEEDS_IMPROVEMENT | UNSATISFACTORY

  findings       String?  @db.Text  // What was observed
  improvements   String?  @db.Text  // Actions arising from exercise

  conducted_by   String?  // Name of exercise director
  approved_by    String?  // Name of approver (SM or AM)

  created_by_id  String?
  created_at     DateTime @default(now())

  created_by User? @relation("ERPExerciseCreator", fields: [created_by_id], references: [id])

  @@index([exercise_date])
}

// ── ERP Revision History ───────────────────────────────────────────────────────
model sms_erp_revision {
  id                   String    @id @default(uuid())

  revision_number      String    // e.g. "2026.1", "2026.2"
  status               String    @default("ACTIVE") // ACTIVE | SUPERSEDED

  // Full snapshots of the ERP at this revision
  emergency_types_json String    @db.Text
  roles_json           String    @db.Text
  checklist_json       String    @db.Text
  contacts_json        String    @db.Text

  // Change metadata
  change_notes         String    @db.Text  // Required reason for change
  effective_date       DateTime  @default(now())

  // Supersession chain
  superseded_at        DateTime?
  superseded_by_id     String?   // ID of the revision that replaced this one

  // Authorship
  changed_by_id        String?
  changed_at           DateTime  @default(now())

  changed_by User? @relation("ERPRevisionAuthor", fields: [changed_by_id], references: [id])

  @@index([status])
  @@index([changed_at])
}

// ── ERP Live Activation / Crisis Console ─────────────────────────────────────
model sms_erp_activation {
  id                     String    @id @default(uuid())

  emergency_type_id      String    // matches type id from ERP settings
  emergency_type_label   String    // denormalized for display
  description            String    @db.Text

  status                 String    @default("ACTIVE") // ACTIVE | RESOLVED | CANCELLED
  activated_at           DateTime  @default(now())
  resolved_at            DateTime?
  resolution_notes       String?   @db.Text

  // Live checklist: JSON [{id, phase, item, checked_by, checked_at}]
  checklist_progress_json String   @default("[]") @db.Text

  // Running notes log: JSON [{timestamp, author, note}]
  notes_log_json         String    @default("[]") @db.Text

  // ERP revision that was active at time of activation
  erp_revision_number    String?

  // Optional link to an occurrence
  linked_occurrence_id   String?

  activated_by_id        String?
  resolved_by_id         String?

  activated_by User? @relation("ERPActivationCreator", fields: [activated_by_id], references: [id])
  resolved_by  User? @relation("ERPActivationResolver", fields: [resolved_by_id], references: [id])

  @@index([status])
  @@index([activated_at])
}

model sys_record_retention_log {
  id                   String  @id @default(uuid())
  record_type          String
  department           String
  retention_period_yrs Int
  storage_location     String
  is_active            Boolean @default(true)
}

// sys_nominated_persons table removed — NP data lives in orgPost (managed via /organisation).
// Canonical lookup: getKeyPersonnel() in src/app/actions/nominatedPersonsActions.ts

// ---------------------------------------------------------
// MODULES 9 & 10: MANUAL AMENDMENTS & AUTHORITY APPROVALS
// ---------------------------------------------------------

model mod9_10_amendments {
  id                      String  @id @default(uuid())
  manual_id               String
  source_moc_id           String? // Nullable
  proposed_revision       String
  change_classification   String // Enum: Pending_Triage, Minor_Notification_Mod9, Major_PriorApproval_Mod10
  ai_summary_of_changes   String? // Longtext
  lba_approval_file_url   String?
  final_pdf_url           String? // Immutable generated PDF for this revision
  final_pdf_url_delta     String? // Immutable generated Delta PDF
