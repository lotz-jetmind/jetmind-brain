model mod3_moc_hazards {
  id     String @id @default(uuid())
  moc_id String

  // Hazard context
  state              String // TRANSITION | FUTURE
  area               String // Human_Factors | Interfaces | Documentation | Qualification | Resources | IT_Systems | Continuity | Certification | Other
  hazard_description String

  // Initial risk (before mitigation)
  likelihood_initial Int    @default(3) // 1-5
  severity_initial   String @default("C") // A=Catastrophic B=Hazardous C=Major D=Minor E=Negligible
  risk_score_initial Int    @default(9) // 1-25

  // Mitigation
  mitigation_description String?
  mitigation_owner       String? // User ID or name
  mitigation_due_date    DateTime?

  // Residual risk (after mitigation)
  likelihood_residual Int?
  severity_residual   String?
  risk_score_residual Int?

  // ALARP
  alarp_justification String?
  status              String  @default("Open") // Open | Mitigated | Accepted

