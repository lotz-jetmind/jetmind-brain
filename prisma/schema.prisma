// ── Regulatory Intelligence Monitor ─────────────────────────────────────────
// Watches external websites and APIs for new ADs, SBs, LTAs, AADs, regulations.
// EASA Part-CAMO.A.205 — continuing airworthiness information obligations.

model WebMonitor {
  id          String  @id @default(cuid())
  name        String // "EASA ADs — Citation XLS+"
  description String?
  category    String // "AD" | "SB" | "LTA" | "AAD" | "SIB" | "CAA" | "RULE" | "FUEL" | "CUSTOM"
  targetUrl   String // URL to fetch / API endpoint
  fetchType   String  @default("page_hash") // "rss" | "json_api" | "html_selector" | "page_hash" | "easa_ad_api"

  // ── Content extraction ────────────────────────────────────────────────
  htmlSelector   String? // CSS-like pattern to find items
  jsonPath       String? // JSONPath for API responses (e.g. "$.data[*]")
  pdfLinkPattern String? // regex to find PDF download links

  // ── Filtering ─────────────────────────────────────────────────────────
  searchKeywords  String? // JSON: string[] — only alert if these words appear
  aircraftFilters String? // JSON: string[] — e.g. ["C525","C560"] for EASA AD API
  excludeKeywords String? // JSON: string[] — ignore items with these words

  // ── Scheduling ────────────────────────────────────────────────────────
  scheduleExpr String  @default("0 6 * * *") // cron expression
  isActive     Boolean @default(true)

  // ── Notification ──────────────────────────────────────────────────────
  notifyEmail    String? // override; falls back to org admin email
  notifyOnChange Boolean @default(true) // email when new items found
  downloadPdf    Boolean @default(true) // auto-download PDFs to S3

  // ── State ─────────────────────────────────────────────────────────────
  lastCheckedAt   DateTime?
  lastChangeAt    DateTime?
  lastContentHash String? // SHA-256 of last full page content
  lastResultCount Int? // items seen in last run

  results WebMonitorResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model WebMonitorResult {
  id        String     @id @default(cuid())
  monitorId String
  monitor   WebMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  // ── Item metadata ─────────────────────────────────────────────────────
  externalId  String? // e.g. EASA AD number "2026-0042"
  title       String
  sourceUrl   String? // direct link to item page
  publishedAt String? // extracted date string
  summary     String? @db.Text // extracted description
  contentHash String // SHA-256 of this specific item — for dedupe

  // ── PDF ───────────────────────────────────────────────────────────────
  pdfSourceUrl    String? // original PDF URL found in source
  storedPdfKey    String? // S3 key after successful download
  pdfFileName     String?
  pdfDownloadedAt DateTime?

  // ── Workflow ──────────────────────────────────────────────────────────
  isNew          Boolean   @default(true) // false once acknowledged
  acknowledgedAt DateTime?
  acknowledgedBy String? // User ID
  notifiedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([monitorId])
  @@index([isNew])
  @@index([contentHash])
}

model Quote {
  id          String  @id @default(cuid())
  quoteNumber String  @unique
  customerId  String
  requestId   String?
  status      String  @default("DRAFT")
  // DRAFT → SENT → OPTION → BOOKED → INVOICED / CANCELLED / DECLINED / EXPIRED

  route              String
  startDate          DateTime
  endDate            DateTime
  pax                Int
  aircraftType       String
  aircraftId         String? // own fleet
  externalAircraftId String? // third-party registry
  matchedEmptyLegId  String?
  totalFlightTime    Int?
  aiSuggestedMargin  Float?
  price              Float
  currency           String   @default("EUR")
  margin             Float?
  customAttributes   String   @default("{}")

  // ── Leg Detail (JSON: TripCostResult) ───────────────────────
  legDataJson String? // full TripCostResult from engine

  // ── Positioning ───────────────────────────────────
  lastKnownPosition String? // ICAO of last known position
  ferryFromIcao     String? // ferry origin if repositioning needed
  ferryDistanceNm   Int?
  ferryCostEur      Float?
  positioningNotes  String? // AI-generated positioning recommendation

  // ── Passenger Taxes ──────────────────────────────
  passengerTaxJson  String? // JSON: PassengerTaxResult[]
  passengerTaxTotal Float?  @default(0)

  // ── Option / Booking ──────────────────────────────
  optionExpiresAt DateTime?
  bookedAt        DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  declinedAt      DateTime?
  declineReason   String?

  // ── Invoice Link ──────────────────────────────────
  charterInvoiceId String? // set when INVOICED

  // ── Pricing Profile Override (SPECIAL profiles only) ──
  // null = use aircraft's default fee profile
  customFeeProfileId String?

  // ── Client Delivery ───────────────────────────────────
  // Public share link — generated when quote is sent to client
  publicToken      String?   @unique // UUID v4 — used in /quotes/public/[token]
  clientEmail      String? // Recipient email override (falls back to customer.email)
  sentAt           DateTime? // When email was dispatched
  clientViewedAt   DateTime? // First time client opened the public link
  clientResponseAt DateTime? // When client accepted/declined via web
  clientResponse   String? // "ACCEPTED" | "DECLINED"
  clientNote       String? // Optional message from client

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking          Booking?
  costBreakdown    CostBreakdown?
  matchedEmptyLeg  FlightLeg?          @relation(fields: [matchedEmptyLegId], references: [id])
  aircraft         Aircraft?           @relation(fields: [aircraftId], references: [id])
  externalAircraft ExternalAircraft?   @relation(fields: [externalAircraftId], references: [id])
  request          QuoteRequest?       @relation(fields: [requestId], references: [id])
  customer         Customer            @relation(fields: [customerId], references: [id])
  charterInvoice   CharterInvoice?     @relation(fields: [charterInvoiceId], references: [id])
  customFeeProfile FeeScheduleProfile? @relation("QuoteFeeProfile", fields: [customFeeProfileId], references: [id])

  @@index([status])
}

/// Third-party aircraft registry.
/// When quoting with a non-owned aircraft, enter the registration once —
/// it is saved here and auto-filled on next use.
model ExternalAircraft {
  id           String  @id @default(cuid())
  registration String  @unique // e.g. D-AAAA, OE-LAX
  operatorName String // e.g. "Air Hamburg"
  operatorIcao String? // ICAO operator code
  operatorAoc  String? // AOC number
  aircraftType String // e.g. "Citation XLS+"
  manufacturer String?
  yearBuilt    Int?

  // Specs
  paxCapacity   Int?
  rangeNm       Int?
  cruiseSpeedKt Int?
  mtowTonnes    Float?

  // Media
  imageUrls       String? // JSON: string[]
  primaryImageUrl String?

  // Rates
  acmiRatePerHr    Float? // ACMI rate EUR/h if applicable
  charterRatePerHr Float? // typical charter rate
  currency         String @default("EUR")

  // Contacts
  contactName  String?
  contactPhone String?
  contactEmail String?

  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes Quote[]
}

/// Charter invoice generated when a quote reaches BOOKED → INVOICED.
/// Never deleted — use status CANCELLED + CreditNote for reversals.
/// Rechnungssteller-Gesellschaft (z.B. Jetmind GmbH, Neo Aviation AG)
/// Jede Gesellschaft hat eine eigene fortlaufende Rechnungsnummer.
model BillingEntity {
  id String @id @default(cuid())

  // Identity
  name           String // Kurzname, z.B. "Jetmind GmbH"
  legalName      String? // Vollständiger Firmenname für Rechnungsheader
  invoicePrefix  String  @default("INV") // z.B. "JM", "NA", "AA"
  lastInvoiceSeq Int     @default(0) // Fortlaufender Zähler — nie zurücksetzen
  lastCreditSeq  Int     @default(0)

  // Address
  street     String?
  city       String?
  postalCode String?
  country    String  @default("DE")

  // Tax & Bank
  vatId     String? // USt-ID, z.B. "DE123456789"
  taxNumber String? // Steuernummer
  iban      String?
  bic       String?
  bankName  String?

  // Contact
  email   String?
  phone   String?
  website String?

  // Branding
  logoUrl      String?
  primaryColor String  @default("#0ea5e9") // Hex, used in invoice PDF

  // Notes / audit
  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  charterInvoices CharterInvoice[]
  creditNotes     CreditNote[]

  @@index([isActive])
}

model CharterInvoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique // e.g. "JM-2026-0042" — prefix from BillingEntity
  status        String @default("DRAFT")
  // DRAFT → SENT → PAID / CANCELLED

  // Rechnungssteller
  billingEntityId String?
  billingEntity   BillingEntity? @relation(fields: [billingEntityId], references: [id])

  // Link back to quote
  quoteId String?

  // Customer
  customerId      String
  customerName    String
  customerAddress String?

  // Amounts
  subtotal          Float // pre-tax, pre-margin
  marginAmount      Float  @default(0)
  passengerTaxTotal Float  @default(0)
  vatAmount         Float  @default(0)
  vatPct            Float  @default(0)
  totalAmount       Float
  currency          String @default("EUR")

  // Line items stored as JSON for flexibility
  lineItemsJson String @default("[]")
  // [{description, amount, unit, qty, vatPct}]

  // Dates
  issuedDate    DateTime  @default(now())
  dueDate       DateTime
  paidDate      DateTime?
  cancelledDate DateTime?
  cancelReason  String?

  // Payment
  paymentMethod String?
  paymentRef    String?

  // PDF
  pdfUrl String?

  // Audit
  createdBy String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])
  creditNotes CreditNote[]
  quotes      Quote[]

  @@index([status])
  @@index([customerId])
  @@index([billingEntityId])
}

/// Credit note issued when a CharterInvoice is cancelled after payment.
/// Always references the original invoice. Never deleted.
model CreditNote {
  id                String @id @default(cuid())
  creditNoteNumber  String @unique // e.g. "JM-CN-2026-0003"
  originalInvoiceId String
  customerId        String
  customerName      String

  // Rechnungssteller (gleiche Entity wie die ursprüngliche Rechnung)
  billingEntityId String?
  billingEntity   BillingEntity? @relation(fields: [billingEntityId], references: [id])

  totalAmount   Float // negative = refund
  currency      String @default("EUR")
  lineItemsJson String @default("[]")

  reason     String
  issuedDate DateTime @default(now())
  pdfUrl     String?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  originalInvoice CharterInvoice @relation(fields: [originalInvoiceId], references: [id])
  customer        Customer       @relation(fields: [customerId], references: [id])

  @@index([billingEntityId])
}

// Customer extension: add relation to CharterInvoice + CreditNote

model CostBreakdown {
  id           String   @id @default(cuid())
  quoteId      String   @unique
  fuelCost     Float
