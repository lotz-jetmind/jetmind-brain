// ── CAMO: Workload Analysis (WT010) ──────────────────────────────────────────

model WorkloadAnalysis {
  id          String   @id @default(cuid())
  orgId       String

  wlaRef      String   @default("")
  periodLabel String   @default("")
  periodStart DateTime
  periodEnd   DateTime

