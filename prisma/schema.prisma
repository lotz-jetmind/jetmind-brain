// ─── Authority Communication Log ─────────────────────────────────────────────
// ORO.GEN.135 - all formal correspondence with regulatory authorities.
// Workflow: receive/send → attach files → assign tasks → communicate → close.
//
//   compliance_authority_contact     ← main case/dossier
//     └─ compliance_authority_attachment  ← PDFs, emails, letters
//     └─ compliance_authority_task        ← assigned action tasks
//     └─ compliance_authority_thread      ← chronological event log

model compliance_authority_contact {
  id          String   @id @default(cuid())
  orgId       String   @default("")
  date        DateTime
  authority   String
  // EASA | LBA | CAA | DGAC | FAA | ICAO | GCAA | BAZL | TCCA | CASA | INTERNAL | AUDITOR | VENDOR | PARTNER | OTHER
  sentTo      String?
  // Free text: who was this sent to / received from (person name, org, email)
  contactType String   @default("CORRESPONDENCE")
  // NOTIFICATION | CORRESPONDENCE | APPROVAL_REQUEST | INSPECTION | MEETING | EXEMPTION | NPA_RESPONSE | AUDIT_REQUEST | INTERNAL | OTHER
  subject     String
  reference   String?
  summary     String   @db.Text
  status      String   @default("OPEN")
  // NEW | IN_PROGRESS | AWAITING_RESPONSE | RESPONDED | CLOSED | ACKNOWLEDGED
  priority    String   @default("MEDIUM")
  deadline    DateTime?
  responseDate DateTime?
  responseNote String?  @db.Text
  closedAt    DateTime?
  closedById  String?
  createdById String?
  createdBy   User?    @relation("AuthorityContactCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attachments compliance_authority_attachment[]
  tasks       compliance_authority_task[]
  thread      compliance_authority_thread[]

  @@index([orgId, date])
  @@index([authority])
  @@index([status])
  @@index([deadline])
}

model compliance_authority_attachment {
  id        String   @id @default(cuid())
  orgId     String   @default("")
  contactId String

  filename      String
  fileUrl       String
  mimeType      String   @default("application/pdf")
  fileSizeBytes Int      @default(0)
  fileHash      String?

  direction    String   @default("INBOUND")
  // INBOUND | OUTBOUND | INTERNAL
  documentType String   @default("LETTER")
  // LETTER | EMAIL | EMAIL_PDF | INSPECTION_REPORT | APPLICATION | RESPONSE | EVIDENCE | OTHER

  description  String?
  sentDate     DateTime?
  receivedDate DateTime?

  uploadedById String?
  uploadedAt   DateTime @default(now())

  contact compliance_authority_contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([orgId])
  @@index([direction])
}

model compliance_authority_task {
  id        String   @id @default(cuid())
  orgId     String   @default("")
  contactId String

  title       String
  description String?  @db.Text
  status      String   @default("OPEN")
  // OPEN | IN_PROGRESS | DONE | CANCELLED
  priority    String   @default("MEDIUM")
  dueDate     DateTime?

  assignedToId   String?
  assignedToName String?
  assignedById   String?

  completedAt   DateTime?
  completedById String?
  completionNote String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact    compliance_authority_contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("AuthorityTaskAssignee", fields: [assignedToId], references: [id])

  @@index([contactId])
  @@index([orgId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
}

model compliance_authority_thread {
  id        String   @id @default(cuid())
  orgId     String   @default("")
  contactId String

  eventType  String   @default("NOTE")
  // RECEIVED | SENT | CALL | MEETING | NOTE | STATUS_CHANGE | TASK_COMPLETED | ATTACHMENT_ADDED
  direction  String?
  // INBOUND | OUTBOUND | INTERNAL

  title      String
  body       String?  @db.Text
  authorName String?
  authorId   String?

  recipientName  String?
  recipientEmail String?
  recipientOrg   String?

  attachmentId String?

  eventDate DateTime @default(now())
  createdAt DateTime @default(now())

  contact compliance_authority_contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([orgId])
  @@index([eventDate])
}

